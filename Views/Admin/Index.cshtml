@model IEnumerable<Delivery_System.Models.TblUser>

@{
    ViewData["Title"] = "Hệ Thống Quản Trị - Delivery System";
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin.css">
}

<div class="admin-wrapper">
    <!-- --- MODERN PAGE HEADER --- -->
    <div class="modern-page-header">
        <div>
            <h3>🛡️ Quản Lý Hệ Thống</h3>
            <div class="modern-page-header-meta">Chào mừng quản trị viên, đây là tình trạng vận hành hôm nay.</div>
        </div>
        
        <div class="header-actions" style="display: flex; gap: 10px;">
            <a asp-controller="Shift" asp-action="Index" class="btn-modern" style="background: rgba(255,255,255,0.15); color: white; border: 1px solid rgba(255,255,255,0.2); padding: 10px 20px; text-decoration: none; border-radius: 10px; font-weight: 700;">
                ⏰ Ca Làm Việc
            </a>
            <button class="btn-modern btn-add" onclick="showAddModal()" style="background: rgba(255,255,255,0.2); color: white; border: 1px solid rgba(255,255,255,0.3); padding: 10px 20px;">
                ➕ Thêm Nhân Viên Mới
            </button>
            <button class="btn-modern btn-add" onclick="showStationModal()" style="background: rgba(255,255,255,0.2); color: white; border: 1px solid rgba(255,255,255,0.3); padding: 10px 20px;">
                🏢 Thêm Trạm Mới
            </button>
        </div>
    </div>

    <!-- ... KPI SECTION ... -->
    <section class="kpi-grid">
        <div class="kpi-card blue">
            <span class="label">Doanh thu hôm nay</span>
            <span class="value">@string.Format("{0:N0}", ViewBag.RevenueToday) K</span>
            <span style="font-size: 0.8rem; opacity: 0.8;">VND (Chỉ đơn đã chuyển)</span>
        </div>
        <div class="kpi-card green">
            <span class="label">Nhân viên trực ca</span>
            <span class="value">@ViewBag.ActiveStaffCount</span>
            <span style="font-size: 0.8rem; opacity: 0.8;">Ca làm đang hoạt động</span>
        </div>
        <div class="kpi-card chart">
            <canvas id="revenueChart" style="max-height: 100px; width: 100%;"></canvas>
        </div>
    </section>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert-box alert-error">⚠️ @TempData["ErrorMessage"]</div>
    }
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert-box alert-success">✅ @TempData["SuccessMessage"]</div>
    }

    <!-- --- TAB SELECTION --- -->
    <div style="margin-bottom: 20px; display: flex; gap: 10px;">
        <button id="btnTabStaff" class="btn-tab active" onclick="showTab('staff')">👥 Quản Lý Nhân Viên</button>
        <button id="btnTabStation" class="btn-tab" onclick="showTab('station')">🏢 Quản Lý Trạm</button>
    </div>

    <!-- --- STAFF MANAGEMENT --- -->
    <main id="tabStaff" class="content-card tab-content active">
        <div class="section-title">
            <h2>Danh Sách Đội Ngũ Nhân Viên</h2>
            <div style="display: flex; gap: 15px;">
                <span class="badge badge-user">Tổng: @Model.Count()</span>
                <span class="badge badge-active">Mở: @Model.Count(u => u.Status == true)</span>
                <span class="badge badge-locked">Khóa: @Model.Count(u => u.Status != true)</span>
            </div>
        </div>

        <div class="search-container">
            <i>🔍</i>
            <input type="text" id="staffSearch" placeholder="Tìm kiếm tên hoặc số điện thoại..." oninput="filterStaff(this.value)">
        </div>

        <div class="table-responsive">
            <table>
                <thead>
                    <tr>
                        <th>Mã NV</th>
                        <th>Họ Tên Nhân Viên</th>
                        <th>Trạm Làm Việc</th>
                        <th>SĐT</th>
                        <th>Quyền Hạn</th>
                        <th>Trạng Thái</th>
                        <th style="text-align: center;">Thao Tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr class="staff-row" data-name="@user.FullName.ToLower()" data-phone="@user.Phone">
                            <td><strong style="color: var(--primary);">@user.UserId</strong></td>
                            <td>
                                <div style="font-weight: 700;">@user.FullName</div>
                                @* <div style="font-size: 0.75rem; color: #94a3b8;">@user.Username</div> *@
                            </td>
                            <td>
                                <span class="badge" style="background: #f0fdf4; color: #16a34a; border: 1px solid #dcfce7;">
                                    📍 @(user.Station?.StationName ?? "Chưa gán")
                                </span>
                            </td>
                            <td>@(string.IsNullOrEmpty(user.Phone) ? "—" : user.Phone)</td>
                            <td>
                                <span class="badge @(user.RoleId == "AD" ? "badge-admin" : "badge-user")">
                                    @(user.RoleId == "AD" ? "🛡️ Admin" : "👤 Nhân Viên")
                                </span>
                            </td>
                            <td>
                                <span class="badge @(user.Status == true ? "badge-active" : "badge-locked")">
                                    @(user.Status == true ? "● Hoạt động" : "● Đã khóa")
                                </span>
                            </td>
                            <td>
                                <div class="action-group">
                                    <button class="btn-s btn-s-blue" onclick="showChangePassModal('@user.UserId', '@user.FullName')">Đổi MK</button>
                                    
                                    <button class="btn-s btn-s-cyan" 
                                            onclick="showDetailsModal('@user.UserId', '@user.Username', '@user.FullName', '@(user.RoleId == "AD" ? "Admin" : "Nhân Viên")', '@user.Phone', '@user.Email', '@user.Status', '@user.CreatedAt?.ToString("dd/MM/yyyy HH:mm")')">Chi tiết</button>

                                    @if (user.RoleId != "AD")
                                    {
                                        <form asp-action="ToggleUser" method="POST" style="display:inline;">
                                            <input type="hidden" name="userID" value="@user.UserId">
                                            <button type="submit" class="btn-s @(user.Status == true ? "btn-s-orange" : "btn-s-green")">
                                                @(user.Status == true ? "Khóa" : "Mở")
                                            </button>
                                        </form>

                                        <button type="button" class="btn-s btn-s-red" onclick="confirmDeleteUser('@user.UserId')">Xóa</button>
                                        <form id="deleteUserForm-@user.UserId" asp-action="DeleteUser" method="POST" style="display:none;">
                                            <input type="hidden" name="userID" value="@user.UserId" />
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </main>

    <!-- --- STATION MANAGEMENT --- -->
    @{
        var stationList = ViewBag.StationList as IEnumerable<Delivery_System.Models.TblStation>;
    }
    <main id="tabStation" class="content-card tab-content" style="display: none;">
        <div class="section-title">
            <h2>Danh Sách Các Trạm</h2>
            <div style="display: flex; gap: 15px;">
                <span class="badge badge-active">Tổng: @(stationList?.Count() ?? 0)</span>
            </div>
        </div>

        <div class="table-responsive">
            <table>
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Tên Trạm</th>
                        <th>Địa Chỉ</th>
                        <th>SĐT</th>
                        <th>Trạng Thái</th>
                        <th style="text-align: center;">Thao Tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (stationList != null)
                    {
                        foreach (var s in stationList)
                        {
                            <tr>
                                <td><strong style="color: var(--primary);">@s.StationId</strong></td>
                                <td><div style="font-weight: 700;">@s.StationName</div></td>
                                <td>@s.Address</td>
                                <td>@s.Phone</td>
                                <td>
                                    <span class="badge @(s.IsActive == true ? "badge-active" : "badge-locked")">
                                        @(s.IsActive == true ? "● Hoạt động" : "● Tạm dừng")
                                    </span>
                                </td>
                                <td>
                                    <div class="action-group">
                                        <button class="btn-s btn-s-blue" onclick="showStationModal(@s.StationId, '@s.StationName', '@s.Address', '@s.Phone')">Sửa</button>
                                        
                                        <button class="btn-s btn-s-cyan" onclick="showStaffStationModal(@s.StationId, '@s.StationName')">👥 Nhân sự</button>

                                        <form asp-action="ToggleStation" method="POST" style="display:inline;">
                                            <input type="hidden" name="stationId" value="@s.StationId">
                                            <button type="submit" class="btn-s @(s.IsActive == true ? "btn-s-orange" : "btn-s-green")">
                                                @(s.IsActive == true ? "Tạm dừng" : "Kích hoạt")
                                            </button>
                                        </form>

                                        <button type="button" class="btn-s btn-s-red" onclick="confirmDeleteStation(@s.StationId)">Xóa</button>
                                        <form id="deleteStationForm-@s.StationId" asp-action="DeleteStation" method="POST" style="display:none;">
                                            <input type="hidden" name="stationId" value="@s.StationId" />
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </main>
</div>

<!-- --- MODALS --- -->

<div id="stationModal" class="modal">
    <div class="modal-content">
        <div class="modal-header"><h3 id="stationModalTitle">🏢 Thêm Trạm Mới</h3></div>
        <form asp-action="SaveStation" method="POST">
            <input type="hidden" name="stationId" id="stationId">
            <div class="form-group"><label>Mã Trạm (Quản lý)</label><input type="text" name="idStation" id="stationCode" placeholder="Ví dụ: HCM-Q1" required></div>
            <div class="form-group"><label>Tên Trạm</label><input type="text" name="stationName" id="stationName" required></div>
            <div class="form-group"><label>Địa Chỉ</label><input type="text" name="address" id="stationAddress"></div>
            <div class="form-group"><label>Số Điện Thoại</label><input type="tel" name="phone" id="stationPhone"></div>

            <div class="modal-footer">
                <button type="submit" class="btn-m btn-add" style="flex:2">Lưu Thông Tin</button>
                <button type="button" onclick="hideStationModal()" class="btn-cancel">Hủy</button>
            </div>
        </form>
    </div>
</div>

<div id="addModal" class="modal">
    <div class="modal-content">
        <div class="modal-header"><h3>➕ Thêm Nhân Viên Mới</h3></div>
        <form asp-action="SaveUser" method="POST" onsubmit="return validateAddForm()">
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px;">
                <div class="form-group"><label>Mã Nhân Viên</label><input type="text" name="newUserID" id="newUserID" required></div>
                <div class="form-group"><label>Tên Đăng Nhập</label><input type="text" name="newUsername" id="newUsername" required></div>
            </div>
            
            <div class="form-group"><label>Họ Và Tên</label><input type="text" name="newFullName" required></div>
            
            <div class="form-group">
                <label>Trạm Làm Việc</label>
                <select name="newStationID" class="form-control-modern" style="width:100%; padding:12px; border-radius:12px; border:2px solid #e2e8f0; background:#f8fafc;">
                    <option value="">-- Chọn trạm (Không bắt buộc) --</option>
                    @if (stationList != null)
                    {
                        foreach (var s in stationList)
                        {
                            <option value="@s.StationId">@s.StationName</option>
                        }
                    }
                </select>
            </div>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px;">
                <div class="form-group"><label>Mật Khẩu</label><input type="password" name="newPassword" id="newPassword" required></div>
                <div class="form-group"><label>Xác Nhận MK</label><input type="password" id="newConfirmPassword" required></div>
            </div>
            <small id="addPassErr" style="color:var(--danger);display:none;font-weight:700;margin-top:-10px;margin-bottom:10px;">Mật khẩu không khớp!</small>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px;">
                <div class="form-group"><label>Số Điện Thoại</label><input type="tel" name="newPhone" required></div>
                <div class="form-group"><label>Email</label><input type="email" name="newEmail" required></div>
            </div>

            <div class="modal-footer">
                <button type="submit" class="btn-m btn-add" style="flex:2">Lưu Nhân Viên</button>
                <button type="button" onclick="hideAddModal()" class="btn-cancel">Hủy</button>
            </div>
        </form>
    </div>
</div>

<div id="changePassModal" class="modal">
    <div class="modal-content">
        <div class="modal-header"><h3>🔑 Đổi Mật Khẩu</h3></div>
        <p id="cpUserLabel"></p>
        <form asp-action="ChangePassword" method="POST" onsubmit="return validateChangePassForm()">
            <input type="hidden" name="cpUserID" id="cpUserID">
            <div class="form-group"><label>Mật Khẩu Mới</label><input type="password" name="cpNewPassword" id="cpNewPassword" required></div>
            <div class="form-group"><label>Xác Nhận MK</label><input type="password" id="cpConfirmPassword" required>
            <small id="cpPassErr" style="color:var(--danger);display:none;font-weight:700;">MK không khớp!</small></div>
            <div class="modal-footer">
                <button type="submit" class="btn-m btn-add" style="flex:2">Cập Nhật</button>
                <button type="button" onclick="hideChangePassModal()" class="btn-cancel">Hủy</button>
            </div>
        </form>
    </div>
</div>

<div id="detailsModal" class="modal">
    <div class="modal-content">
        <div class="modal-header"><h3>👤 Hồ Sơ Nhân Viên</h3></div>
        <div class="details-list">
            <div class="details-row"><span class="det-label">Mã nhân viên:</span><span class="det-value det-highlight" id="detUserId"></span></div>
            <div class="details-row"><span class="det-label">Tài khoản:</span><span class="det-value" id="detUsername"></span></div>
            <div class="details-row"><span class="det-label">Họ và tên:</span><span class="det-value" id="detFullName"></span></div>
            <div class="details-row"><span class="det-label">Quyền hạn:</span><span class="det-value" id="detRole"></span></div>
            <div class="details-row"><span class="det-label">Điện thoại:</span><span class="det-value" id="detPhone"></span></div>
            <div class="details-row"><span class="det-label">Email:</span><span class="det-value" id="detEmail"></span></div>
            <div class="details-row"><span class="det-label">Trạng thái:</span><span class="det-value" id="detStatus"></span></div>
            <div class="details-row"><span class="det-label">Ngày tạo:</span><span class="det-value" id="detCreatedAt"></span></div>
        </div>
        <div class="modal-footer"><button type="button" onclick="hideDetailsModal()" class="btn-m btn-add" style="width:100%">Đóng</button></div>
    </div>
</div>

<div id="staffStationModal" class="modal">
    <div class="modal-content" style="max-width: 700px; width: 95%;">
        <div class="modal-header"><h3 id="staffStationModalTitle">👥 Quản Lý Nhân Sự Tại Trạm</h3></div>
        <input type="hidden" id="currentStationId">
        
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-top: 15px;">
            <!-- CỘT 1: NHÂN VIÊN TRONG TRẠM -->
            <div class="station-staff-zone">
                <h4 style="margin-bottom: 10px; font-size: 0.9rem; color: var(--primary);">📍 NHÂN VIÊN TRONG TRẠM</h4>
                <div id="inStationList" style="max-height: 300px; overflow-y: auto; border: 1px solid #e2e8f0; border-radius: 8px; padding: 10px;">
                    <!-- JS render -->
                </div>
            </div>

            <!-- CỘT 2: NHÂN VIÊN CHƯA CÓ TRẠM -->
            <div class="station-staff-zone">
                <h4 style="margin-bottom: 10px; font-size: 0.9rem; color: var(--text-muted);">📢 NHÂN VIÊN CHƯA CÓ TRẠM</h4>
                <div id="availableList" style="max-height: 300px; overflow-y: auto; border: 1px solid #e2e8f0; border-radius: 8px; padding: 10px;">
                    <!-- JS render -->
                </div>
            </div>
        </div>

        <div class="modal-footer">
            <button type="button" onclick="hideStaffStationModal()" class="btn-cancel">Đóng</button>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const ctx = document.getElementById('revenueChart').getContext('2d');
        new Chart(ctx, {
            type: 'line',
            data: {
                labels: @Html.Raw(Json.Serialize(ViewBag.ChartLabels)),
                datasets: [{
                    data: @Html.Raw(Json.Serialize(ViewBag.ChartData)),
                    borderColor: '#4f46e5', backgroundColor: 'rgba(79, 70, 229, 0.1)',
                    borderWidth: 3, fill: true, tension: 0.4, pointRadius: 0
                }]
            },
            options: { plugins: { legend: { display: false } }, scales: { x: { display: false }, y: { display: false } } }
        });

        function confirmDeleteUser(id) {
            Swal.fire({
                title: 'Xóa nhân viên?', text: "Hành động này không thể hoàn tác!", icon: 'warning',
                showCancelButton: true, confirmButtonColor: '#ef4444', confirmButtonText: 'Xóa ngay', cancelButtonText: 'Hủy'
            }).then((result) => { if (result.isConfirmed) document.getElementById('deleteUserForm-' + id).submit(); });
        }

        function showAddModal() { document.getElementById('addModal').style.display = 'flex'; }
        function hideAddModal() { document.getElementById('addModal').style.display = 'none'; }
        function showChangePassModal(id, name) { document.getElementById('cpUserID').value = id; document.getElementById('cpUserLabel').textContent = name; document.getElementById('changePassModal').style.display = 'flex'; }
        function hideChangePassModal() { document.getElementById('changePassModal').style.display = 'none'; }
        function showDetailsModal(id, user, name, role, phone, email, status, created) {
            document.getElementById('detUserId').textContent = id; document.getElementById('detUsername').textContent = user;
            document.getElementById('detFullName').textContent = name; document.getElementById('detRole').textContent = role;
            document.getElementById('detPhone').textContent = phone || '—'; document.getElementById('detEmail').textContent = email || '—';
            document.getElementById('detStatus').innerHTML = (status.toLowerCase() === 'true') ? '<span style="color:#10b981">● Hoạt động</span>' : '<span style="color:#ef4444">● Đã khóa</span>';
            document.getElementById('detCreatedAt').textContent = created; document.getElementById('detailsModal').style.display = 'flex';
        }
        function hideDetailsModal() { document.getElementById('detailsModal').style.display = 'none'; }

        function validateAddForm() {
            const p1 = document.getElementById('newPassword').value; const p2 = document.getElementById('newConfirmPassword').value;
            if (p1 !== p2) { document.getElementById('addPassErr').style.display = 'block'; return false; } return true;
        }
        function validateChangePassForm() {
            const p1 = document.getElementById('cpNewPassword').value; const p2 = document.getElementById('cpConfirmPassword').value;
            if (p1 !== p2) { document.getElementById('cpPassErr').style.display = 'block'; return false; } return true;
        }

        // --- TAB MANAGEMENT ---
        function showTab(tabName) {
            document.querySelectorAll('.tab-content').forEach(t => t.style.display = 'none');
            document.querySelectorAll('.btn-tab').forEach(b => b.classList.remove('active'));

            if (tabName === 'staff') {
                document.getElementById('tabStaff').style.display = 'block';
                document.getElementById('btnTabStaff').classList.add('active');
            } else {
                document.getElementById('tabStation').style.display = 'block';
                document.getElementById('btnTabStation').classList.add('active');
            }
        }

        // --- STATION MODAL ---
        function showStationModal(id = 0, name = '', addr = '', phone = '') {
            document.getElementById('stationId').value = id;
            document.getElementById('stationName').value = name;
            document.getElementById('stationAddress').value = addr;
            document.getElementById('stationPhone').value = phone;
            
            document.getElementById('stationModalTitle').textContent = id > 0 ? '📝 Sửa Thông Tin Trạm' : '🏢 Thêm Trạm Mới';
            document.getElementById('stationModal').style.display = 'flex';
        }

        function hideStationModal() {
            document.getElementById('stationModal').style.display = 'none';
        }

        function confirmDeleteStation(id) {
            Swal.fire({
                title: 'Xóa trạm này?', text: "Dữ liệu liên quan đến trạm có thể bị ảnh hưởng!", icon: 'warning',
                showCancelButton: true, confirmButtonColor: '#ef4444', confirmButtonText: 'Xóa ngay', cancelButtonText: 'Hủy'
            }).then((result) => { if (result.isConfirmed) document.getElementById('deleteStationForm-' + id).submit(); });
        }

        // --- STAFF STATION MANAGEMENT JS ---
        async function showStaffStationModal(stationId, stationName) {
            document.getElementById('currentStationId').value = stationId;
            document.getElementById('staffStationModalTitle').textContent = '👥 Nhân Sự Tại: ' + stationName;
            
            await refreshStaffLists(stationId);
            document.getElementById('staffStationModal').style.display = 'flex';
        }

        function hideStaffStationModal() {
            document.getElementById('staffStationModal').style.display = 'none';
            // Reload page to see changes in main table
            location.reload();
        }

        async function refreshStaffLists(stationId) {
            const response = await fetch(`/Admin/GetStaffByStation?stationId=${stationId}`);
            const data = await response.json();
            
            const inList = document.getElementById('inStationList');
            const avList = document.getElementById('availableList');
            
            inList.innerHTML = data.inStation.length > 0 ? '' : '<p style="font-size:0.8rem; color:#94a3b8; text-align:center;">Trạm chưa có nhân sự</p>';
            avList.innerHTML = data.available.length > 0 ? '' : '<p style="font-size:0.8rem; color:#94a3b8; text-align:center;">Không có nhân viên trống</p>';

            data.inStation.forEach(u => {
                inList.innerHTML += `
                    <div style="display:flex; justify-content:space-between; align-items:center; padding:8px; border-bottom:1px solid #f1f5f9;">
                        <div>
                            <div style="font-weight:700; font-size:0.85rem;">${u.fullName}</div>
                            <div style="font-size:0.75rem; color:#64748b;">ID: ${u.userId}</div>
                        </div>
                        <button onclick="removeStaff('${u.userId}')" style="background:#fee2e2; color:#ef4444; border:none; padding:4px 8px; border-radius:4px; font-size:0.75rem; cursor:pointer;">✖ Gỡ</button>
                    </div>`;
            });

            data.available.forEach(u => {
                avList.innerHTML += `
                    <div style="display:flex; justify-content:space-between; align-items:center; padding:8px; border-bottom:1px solid #f1f5f9;">
                        <div>
                            <div style="font-weight:700; font-size:0.85rem;">${u.fullName}</div>
                            <div style="font-size:0.75rem; color:#64748b;">ID: ${u.userId}</div>
                        </div>
                        <button onclick="addStaff('${u.userId}')" style="background:#dcfce7; color:#16a34a; border:none; padding:4px 8px; border-radius:4px; font-size:0.75rem; cursor:pointer;">✚ Thêm</button>
                    </div>`;
            });
        }

        async function addStaff(userId) {
            const stationId = document.getElementById('currentStationId').value;
            const formData = new FormData();
            formData.append('userId', userId);
            formData.append('stationId', stationId);

            const response = await fetch('/Admin/AddStaffToStation', { method: 'POST', body: formData });
            const data = await response.json();
            if (data.success) await refreshStaffLists(stationId);
            else alert(data.message);
        }

        async function removeStaff(userId) {
            const stationId = document.getElementById('currentStationId').value;
            const formData = new FormData();
            formData.append('userId', userId);

            const response = await fetch('/Admin/RemoveStaffFromStation', { method: 'POST', body: formData });
            const data = await response.json();
            if (data.success) await refreshStaffLists(stationId);
            else alert(data.message);
        }

        function filterStaff(kw) {
            const k = kw.toLowerCase(); document.querySelectorAll('.staff-row').forEach(r => {
                const n = r.getAttribute('data-name'); const p = r.getAttribute('data-phone');
                r.style.display = (n.includes(k) || p.includes(k)) ? '' : 'none';
            });
        }
        window.onclick = (e) => { if (e.target.className === 'modal') { hideAddModal(); hideChangePassModal(); hideDetailsModal(); } };
    </script>
}
