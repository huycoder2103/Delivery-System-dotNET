@model IEnumerable<Delivery_System.Models.TblUser>

@{
    ViewData["Title"] = "Quản Lý Admin";
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin.css" />
}

<!-- --- ADMIN DASHBOARD --- -->
<div class="admin-container" style="margin-bottom: 20px; background: #fdfdfd;">
    <div class="admin-header">
        <h2>BẢNG ĐIỀU KHIỂN HỆ THỐNG</h2>
    </div>
    <div class="kpi-row">
        <div class="kpi-mini blue" style="background: #e7f3ff; border: 1px solid #b3d7ff;">
            <div class="v" style="color: #007bff;">
                @string.Format("{0:N0}", ViewBag.RevenueToday) K
            </div>
            <div class="l">Doanh thu hôm nay</div>
        </div>
        <div class="kpi-mini green" style="background: #e6fffa; border: 1px solid #b2f5ea;">
            <div class="v" style="color: #38b2ac;">@ViewBag.ActiveStaffCount</div>
            <div class="l">Nhân viên đang trong ca làm</div>
        </div>
        <div class="kpi-mini" style="flex: 2; background: white; padding: 10px;">
            <canvas id="revenueChart" style="max-height: 120px; width: 100%;"></canvas>
        </div>
    </div>
</div>

@if (TempData["ErrorMessage"] != null)
{
    <div style="background:#f8d7da;color:#721c24;padding:10px 20px;text-align:center;font-weight:bold;margin-bottom:10px; border-radius: 8px;">
        ❌ @TempData["ErrorMessage"]
    </div>
}
@if (TempData["SuccessMessage"] != null)
{
    <div style="background:#d4edda;color:#155724;padding:10px 20px;text-align:center;font-weight:bold;margin-bottom:10px; border-radius: 8px;">
        ✅ @TempData["SuccessMessage"]
    </div>
}

<div class="admin-container">
    <div class="admin-header">
        <h2>QUẢN LÝ NHÂN VIÊN</h2>
        <button class="btn-cyan" onclick="showAddModal()">+ Thêm Nhân Viên Mới</button>
    </div>

    <div class="kpi-row">
        <div class="kpi-mini">
            <div class="v">@Model.Count()</div>
            <div class="l">Tổng nhân viên</div>
        </div>
        <div class="kpi-mini green">
            <div class="v">@Model.Count(u => u.Status == true)</div>
            <div class="l">Đang hoạt động</div>
        </div>
        <div class="kpi-mini red">
            <div class="v">@Model.Count(u => u.Status != true)</div>
            <div class="l">Tạm khóa</div>
        </div>
    </div>

    <div class="search-bar">
        <input type="text" id="staffSearch" placeholder="🔍 Tìm theo tên hoặc SĐT..." oninput="filterStaff(this.value)">
        <button class="btn-search">Tìm kiếm</button>
        <span class="result-count" id="resultCount"></span>
    </div>

    <div class="table-responsive">
        <table>
            <thead>
                <tr>
                    <th>#</th>
                    <th>Mã NV</th>
                    <th>Họ Tên</th>
                    <th>SĐT</th>
                    <th>Quyền</th>
                    <th>Tài Khoản</th>
                    <th>Thao Tác</th>
                </tr>
            </thead>
            <tbody>
                @{ int count = 1; }
                @foreach (var user in Model)
                {
                    <tr class="staff-row" data-name="@user.FullName.ToLower()" data-phone="@user.Phone">
                        <td>@(count++)</td>
                        <td><strong>@user.UserId</strong></td>
                        <td>@user.FullName</td>
                        <td>@(string.IsNullOrEmpty(user.Phone) ? "-" : user.Phone)</td>
                        <td>
                            <span class="badge-@(user.RoleId == "AD" ? "admin" : "user")">
                                @(user.RoleId == "AD" ? "Admin" : "Nhân Viên")
                            </span>
                        </td>
                        <td>
                            <span class="@(user.Status == true ? "status-active" : "status-inactive")">
                                @(user.Status == true ? "✅ Mở" : "⛔ Khóa")
                            </span>
                        </td>
                        <td>
                            <div style="display: flex; gap: 5px; justify-content: center;">
                                <form asp-action="ToggleUser" method="POST" style="display:inline;">
                                    <input type="hidden" name="userID" value="@user.UserId">
                                    <input type="submit" value="@(user.Status == true ? "Khóa" : "Mở")" 
                                           class="btn-action @(user.Status == true ? "btn-orange" : "btn-green")" style="width: 60px;">
                                </form>
                                <button class="btn-action btn-blue" onclick="showChangePassModal('@user.UserId', '@user.FullName')" style="width: 70px;">Đổi MK</button>
                                
                                @if (user.UserId != "admin")
                                {
                                    <button type="button" class="btn-action" style="background:#fce8e6; color:#d93025; border:none; border-radius:4px; cursor:pointer;" 
                                            onclick="confirmDeleteUser('@user.UserId')">🗑️ Xóa</button>
                                    <form id="deleteUserForm-@user.UserId" asp-action="DeleteUser" method="POST" style="display:none;">
                                        <input type="hidden" name="userID" value="@user.UserId" />
                                    </form>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- MODAL: THÊM NHÂN VIÊN -->
<div id="addModal" class="modal">
    <div class="modal-content">
        <h3>➕ THÊM NHÂN VIÊN MỚI</h3>
        <form asp-action="SaveUser" method="POST" onsubmit="return validateAddForm()">
            <div class="group">
                <label>Mã Tài Khoản <span style="color:red">*</span></label>
                <input type="text" name="newUserID" id="newUserID" class="inp" required placeholder="VD: NV05">
            </div>
            <div class="group">
                <label>Họ Tên <span style="color:red">*</span></label>
                <input type="text" name="newFullName" class="inp" required placeholder="Nguyễn Văn A">
            </div>
            <div class="group">
                <label>Mật Khẩu <span style="color:red">*</span></label>
                <input type="password" name="newPassword" id="newPassword" class="inp" required placeholder="Nhập mật khẩu">
            </div>
            <div class="group">
                <label>Xác Nhận Mật Khẩu <span style="color:red">*</span></label>
                <input type="password" id="newConfirmPassword" class="inp" required placeholder="Nhập lại mật khẩu">
                <small id="addPassErr" style="color:red;display:none;">Mật khẩu không khớp!</small>
            </div>
            <div class="group">
                <label>Số Điện Thoại</label>
                <input type="tel" name="newPhone" class="inp" placeholder="0901234567">
            </div>
            <div class="group">
                <label>Email</label>
                <input type="email" name="newEmail" class="inp" placeholder="abc@company.vn">
            </div>
            <div class="modal-footer">
                <input type="submit" value="💾 Lưu Nhân Viên" class="btn-cyan">
                <button type="button" onclick="hideAddModal()" class="btn-back">Hủy</button>
            </div>
        </form>
    </div>
</div>

<!-- MODAL: ĐỔI MẬT KHẨU -->
<div id="changePassModal" class="modal">
    <div class="modal-content">
        <h3>🔑 ĐỔI MẬT KHẨU</h3>
        <p id="cpUserLabel" style="color:#555;margin-bottom:15px;"></p>
        <form asp-action="ChangePassword" method="POST" onsubmit="return validateChangePassForm()">
            <input type="hidden" name="cpUserID" id="cpUserID">
            <div class="group">
                <label>Mật Khẩu Mới <span style="color:red">*</span></label>
                <input type="password" name="cpNewPassword" id="cpNewPassword" class="inp" required placeholder="Nhập mật khẩu mới">
            </div>
            <div class="group">
                <label>Xác Nhận Mật Khẩu Mới <span style="color:red">*</span></label>
                <input type="password" id="cpConfirmPassword" class="inp" required placeholder="Nhập lại mật khẩu mới">
                <small id="cpPassErr" style="color:red;display:none;">Mật khẩu không khớp!</small>
            </div>
            <div class="modal-footer">
                <input type="submit" value="✅ Xác Nhận Đổi" class="btn-cyan">
                <button type="button" onclick="hideChangePassModal()" class="btn-back">Hủy</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        function confirmDeleteUser(id) {
            Swal.fire({
                title: 'Xóa nhân viên?',
                text: "Tài khoản " + id + " sẽ bị xóa khỏi hệ thống!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#3085d6',
                confirmButtonText: 'Xác nhận xóa',
                cancelButtonText: 'Hủy'
            }).then((result) => {
                if (result.isConfirmed) {
                    document.getElementById('deleteUserForm-' + id).submit();
                }
            })
        }

        function showAddModal() { document.getElementById('addModal').style.display = 'flex'; }
        function hideAddModal() { document.getElementById('addModal').style.display = 'none'; }
        
        function showChangePassModal(userID, fullName) {
            document.getElementById('cpUserID').value = userID;
            document.getElementById('cpUserLabel').textContent = 'Nhân viên: ' + fullName + ' (' + userID + ')';
            document.getElementById('changePassModal').style.display = 'flex';
        }
        function hideChangePassModal() { document.getElementById('changePassModal').style.display = 'none'; }

        function validateAddForm() {
            const p1 = document.getElementById('newPassword').value;
            const p2 = document.getElementById('newConfirmPassword').value;
            if (p1 !== p2) { document.getElementById('addPassErr').style.display = 'block'; return false; }
            return true;
        }

        function validateChangePassForm() {
            const p1 = document.getElementById('cpNewPassword').value;
            const p2 = document.getElementById('cpConfirmPassword').value;
            if (p1 !== p2) { document.getElementById('cpPassErr').style.display = 'block'; return false; }
            return true;
        }

        function filterStaff(keyword) {
            const kw = keyword.toLowerCase();
            const rows = document.querySelectorAll('.staff-row');
            rows.forEach(row => {
                const name = row.getAttribute('data-name');
                const phone = row.getAttribute('data-phone');
                row.style.display = (name.includes(kw) || phone.includes(kw)) ? '' : 'none';
            });
        }

        window.onclick = function (e) {
            if (e.target.className === 'modal') {
                hideAddModal();
                hideChangePassModal();
            }
        };
    </script>
}
