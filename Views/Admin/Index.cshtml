@model IEnumerable<Delivery_System.Models.TblUser>

@{
    ViewData["Title"] = "Hệ Thống Quản Trị - Delivery System";
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin.css">
}

<div class="admin-wrapper">
    <div class="admin-page-header">
        <div>
            <h3>🛡️ Quản Lý Hệ Thống</h3>
            <div class="admin-page-header-meta">Chào mừng quản trị viên, đây là tình trạng vận hành hôm nay.</div>
        </div>
    
        <div class="admin-header-actions">
            <a asp-controller="Report" asp-action="Index" class="admin-btn-header-action">
                ⏰ Ca Làm Việc
            </a>
            <button class="admin-btn-modern admin-btn-add" onclick="showAddModal()">
                ➕ Thêm Nhân Viên Mới
            </button>
            <button class="admin-btn-modern admin-btn-add" onclick="showStationModal()">
                🏢 Thêm Trạm Mới
            </button>
        </div>
    </div>

    <section class="admin-kpi-grid">
        <div class="admin-kpi-card admin-card-revenue">
            <div class="admin-stat-label">Doanh thu hệ thống (Ngày)</div>
            <div class="admin-stat-value admin-text-primary">@ViewBag.RevenueToday.ToString("N0") k</div>
            <div class="admin-stat-note">(Tổng TR + CT đơn đã giao)</div>
        </div>

        <div class="admin-kpi-card admin-card-staff-count">
            <span class="admin-stat-label">Nhân viên trực ca</span>
            <span class="admin-stat-value admin-text-success">@ViewBag.ActiveStaffCount</span>
            <span class="admin-stat-note">Ca làm đang hoạt động</span>
        </div>

        <div class="admin-chart-card">
            <h4 class="admin-chart-title">Doanh thu 7 ngày gần nhất</h4>
            <canvas id="revenueChart" class="admin-revenue-chart"></canvas>
        </div>
    </section>

    <div class="admin-tabs-container">
        <button id="btnTabStaff" class="admin-btn-tab active" onclick="showTab('staff')">👥 Quản Lý Nhân Viên</button>
        <button id="btnTabStation" class="admin-btn-tab" onclick="showTab('station')">🏢 Quản Lý Trạm</button>
    </div>

    <main id="tabStaff" class="admin-content-card admin-tab-content active">
        <div class="admin-section-title">
            <h2>Danh Sách Đội Ngũ Nhân Viên</h2>
            <div class="admin-staff-meta-badges">
                <span class="admin-badge admin-badge-user">Tổng: @Model.Count()</span>
                <span class="admin-badge admin-badge-active">Mở: @Model.Count(u => u.Status == true)</span>
                <span class="admin-badge admin-badge-locked">Khóa: @Model.Count(u => u.Status != true)</span>
            </div>
        </div>

        <div class="admin-search-container">
            <div class="admin-search-box">
                <i>🔍</i>
                <input type="text" id="staffSearch" placeholder="Tìm kiếm tên hoặc số điện thoại..." oninput="filterStaff()">
            </div>
            <div class="admin-filter-box">
                <select id="stationFilter" onchange="filterStaff()" class="admin-form-control">
                    <option value="">-- Tất cả các trạm --</option>
                    @if (ViewBag.StationList != null)
                    {
                        foreach (var s in ViewBag.StationList as IEnumerable<Delivery_System.Models.TblStation>)
                        {
                            <option value="@s.StationId">@s.StationName (@s.StationId)</option>
                        }
                    }
                </select>
            </div>
        </div>

        <div class="admin-table-responsive">
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>Mã NV</th>
                        <th>Họ Tên Nhân Viên</th>
                        <th>Trạm Làm Việc</th>
                        <th>SĐT</th>
                        <th>Quyền Hạn</th>
                        <th>Trạng Thái</th>
                        <th>Ca Làm</th>
                        <th class="admin-text-center">Thao Tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        bool isInShift = user.TblWorkShifts.Any(s => s.Status == "ACTIVE");
                        <tr class="admin-staff-row" 
                            data-id="@user.UserId.ToLower()" 
                            data-name="@user.FullName.ToLower()" 
                            data-phone="@user.Phone" 
                            data-station="@user.StationId">
                            <td><strong class="admin-text-primary">@user.UserId</strong></td>
                            <td>
                                <div class="admin-font-bold">@user.FullName</div>
                            </td>
                            <td>
                                @if (user.Station != null)
                                {
                                    <span class="admin-badge admin-station-badge" onclick="showAssignStationModal('@user.UserId', '@user.FullName')">
                                        📍 @user.Station.StationName
                                    </span>
                                }
                                else
                                {
                                    <span class="admin-badge admin-station-badge-empty" onclick="showAssignStationModal('@user.UserId', '@user.FullName')">
                                        Chưa có trạm
                                    </span>
                                }
                            </td>
                            <td>@(string.IsNullOrEmpty(user.Phone) ? "—" : user.Phone)</td>
                            <td>
                                <span class="admin-badge @(user.RoleId == "AD" ? "admin-badge-role-admin" : "admin-badge-user")">
                                    @(user.RoleId == "AD" ? "🛡️ Admin" : "👤 Nhân Viên")
                                </span>
                            </td>
                            <td>
                                <span class="admin-badge @(user.Status == true ? "admin-badge-active" : "admin-badge-locked")">
                                    @(user.Status == true ? "● Hoạt động" : "● Đã khóa")
                                </span>
                            </td>
                            <td>
                                @if (isInShift)
                                {
                                    <span class="admin-badge" style="background: #dcfce7; color: #15803d; border: 1px solid #bbf7d0;">● Trong ca</span>
                                }
                                else
                                {
                                    <span class="admin-badge" style="background: #fee2e2; color: #b91c1c; border: 1px solid #fecaca;">● Ngoài ca</span>
                                }
                            </td>
                            <td>
                                <div class="admin-action-group">
                                    <button class="admin-btn-small admin-btn-blue" onclick="showChangePassModal('@user.UserId', '@user.FullName')">Đổi MK</button>
                                
                                    <button class="admin-btn-small admin-btn-cyan"
                                            onclick="showDetailsModal('@user.UserId', '@user.Username', '@user.FullName', '@(user.RoleId == "AD" ? "Admin" : "Nhân Viên")', '@user.Phone', '@user.Email', '@user.Status', '@user.CreatedAt?.ToString("dd/MM/yyyy HH:mm")', '@(user.StationId)')">
                                        Chi tiết
                                    </button>
                                    @if (isInShift)
                                    {
                                        <button type="button" class="admin-btn-small admin-btn-red" onclick="adminEndShiftDirect('@user.UserId', '@user.FullName')">Kết ca</button>
                                    }

                                    @if (user.RoleId != "AD")
                                    {
                                        <button type="button" class="admin-btn-small @(user.Status == true ? "admin-btn-orange" : "admin-btn-green")" onclick="toggleUserDirect('@user.UserId')">
                                            @(user.Status == true ? "Khóa" : "Mở")
                                        </button>

                                        <button type="button" class="admin-btn-small admin-btn-red" onclick="deleteUserDirect('@user.UserId', '@user.FullName')">Xóa</button>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </main>

    @{
        var stationList = ViewBag.StationList as IEnumerable<Delivery_System.Models.TblStation>;
    }
    <main id="tabStation" class="admin-content-card admin-tab-content admin-display-none">
        <div class="admin-section-title">
            <h2>Danh Sách Các Trạm</h2>
            <div class="admin-staff-meta-badges">
                <span class="admin-badge admin-badge-active">Tổng: @(stationList?.Count() ?? 0)</span>
            </div>
        </div>

        <div class="admin-search-container">
            <div class="admin-search-box">
                <i>🔍</i>
                <input type="text" id="stationSearch" placeholder="Tìm kiếm mã trạm hoặc tên trạm..." oninput="filterStation()">
            </div>
        </div>

        <div class="admin-table-responsive">
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Tên Trạm</th>
                        <th>Địa Chỉ</th>
                        <th>SĐT</th>
                        <th>Trạng Thái</th>
                        <th class="admin-text-center">Thao Tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (stationList != null)
                    {
                        foreach (var s in stationList)
                        {
                            <tr class="admin-station-row" data-id="@s.StationId" data-name="@s.StationName.ToLower()">
                                <td><strong class="admin-text-primary">@s.StationId</strong></td>
                                <td><div class="admin-font-bold">@s.StationName</div></td>
                                <td>@s.Address</td>
                                <td>@s.Phone</td>
                                <td>
                                    <span class="admin-badge @(s.IsActive == true ? "admin-badge-active" : "admin-badge-locked")">
                                        @(s.IsActive == true ? "● Hoạt động" : "● Tạm dừng")
                                    </span>
                                </td>
                                <td>
                                    <div class="admin-action-group">
                                        <button class="admin-btn-small admin-btn-blue" onclick="showStationModal(@s.StationId, '@s.StationName', '@s.Address', '@s.Phone')">Sửa</button>
                                    
                                        <button class="admin-btn-small admin-btn-cyan" onclick="showStaffStationModal(@s.StationId, '@s.StationName')">👥 Nhân sự</button>

                                        <button type="button" class="admin-btn-small @(s.IsActive == true ? "admin-btn-orange" : "admin-btn-green")" onclick="toggleStationDirect(@s.StationId)">
                                            @(s.IsActive == true ? "Tạm dừng" : "Kích hoạt")
                                        </button>

                                        <button type="button" class="admin-btn-small admin-btn-red" onclick="deleteStationDirect(@s.StationId, '@s.StationName')">Xóa</button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </main>
</div>

<div id="stationModal" class="admin-modal">
    <div class="admin-modal-content">
        <div class="admin-modal-header"><h3 id="stationModalTitle">🏢 Thêm Trạm Mới</h3></div>
        <form asp-action="SaveStation" method="POST">
            <input type="hidden" name="stationId" id="stationId">
            <div class="admin-form-group"><label>Tên Trạm</label><input type="text" name="stationName" id="stationName" class="admin-form-control" required></div>
            <div class="admin-form-group"><label>Địa Chỉ</label><input type="text" name="address" id="stationAddress" class="admin-form-control"></div>
            <div class="admin-form-group"><label>Số Điện Thoại</label><input type="tel" name="phone" id="stationPhone" class="admin-form-control"></div>

            <div class="admin-modal-footer">
                <button type="submit" class="admin-btn-medium admin-btn-add admin-flex-2">Lưu Thông Tin</button>
                <button type="button" onclick="hideStationModal()" class="admin-btn-cancel">Hủy</button>
            </div>
        </form>
    </div>
</div>

<div id="addModal" class="admin-modal">
    <div class="admin-modal-content">
        <div class="admin-modal-header"><h3>➕ Thêm Nhân Viên Mới</h3></div>
        <form asp-action="SaveUser" method="POST" onsubmit="return validateAddForm()">
            <div class="admin-grid-2-col">
                <div class="admin-form-group"><label>Mã Nhân Viên</label><input type="text" name="newUserID" id="newUserID" class="admin-form-control" required></div>
                <div class="admin-form-group"><label>Tên Đăng Nhập</label><input type="text" name="newUsername" id="newUsername" class="admin-form-control" required></div>
            </div>
        
            <div class="admin-form-group"><label>Họ Và Tên</label><input type="text" name="newFullName" class="admin-form-control" required></div>
        
            <div class="admin-form-group">
                <label>Trạm Làm Việc</label>
                <select name="newStationID" class="admin-form-control">
                    <option value="">-- Chọn trạm (Không bắt buộc) --</option>
                    @if (stationList != null)
                    {
                        foreach (var s in stationList)
                        {
                            <option value="@s.StationId">@s.StationName (@s.StationId)</option>
                        }
                    }
                </select>
            </div>

            <div class="admin-grid-2-col">
                <div class="admin-form-group"><label>Mật Khẩu</label><input type="password" name="newPassword" id="newPassword" class="admin-form-control" required></div>
                <div class="admin-form-group"><label>Xác Nhận MK</label><input type="password" id="newConfirmPassword" class="admin-form-control" required></div>
            </div>
            <small id="addPassErr" class="admin-text-danger admin-font-bold admin-mt-n10 admin-mb-10 admin-display-none">Mật khẩu không khớp!</small>

            <div class="admin-grid-2-col">
                <div class="admin-form-group"><label>Số Điện Thoại</label><input type="tel" name="newPhone" class="admin-form-control" required></div>
                <div class="admin-form-group"><label>Email</label><input type="email" name="newEmail" class="admin-form-control" required></div>
            </div>

            <div class="admin-modal-footer">
                <button type="submit" class="admin-btn-medium admin-btn-add admin-flex-2">Lưu Nhân Viên</button>
                <button type="button" onclick="hideAddModal()" class="admin-btn-cancel">Hủy</button>
            </div>
        </form>
    </div>
</div>

<div id="changePassModal" class="admin-modal">
    <div class="admin-modal-content">
        <div class="admin-modal-header"><h3>🔑 Đổi Mật Khẩu</h3></div>
        <p id="cpUserLabel" class="admin-text-center admin-font-bold admin-mb-15" style="color: #1e293b;"></p>
        <form asp-action="ChangePassword" method="POST" onsubmit="return validateChangePassForm()">
            <input type="hidden" name="cpUserID" id="cpUserID">
            <div class="admin-form-group"><label>Mật Khẩu Mới</label><input type="password" name="cpNewPassword" id="cpNewPassword" class="admin-form-control" required></div>
            <div class="admin-form-group">
                <label>Xác Nhận MK</label>
                <input type="password" id="cpConfirmPassword" class="admin-form-control" required>
                <small id="cpPassErr" class="admin-text-danger admin-font-bold admin-display-none">MK không khớp!</small>
            </div>
            <div class="admin-modal-footer">
                <button type="submit" class="admin-btn-medium admin-btn-add admin-flex-2">Cập Nhật</button>
                <button type="button" onclick="hideChangePassModal()" class="admin-btn-cancel">Hủy</button>
            </div>
        </form>
    </div>
</div>

<div id="detailsModal" class="admin-modal">
    <div class="admin-modal-content admin-details-container">
        <div class="admin-modal-header">
            <h3 class="admin-details-header">👤 Hồ Sơ & Chỉnh Sửa Nhân Viên</h3>
        </div>
    
        <form asp-action="UpdateUser" method="POST">
            <input type="hidden" name="userId" id="detUserIdInp">
        
            <div class="admin-details-list">
                <div class="admin-details-row">
                    <span class="admin-det-label">Mã Nhân Viên:</span>
                    <span class="admin-det-value admin-det-highlight" id="detUserId"></span>
                </div>

                <div class="admin-details-row">
                    <span class="admin-det-label">Tên Đăng Nhập:</span>
                    <span class="admin-det-value admin-font-semibold" id="detUsernameText"></span>
                </div>

                <div class="admin-form-group admin-mt-15">
                    <label>Họ Và Tên</label>
                    <input type="text" name="fullName" id="detFullName" class="admin-form-control" required>
                </div>

                <div class="admin-form-group admin-mt-15">
                    <label>Số Điện Thoại</label>
                    <input type="tel" name="phone" id="detPhone" class="admin-form-control">
                </div>

                <div class="admin-form-group admin-mt-15">
                    <label>Địa Chỉ Email</label>
                    <input type="email" name="email" id="detEmail" class="admin-form-control">
                </div>

                <div class="admin-form-group admin-mt-15">
                    <label>Trạm Làm Việc</label>
                    <select name="stationId" id="detStationId" class="admin-form-control admin-form-select">
                        <option value="">-- Chưa gán trạm --</option>
                        @if (stationList != null)
                        {
                            foreach (var s in stationList)
                            {
                                <option value="@s.StationId">@s.StationName (@s.StationId)</option>
                            }
                        }
                    </select>
                </div>

                <div class="admin-details-footer-meta">
                    <div>Quyền: <strong id="detRole" style="color: #334155;"></strong></div>
                    <div class="admin-text-right">Trạng thái: <span id="detStatus"></span></div>
                    <div style="grid-column: span 2; margin-top: 5px; color: #94a3b8;">Ngày tạo: <span id="detCreatedAt"></span></div>
                </div>
            </div>

            <div class="admin-modal-footer admin-details-footer-btns">
                <button type="submit" class="admin-btn-medium admin-btn-add admin-w-full admin-font-bold">💾 Lưu Thay Đổi</button>
                <button type="button" onclick="hideDetailsModal()" class="admin-btn-cancel admin-w-full admin-font-bold">Đóng</button>
            </div>
        </form>
    </div>
</div>

<div id="staffStationModal" class="admin-modal">
    <div class="admin-modal-content admin-modal-station-manage">
        <div class="admin-modal-header"><h3 id="staffStationModalTitle">👥 Quản Lý Nhân Sự Tại Trạm</h3></div>
        <input type="hidden" id="currentStationId">
    
        <div class="admin-station-staff-grid">
            <div class="admin-station-staff-zone">
                <h4 class="admin-section-subtitle-primary">📍 NHÂN VIÊN TRONG TRẠM</h4>
                <div id="inStationList" class="admin-staff-list-box"></div>
            </div>

            <div class="admin-station-staff-zone">
                <h4 class="admin-section-subtitle-muted">📢 NHÂN VIÊN CHƯA CÓ TRẠM</h4>
                <div id="availableList" class="admin-staff-list-box"></div>
            </div>
        </div>

        <div class="admin-modal-footer">
            <button type="button" onclick="hideStaffStationModal()" class="admin-btn-cancel">Đóng</button>
        </div>
    </div>
</div>

<div id="assignStationModal" class="admin-modal">
    <div class="admin-modal-content admin-modal-small">
        <div class="admin-modal-header"><h3>📍 Gán Trạm Làm Việc</h3></div>
        <p id="asUserLabel" class="admin-text-center admin-font-bold admin-mb-15 admin-text-primary"></p>
        <input type="hidden" id="asUserId">
    
        <div class="admin-form-group">
            <label>Chọn Trạm</label>
            <select id="asStationId" class="admin-form-control">
                <option value="">-- Chọn trạm để gán --</option>
                @if (stationList != null)
                {
                    foreach (var s in stationList)
                    {
                        <option value="@s.StationId">@s.StationName (@s.StationId)</option>
                    }
                }
            </select>
        </div>

        <div class="admin-modal-footer">
            <button type="button" onclick="submitAssignStation()" class="admin-btn-medium admin-btn-add admin-flex-2">Xác Nhận Gán</button>
            <button type="button" onclick="hideAssignStationModal()" class="admin-btn-cancel">Hủy</button>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.1/signalr.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        let currentAdminTab = sessionStorage.getItem('activeAdminTab') || 'staff';

        window.onload = function() {
            showTab(currentAdminTab);
        };

        function showTab(tabName) {
            document.querySelectorAll('.admin-tab-content').forEach(t => t.classList.add('admin-display-none'));
            document.querySelectorAll('.admin-btn-tab').forEach(b => b.classList.remove('active'));

            if (tabName === 'staff') {
                document.getElementById('tabStaff').classList.remove('admin-display-none');
                document.getElementById('tabStaff').classList.add('active');
                document.getElementById('btnTabStaff').classList.add('active');
            } else {
                document.getElementById('tabStation').classList.remove('admin-display-none');
                document.getElementById('tabStation').classList.add('active');
                document.getElementById('btnTabStation').classList.add('active');
            }
            sessionStorage.setItem('activeAdminTab', tabName);
        }

        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/deliveryHub")
            .withAutomaticReconnect()
            .build();

        connection.on("UpdateOrderList", function () {
            location.reload(); 
        });

        connection.start().catch(err => console.error(err.toString()));

        const ctx = document.getElementById('revenueChart').getContext('2d');
        new Chart(ctx, {
            type: 'line',
            data: {
                labels: @Html.Raw(Json.Serialize(ViewBag.ChartLabels)),
                datasets: [{
                    data: @Html.Raw(Json.Serialize(ViewBag.ChartData)),
                    borderColor: '#4f46e5', backgroundColor: 'rgba(79, 70, 229, 0.1)',
                    borderWidth: 3, fill: true, tension: 0.4, pointRadius: 0
                }]
            },
            options: { plugins: { legend: { display: false } }, scales: { x: { display: false }, y: { display: false } } }
        });

        function showAddModal() { document.getElementById('addModal').style.display = 'flex'; }
        function hideAddModal() { document.getElementById('addModal').style.display = 'none'; }
        function showChangePassModal(id, name) { document.getElementById('cpUserID').value = id; document.getElementById('cpUserLabel').textContent = name; document.getElementById('changePassModal').style.display = 'flex'; }
        function hideChangePassModal() { document.getElementById('changePassModal').style.display = 'none'; }
        function showDetailsModal(id, user, name, role, phone, email, status, created, stationId) {
            document.getElementById('detUserId').textContent = id;
            document.getElementById('detUserIdInp').value = id;
            document.getElementById('detUsernameText').textContent = user;
            document.getElementById('detFullName').value = name;
            document.getElementById('detRole').textContent = role;
            document.getElementById('detPhone').value = phone === '—' ? '' : phone;
            document.getElementById('detEmail').value = email === '—' ? '' : email;
            document.getElementById('detStationId').value = stationId || '';
            document.getElementById('detCreatedAt').textContent = created;
            
            document.getElementById('detStatus').innerHTML = (status.toLowerCase() === 'true') 
                ? '<span style="color:#10b981; font-weight:700;">● Hoạt động</span>' 
                : '<span style="color:#ef4444; font-weight:700;">● Đã khóa</span>';
            
            document.getElementById('detailsModal').style.display = 'flex';
        }
        function hideDetailsModal() { document.getElementById('detailsModal').style.display = 'none'; }

        function validateAddForm() {
            const p1 = document.getElementById('newPassword').value; const p2 = document.getElementById('newConfirmPassword').value;
            if (p1 !== p2) { document.getElementById('addPassErr').classList.remove('admin-display-none'); return false; } return true;
        }
        function validateChangePassForm() {
            const p1 = document.getElementById('cpNewPassword').value; const p2 = document.getElementById('cpConfirmPassword').value;
            if (p1 !== p2) { document.getElementById('cpPassErr').classList.remove('admin-display-none'); return false; } return true;
        }

        function showStationModal(id = 0, name = '', addr = '', phone = '') {
            document.getElementById('stationId').value = id;
            document.getElementById('stationName').value = name;
            document.getElementById('stationAddress').value = addr;
            document.getElementById('stationPhone').value = phone;
            document.getElementById('stationModalTitle').textContent = id > 0 ? '📝 Sửa Thông Tin Trạm' : '🏢 Thêm Trạm Mới';
            document.getElementById('stationModal').style.display = 'flex';
        }
        function hideStationModal() { document.getElementById('stationModal').style.display = 'none'; }

        let hasStaffChanges = false;
        async function showStaffStationModal(stationId, stationName) {
            hasStaffChanges = false;
            document.getElementById('currentStationId').value = stationId;
            document.getElementById('staffStationModalTitle').textContent = '👥 Nhân Sự Tại: ' + stationName;
            await refreshStaffLists(stationId);
            document.getElementById('staffStationModal').style.display = 'flex';
        }
        function hideStaffStationModal() {
            document.getElementById('staffStationModal').style.display = 'none';
            if (hasStaffChanges) location.reload();
        }

        async function refreshStaffLists(stationId) {
            const response = await fetch(`/Admin/GetStaffByStation?stationId=${stationId}`);
            const data = await response.json();
            const inList = document.getElementById('inStationList');
            const avList = document.getElementById('availableList');
            inList.innerHTML = data.inStation.length > 0 ? '' : '<p class="admin-text-center" style="font-size:0.8rem; color:#94a3b8;">Trạm chưa có nhân sự</p>';
            avList.innerHTML = data.available.length > 0 ? '' : '<p class="admin-text-center" style="font-size:0.8rem; color:#94a3b8;">Không có nhân viên trống</p>';
            data.inStation.forEach(u => {
                inList.innerHTML += `
                    <div class="admin-staff-item-row">
                        <div>
                            <div style="font-weight:700; font-size:0.85rem;">${u.fullName}</div>
                            <div style="font-size:0.75rem; color:#64748b;">ID: ${u.userId}</div>
                        </div>
                        <button onclick="removeStaff('${u.userId}')" class="admin-btn-remove-staff">✖ Gỡ</button>
                    </div>`;
            });
            data.available.forEach(u => {
                avList.innerHTML += `
                    <div class="admin-staff-item-row">
                        <div>
                            <div style="font-weight:700; font-size:0.85rem;">${u.fullName}</div>
                            <div style="font-size:0.75rem; color:#64748b;">ID: ${u.userId}</div>
                        </div>
                        <button onclick="addStaff('${u.userId}')" class="admin-btn-add-staff">✚ Thêm</button>
                    </div>`;
            });
        }

        async function addStaff(userId) {
            const stationId = document.getElementById('currentStationId').value;
            const formData = new FormData();
            formData.append('userId', userId); formData.append('stationId', stationId);
            const response = await fetch('/Admin/AddStaffToStation', { method: 'POST', body: formData });
            const data = await response.json();
            if (data.success) { hasStaffChanges = true; await refreshStaffLists(stationId); }
            else alert(data.message);
        }

        async function removeStaff(userId) {
            const stationId = document.getElementById('currentStationId').value;
            const formData = new FormData();
            formData.append('userId', userId);
            const response = await fetch('/Admin/RemoveStaffFromStation', { method: 'POST', body: formData });
            const data = await response.json();
            if (data.success) { hasStaffChanges = true; await refreshStaffLists(stationId); }
            else alert(data.message);
        }

        function showAssignStationModal(userId, fullName) {
            document.getElementById('asUserId').value = userId;
            document.getElementById('asUserLabel').textContent = 'Nhân viên: ' + fullName;
            document.getElementById('asStationId').value = '';
            document.getElementById('assignStationModal').style.display = 'flex';
        }
        function hideAssignStationModal() { document.getElementById('assignStationModal').style.display = 'none'; }

        async function submitAssignStation() {
            const userId = document.getElementById('asUserId').value;
            const stationId = document.getElementById('asStationId').value;
            if (!stationId) { Swal.fire('Chú ý', 'Vui lòng chọn một trạm!', 'warning'); return; }
            const formData = new FormData();
            formData.append('userId', userId); formData.append('stationId', stationId);
            const response = await fetch('/Admin/AddStaffToStation', { method: 'POST', body: formData });
            const data = await response.json();
            if (data.success) location.reload(); else Swal.fire('Lỗi', data.message, 'error');
        }

        async function adminEndShiftDirect(userId, fullName) {
            const { isConfirmed } = await Swal.fire({
                title: 'Kết thúc ca hộ?', text: `Bạn muốn kết thúc ca làm việc của nhân viên: ${fullName}?`,
                icon: 'warning', showCancelButton: true, confirmButtonColor: '#ef4444', confirmButtonText: '🛑 Kết thúc ngay', cancelButtonText: 'Hủy'
            });
            if (isConfirmed) {
                const formData = new FormData(); formData.append('userId', userId);
                try {
                    const resp = await fetch('/Admin/AdminEndShift', { method: 'POST', body: formData });
                    const result = await resp.json();
                    if (result.success) { Toast.fire({ icon: 'success', title: result.message }); setTimeout(() => location.reload(), 1000); }
                    else Swal.fire('Lỗi', result.message, 'error');
                } catch (err) { Swal.fire('Lỗi', 'Lỗi kết nối', 'error'); }
            }
        }

        async function toggleUserDirect(userId) {
            const formData = new FormData(); formData.append('userID', userId);
            try {
                const resp = await fetch('/Admin/ToggleUser', { method: 'POST', body: formData });
                const result = await resp.json();
                if (result.success) { Toast.fire({ icon: 'success', title: result.message }); setTimeout(() => location.reload(), 800); }
                else Swal.fire('Lỗi', result.message, 'error');
            } catch (err) { Swal.fire('Lỗi', 'Lỗi kết nối', 'error'); }
        }

        async function deleteUserDirect(userId, fullName) {
            const { isConfirmed } = await Swal.fire({
                title: 'Xác nhận xóa?', text: `Bạn có chắc muốn xóa nhân viên ${fullName}?`,
                icon: 'warning', showCancelButton: true, confirmButtonColor: '#ef4444', confirmButtonText: 'Xóa ngay'
            });
            if (isConfirmed) {
                const formData = new FormData(); formData.append('userID', userId);
                try {
                    const resp = await fetch('/Admin/DeleteUser', { method: 'POST', body: formData });
                    const result = await resp.json();
                    if (result.success) { Toast.fire({ icon: 'success', title: result.message }); setTimeout(() => location.reload(), 800); }
                    else Swal.fire('Lỗi', result.message, 'error');
                } catch (err) { Swal.fire('Lỗi', 'Lỗi kết nối', 'error'); }
            }
        }

        async function toggleStationDirect(stationId) {
            const formData = new FormData(); formData.append('stationId', stationId);
            try {
                const resp = await fetch('/Admin/ToggleStation', { method: 'POST', body: formData });
                const result = await resp.json();
                if (result.success) { Toast.fire({ icon: 'success', title: result.message }); setTimeout(() => location.reload(), 800); }
                else Swal.fire('Lỗi', result.message, 'error');
            } catch (err) { Swal.fire('Lỗi', 'Lỗi kết nối', 'error'); }
        }

        async function deleteStationDirect(stationId, name) {
            const { isConfirmed } = await Swal.fire({
                title: 'Xác nhận xóa trạm?', text: `Bạn có chắc muốn xóa trạm ${name}?`,
                icon: 'warning', showCancelButton: true, confirmButtonColor: '#ef4444', confirmButtonText: 'Xóa ngay'
            });
            if (isConfirmed) {
                const formData = new FormData(); formData.append('stationId', stationId);
                try {
                    const resp = await fetch('/Admin/DeleteStation', { method: 'POST', body: formData });
                    const result = await resp.json();
                    if (result.success) { Toast.fire({ icon: 'success', title: result.message }); setTimeout(() => location.reload(), 800); }
                    else Swal.fire('Lỗi', result.message, 'error');
                } catch (err) { Swal.fire('Lỗi', 'Lỗi kết nối', 'error'); }
            }
        }

        function filterStaff() {
            const kw = document.getElementById('staffSearch').value.toLowerCase();
            const stationId = document.getElementById('stationFilter').value;
            document.querySelectorAll('.admin-staff-row').forEach(r => {
                const id = r.getAttribute('data-id') || '';
                const name = r.getAttribute('data-name') || '';
                const phone = r.getAttribute('data-phone') || '';
                const station = r.getAttribute('data-station') || '';
                
                const matchesSearch = id.includes(kw) || name.includes(kw) || phone.includes(kw);
                const matchesStation = stationId === "" || station === stationId;
                
                r.style.display = (matchesSearch && matchesStation) ? '' : 'none';
            });
        }

        function filterStation() {
            const kw = document.getElementById('stationSearch').value.toLowerCase();
            document.querySelectorAll('.admin-station-row').forEach(r => {
                const id = r.getAttribute('data-id') || '';
                const name = r.getAttribute('data-name') || '';
                const matches = id.includes(kw) || name.includes(kw);
                r.style.display = matches ? '' : 'none';
            });
        }

        window.onclick = (e) => { 
            if (e.target.className.includes('admin-modal')) { 
                hideAddModal(); hideChangePassModal(); hideDetailsModal(); hideStationModal(); hideStaffStationModal(); hideAssignStationModal();
            } 
        };
    </script>
}
