@model Delivery_System.Models.TblWorkShift

@{
    var addedOrders = (ViewBag.AddedOrders as IEnumerable<Delivery_System.Models.TblOrder>)?.ToList() ?? new List<Delivery_System.Models.TblOrder>();
    var receivedOrders = (ViewBag.ReceivedOrders as IEnumerable<Delivery_System.Models.TblOrder>)?.ToList() ?? new List<Delivery_System.Models.TblOrder>();
    var createdTrips = (ViewBag.CreatedTrips as IEnumerable<Delivery_System.Models.TblTrip>)?.ToList() ?? new List<Delivery_System.Models.TblTrip>();
}

<div class="rp-modal-header rp-d-flex rp-justify-between rp-align-center">
    <div>
        <h3 class="rp-modal-title">Ca làm việc <span class="rp-text-highlight">#@Model.ShiftId</span></h3>
        <div class="rp-modal-meta">
            👤 <strong>@Model.Staff.FullName</strong> | 📅 @Model.StartTime.ToString("dd/MM/yyyy") | ⏱️ @Model.StartTime.ToString("HH:mm") - @(Model.EndTime?.ToString("HH:mm") ?? "Đang trực")
        </div>
    </div>
    <div style="text-align: right;">
        <div class="rp-stat-label-mini">Doanh thu</div>
        <div class="rp-stat-value-large">@ViewBag.TotalRevenue.ToString("N0") K</div>
    </div>
</div>

<!-- ĐIỀU HƯỚNG TAB GỌN GÀNG -->
<div class="rp-modal-tab-nav">
    <button class="rp-modal-tab-btn active" onclick="showModalInnerTab('added', this)">
        📦 Đơn đã nhập <span class="rp-count-badge">@addedOrders.Count</span>
    </button>
    <button class="rp-modal-tab-btn" onclick="showModalInnerTab('received', this)">
        ✅ Đơn đã giao <span class="rp-count-badge">@receivedOrders.Count</span>
    </button>
    <button class="rp-modal-tab-btn" onclick="showModalInnerTab('trips', this)">
        🚛 Chuyến xe <span class="rp-count-badge">@createdTrips.Count</span>
    </button>
</div>

<!-- NỘI DUNG CÁC TAB -->
<div style="flex: 1; overflow-y: auto;">
    
    <div id="modal-tab-added" class="rp-modal-inner-tab active">
        @if (addedOrders.Any()) {
            <table class="rp-table-modern">
                <thead>
                    <tr>
                        <th>Mã Đơn</th>
                        <th>Tên Hàng</th>
                        <th>Trạm Nhận</th>
                        <th>Trạng Thái</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var o in addedOrders) {
                        <tr>
                            <td><a href="@Url.Action("List", "Order", new { searchPhone = o.OrderId })" class="rp-detail-link">@o.OrderId</a></td>
                            <td class="rp-font-bold">@o.ItemName</td>
                            <td>@o.ReceiveStation</td>
                            <td><span class="rp-badge-success @(o.ShipStatus == "Đã giao" ? "rp-badge-success" : "rp-badge-warning")">@o.ShipStatus</span></td>
                        </tr>
                    }
                </tbody>
            </table>
        } else { <div class="rp-empty-state">Chưa có đơn hàng nào được nhập.</div> }
    </div>

    <div id="modal-tab-received" class="rp-modal-inner-tab">
        @if (receivedOrders.Any()) {
            <table class="rp-table-modern">
                <thead>
                    <tr>
                        <th>Mã Đơn</th>
                        <th>Tên Hàng</th>
                        <th>Người Nhận</th>
                        <th>Thời Gian Giao</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var o in receivedOrders) {
                        <tr>
                            <td><a href="@Url.Action("List", "Order", new { searchPhone = o.OrderId })" class="rp-detail-link">@o.OrderId</a></td>
                            <td class="rp-font-bold">@o.ItemName</td>
                            <td>@o.ReceiverName</td>
                            <td>@o.CreatedAt?.ToString("HH:mm dd/MM")</td>
                        </tr>
                    }
                </tbody>
            </table>
        } else { <div class="rp-empty-state">Chưa thực hiện giao đơn nào.</div> }
    </div>

    <div id="modal-tab-trips" class="rp-modal-inner-tab">
        @if (createdTrips.Any()) {
            <table class="rp-table-modern">
                <thead>
                    <tr><th>Mã Chuyến</th><th>Biển Số Xe</th><th>Đích Đến</th><th>Trạng Thái</th></tr>
                </thead>
                <tbody>
                    @foreach (var t in createdTrips) {
                        <tr>
                            <td><a href="@Url.Action("List", "Trip", new { searchTruck = t.TripId })" class="rp-detail-link">@t.TripId</a></td>
                            <td><strong>@t.Truck?.LicensePlate</strong></td>
                            <td>@t.Destination</td>
                            <td><span class="rp-badge-info">@t.Status</span></td>
                        </tr>
                    }
                </tbody>
            </table>
        } else { <div class="rp-empty-state">Chưa tạo chuyến xe nào.</div> }
    </div>
</div>
