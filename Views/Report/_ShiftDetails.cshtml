@model Delivery_System.Models.TblWorkShift

@{
    var addedOrders = (ViewBag.AddedOrders as IEnumerable<Delivery_System.Models.TblOrder>)?.ToList() ?? new List<Delivery_System.Models.TblOrder>();
    var deliveredOrders = (ViewBag.DeliveredOrders as IEnumerable<Delivery_System.Models.TblOrder>)?.ToList() ?? new List<Delivery_System.Models.TblOrder>();
    var createdTrips = (ViewBag.CreatedTrips as IEnumerable<Delivery_System.Models.TblTrip>)?.ToList() ?? new List<Delivery_System.Models.TblTrip>();
    var arrivedTrips = (ViewBag.ArrivedTrips as IEnumerable<Delivery_System.Models.TblTrip>)?.ToList() ?? new List<Delivery_System.Models.TblTrip>();
}

<div class="rp-modal-header rp-d-flex rp-justify-between rp-align-center">
    <div>
        <h3 class="rp-modal-title">Chi Tiết Ca Làm Việc <span class="rp-text-highlight">#@Model.ShiftId</span></h3>
        <div class="rp-modal-meta">
            👤 <strong>@Model.Staff.FullName (@Model.StaffId)</strong> | ⏱️ @Model.StartTime.ToString("HH:mm dd/MM") - @(Model.EndTime?.ToString("HH:mm dd/MM") ?? "Đang trực")
        </div>
    </div>
    <div class="rp-modal-header-right rp-text-right">
        <div class="rp-d-flex rp-gap-1">
            <div class="rp-stat-divider">
                <div class="rp-stat-label-mini">Cước Gửi (TR)</div>
                <div class="rp-stat-value-large rp-stat-prepaid">@ViewBag.TotalPrepaid.ToString("N0") K</div>
            </div>
            <div class="rp-stat-divider rp-stat-padding-left">
                <div class="rp-stat-label-mini">Tiền COD (CT)</div>
                <div class="rp-stat-value-large rp-stat-cod">@ViewBag.TotalCOD.ToString("N0") K</div>
            </div>
            <div class="rp-stat-padding-left">
                <div class="rp-stat-label-mini">TỔNG THỰC THU</div>
                <div class="rp-stat-value-large rp-stat-total">@ViewBag.TotalRevenue.ToString("N0") K</div>
            </div>
        </div>
    </div>
</div>

<!-- ĐIỀU HƯỚNG TAB CHI TIẾT -->
<div class="rp-modal-tab-nav">
    <button class="rp-modal-tab-btn active" onclick="showModalInnerTab('added', this)">
        📦 Nhập Đơn <span class="rp-count-badge">@addedOrders.Count</span>
    </button>
    <button class="rp-modal-tab-btn" onclick="showModalInnerTab('departed', this)">
        📤 Xuất Xe <span class="rp-count-badge">@createdTrips.Count</span>
    </button>
    <button class="rp-modal-tab-btn" onclick="showModalInnerTab('arrived', this)">
        📥 Nhận Xe <span class="rp-count-badge">@arrivedTrips.Count</span>
    </button>
    <button class="rp-modal-tab-btn" onclick="showModalInnerTab('delivered', this)">
        ✅ Giao Khách <span class="rp-count-badge">@deliveredOrders.Count</span>
    </button>
</div>

<!-- NỘI DUNG CÁC TAB -->
<div class="rp-modal-body-scroll">
    
    <!-- 1. ĐƠN ĐÃ NHẬP -->
    <div id="modal-tab-added" class="rp-modal-inner-tab active">
        @if (addedOrders.Any()) {
            <table class="rp-table-modern">
                <thead>
                    <tr>
                        <th>Mã Đơn</th>
                        <th>Tên Hàng</th>
                        <th>Đích Đến</th>
                        <th class="rp-text-right">Cước Gửi (TR)</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var o in addedOrders) {
                        <tr>
                            <td><a href="@Url.Action("List", "Order", new { searchPhone = o.OrderId })" class="rp-detail-link">@o.OrderId</a></td>
                            <td class="rp-font-bold">@o.ItemName</td>
                            <td>@o.ReceiveStation</td>
                            <td class="rp-text-right rp-font-bold rp-text-primary">@((o.Tr ?? 0).ToString("N0")) K</td>
                        </tr>
                    }
                </tbody>
            </table>
        } else { <div class="rp-empty-state">Không có đơn hàng nào được nhập mới.</div> }
    </div>

    <!-- 2. CHUYẾN XE ĐÃ XUẤT (TẠO MỚI) -->
    <div id="modal-tab-departed" class="rp-modal-inner-tab">
        @if (createdTrips.Any()) {
            <table class="rp-table-modern">
                <thead>
                    <tr><th>Mã Chuyến</th><th>Biển Số</th><th>Trạm Đến</th><th>Trạng Thái</th></tr>
                </thead>
                <tbody>
                    @foreach (var t in createdTrips) {
                        <tr>
                            <td><a href="@Url.Action("List", "Trip", new { searchTruck = t.TripId })" class="rp-detail-link">@t.TripId</a></td>
                            <td><strong>@t.Truck?.LicensePlate</strong></td>
                            <td>@t.Destination</td>
                            <td><span class="rp-badge-info">@t.Status</span></td>
                        </tr>
                    }
                </tbody>
            </table>
        } else { <div class="rp-empty-state">Không có chuyến xe nào xuất trạm.</div> }
    </div>

    <!-- 3. CHUYẾN XE ĐÃ TIẾP NHẬN (BẤM XE ĐẾN) -->
    <div id="modal-tab-arrived" class="rp-modal-inner-tab">
        @if (arrivedTrips.Any()) {
            <table class="rp-table-modern">
                <thead>
                    <tr><th>Mã Chuyến</th><th>Biển Số</th><th>Trạm Đi</th><th>Giờ Đến</th></tr>
                </thead>
                <tbody>
                    @foreach (var t in arrivedTrips) {
                        var parts = t.Notes?.Replace("[ARRIVED] ", "").Split('|');
                        <tr>
                            <td><a href="@Url.Action("ArrivalList", "Trip", new { searchTruck = t.TripId })" class="rp-detail-link">@t.TripId</a></td>
                            <td><strong>@t.Truck?.LicensePlate</strong></td>
                            <td>@t.Departure</td>
                            <td class="rp-text-success">@(parts?.Length > 1 ? parts[1].Trim() : "N/A")</td>
                        </tr>
                    }
                </tbody>
            </table>
        } else { <div class="rp-empty-state">Không có chuyến xe nào cập bến.</div> }
    </div>

    <!-- 4. ĐƠN HÀNG ĐÃ GIAO KHÁCH -->
    <div id="modal-tab-delivered" class="rp-modal-inner-tab">
        @if (deliveredOrders.Any()) {
            <table class="rp-table-modern">
                <thead>
                    <tr>
                        <th>Mã Đơn</th>
                        <th>Tên Hàng</th>
                        <th>Người Nhận</th>
                        <th class="rp-text-right">Tiền COD (CT)</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var o in deliveredOrders) {
                        <tr>
                            <td><a href="@Url.Action("List", "Order", new { searchPhone = o.OrderId })" class="rp-detail-link">@o.OrderId</a></td>
                            <td class="rp-font-bold">@o.ItemName</td>
                            <td>@o.ReceiverName</td>
                            <td class="rp-text-right rp-font-bold rp-text-success">@((o.Ct ?? 0).ToString("N0")) K</td>
                        </tr>
                    }
                </tbody>
            </table>
        } else { <div class="rp-empty-state">Không có đơn hàng nào được giao cho khách.</div> }
    </div>
</div>

