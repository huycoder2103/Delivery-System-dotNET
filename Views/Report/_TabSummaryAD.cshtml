<div class="rp-card">
    <div class="rp-filter-bar rp-filter-bar-header">
        <form onsubmit="loadTabContent('summary', event)" class="rp-d-flex rp-align-center rp-gap-1">
            <div class="rp-filter-group">
                <input type="date" name="reportDate" value="@ViewBag.SelectedDate" class="rp-filter-input" onchange="this.form.requestSubmit()">
            </div>
            <button type="submit" class="rp-btn rp-btn-primary">🔍 Cập nhật</button>
        </form>
    </div>

    <h4 class="rp-summary-title">📈 Tổng Kết Doanh Thu Toàn Hệ Thống</h4>
    <div class="rp-goods-grid rp-goods-grid-4">
        <a href="@Url.Action("List", "Order", new { dateFilter = ViewBag.SelectedDate })" class="rp-goods-card rp-goods-card-compact rp-card-link">
            <h3>@ViewBag.RevenueDateVal.ToString("N0") K</h3>
            <p>Tổng tiền thu ngày lọc</p>
            <span class="rp-btn-access rp-bg-blue-alt">Ngày chọn</span>
        </a>
        <div class="rp-goods-card rp-goods-card-compact">
            <h3 class="text-success">@ViewBag.TotalPrepaidAD.ToString("N0") K</h3>
            <p>Tổng cước gửi (TR)</p>
            <span class="rp-btn-access rp-bg-green-alt">Phí gửi</span>
        </div>
        <div class="rp-goods-card rp-goods-card-compact">
            <h3 class="text-warning">@ViewBag.TotalCODAD.ToString("N0") K</h3>
            <p>Tổng tiền COD (CT)</p>
            <span class="rp-btn-access rp-bg-yellow-alt">Tiền thu hộ</span>
        </div>
        <a href="@Url.Action("List", "Order", new { dateFilter = ViewBag.SelectedDate })" class="rp-goods-card rp-goods-card-compact rp-card-link">
            <h3>@ViewBag.OrdersDateVal</h3>
            <p>Đơn hàng nhập mới</p>
            <span class="rp-btn-access rp-bg-red-alt">Đơn mới</span>
        </a>
    </div>

    <h5 class="rp-card-title rp-text-center mt-4">📊 Doanh Thu Tích Lũy</h5>
    <div class="rp-goods-grid rp-goods-grid-4">
        <div class="rp-goods-card rp-goods-card-compact">
            <h3>@ViewBag.RevenueWeekly.ToString("N0") K</h3>
            <p>7 ngày qua (TR+CT)</p>
        </div>
        <div class="rp-goods-card rp-goods-card-compact">
            <h3>@ViewBag.RevenueMonthly.ToString("N0") K</h3>
            <p>Tháng @DateTime.Now.Month</p>
        </div>
        <div class="rp-goods-card rp-goods-card-compact rp-goods-card-span2">
            <h3 class="text-primary">@ViewBag.RevenueTotalSystem.ToString("N0") K</h3>
            <p>TỔNG DOANH THU TOÀN HỆ THỐNG</p>
        </div>
    </div>

    <h5 class="rp-card-title rp-text-center">🚀 Biểu Đồ Tăng Trưởng (7 Ngày)</h5>
    <div class="rp-chart-box">
        <!-- Lưu dữ liệu vào data attributes để JS bên ngoài đọc -->
        <canvas id="realRevenueChart" 
                data-labels='@Html.Raw(Json.Serialize(ViewBag.ChartLabels))'
                data-values='@Html.Raw(Json.Serialize(ViewBag.ChartData))'>
        </canvas>
    </div>
</div>
