@model IEnumerable<Delivery_System.Models.TblUser>

<main class="rp-card">
    <div class="rp-card-title"><h2>📦 Lịch Sử Hoạt Động Nhân Viên Theo Ngày</h2></div>

    <div class="rp-card" style="background: #f0f9ff; border: 1px dashed #7dd3fc; margin-bottom: 20px; padding: 20px;">
        <form onsubmit="loadTabContent('activity', event)" class="rp-filter-bar">
            <div class="rp-filter-group">
                <label class="rp-filter-label">Theo Trạm</label>
                <select name="stationId" class="rp-filter-input">
                    <option value="">-- Tất cả các trạm --</option>
                    @foreach (var s in ViewBag.StationList) {
                        <option value="@s.StationId" selected="@(ViewBag.SelectedStationId == s.StationId ? "selected" : null)">@s.StationName</option>
                    }
                </select>
            </div>
            <div class="rp-filter-group">
                <label class="rp-filter-label">Tìm Nhân Viên (Tên/ID)</label>
                <input type="text" name="searchStaff" class="rp-filter-input" placeholder="Nhập tên/ID..." value="@ViewBag.SearchStaff" />
            </div>
            <div class="rp-filter-group">
                <label class="rp-filter-label">Ngày Hoạt Động</label>
                <input type="date" name="logDate" class="rp-filter-input" value="@ViewBag.LogDate" />
            </div>
            <button type="submit" class="rp-btn rp-btn-primary">🔍 TRUY VẤN</button>
        </form>
    </div>

    <div class="rp-table-wrap">
        <table class="rp-table">
            <thead><tr><th>Nhân Viên</th><th>Trạm Trực</th><th>Mã NV</th><th class="rp-text-center">Thao Tác</th></tr></thead>
            <tbody>
                @if (Model != null && Model.Any()) {
                    foreach (var s in Model) {
                        <tr>
                            <td>
                                <div class="rp-avatar-wrap">
                                    <div class="rp-avatar" style="background: #0ea5e9;">@s.FullName.Substring(0,1).ToUpper()</div>
                                    <div class="rp-staff-name" style="cursor: pointer; color: #1a73e8; text-decoration: underline;" 
                                         onclick="openDailyDetails('@s.UserId', '@ViewBag.LogDate')">@s.FullName</div>
                                </div>
                            </td>
                            <td>@(s.Station?.StationName ?? "N/A")</td><td><code>@s.UserId</code></td>
                            <td class="rp-text-center">
                                <button type="button" class="rp-btn-s rp-btn-s-blue" onclick="openDailyDetails('@s.UserId', '@ViewBag.LogDate')">
                                    📋 Xem hoạt động
                                </button>
                            </td>
                        </tr>
                    }
                } else {
                    <tr><td colspan="4" class="rp-text-center p-4">Không tìm thấy nhân viên nào có hoạt động trong ngày được chọn.</td></tr>
                }
            </tbody>
        </table>
    </div>
</main>
