@model IEnumerable<Delivery_System.Models.TblWorkShift>

<main class="rp-card">
    <div class="rp-card-title">
        <h2>📦 @(User.IsInRole("AD") ? "Lịch Sử Hoạt Động Hệ Thống" : "Lịch Sử Ca Làm Việc Của Tôi")</h2>
    </div>

    <div class="rp-card rp-card-highlight">
        <form onsubmit="loadTabContent('activity', event)" class="rp-filter-bar">
            @if (User.IsInRole("AD")) {
                <div class="rp-filter-group">
                    <label class="rp-filter-label">Theo Trạm</label>
                    <select name="stationId" class="rp-filter-input">
                        <option value="">-- Tất cả các trạm --</option>
                        @foreach (var s in ViewBag.StationList) {
                            <option value="@s.StationId" selected="@(ViewBag.SelectedStationId == s.StationId ? "selected" : null)">@s.StationName</option>
                        }
                    </select>
                </div>
                <div class="rp-filter-group">
                    <label class="rp-filter-label">Tìm Nhân Viên (Tên/ID)</label>
                    <input type="text" name="searchStaff" class="rp-filter-input" placeholder="Nhập tên hoặc mã NV..." value="@ViewBag.SearchStaff" />
                </div>
            }
            <div class="rp-filter-group">
                <label class="rp-filter-label">Từ Ngày</label>
                <input type="date" name="fromDate" class="rp-filter-input" value="@ViewBag.FromDate" />
            </div>
            <div class="rp-filter-group">
                <label class="rp-filter-label">Đến Ngày</label>
                <input type="date" name="toDate" class="rp-filter-input" value="@ViewBag.ToDate" />
            </div>
            <button type="submit" class="rp-btn rp-btn-primary">🔍 TRUY VẤN</button>
        </form>
    </div>

    <div class="rp-table-wrap">
        <table class="rp-table">
            <thead>
                <tr>
                    <th>Mã Ca</th>
                    <th>Nhân Viên</th>
                    <th>Trạm Trực</th>
                    <th>Bắt Đầu</th>
                    <th>Kết Thúc</th>
                    <th class="rp-text-right">Doanh Thu</th>
                    <th class="rp-text-center">Thao Tác</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any()) {
                    foreach (var s in Model) {
                        <tr>
                            <td><code>#@s.ShiftId</code></td>
                            <td>
                                <div class="rp-avatar-wrap">
                                    <div class="rp-avatar rp-avatar-blue">@s.Staff.FullName.Substring(0,1).ToUpper()</div>
                                    <div class="rp-staff-name rp-link-staff" onclick="openShiftDetails(@s.ShiftId)">@s.Staff.FullName</div>
                                </div>
                            </td>
                            <td>@(s.Staff?.Station?.StationName ?? "N/A")</td>
                            <td>@s.StartTime.ToString("HH:mm dd/MM")</td>
                            <td>@(s.EndTime?.ToString("HH:mm dd/MM") ?? "Đang làm...")</td>
                            <td class="rp-text-right rp-font-bold rp-text-primary">@s.Revenue.ToString("N0") K</td>
                            <td class="rp-text-center">
                                <button type="button" class="rp-btn-s rp-btn-s-blue" onclick="openShiftDetails(@s.ShiftId)">
                                    📋 Chi tiết
                                </button>
                            </td>
                        </tr>
                    }
                } else {
                    <tr><td colspan="7" class="rp-text-center p-4">Không có dữ liệu ca làm việc nào phù hợp.</td></tr>
                }
            </tbody>
        </table>
    </div>
</main>
