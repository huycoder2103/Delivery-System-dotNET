@model IEnumerable<Delivery_System.Models.TblWorkShift>
@{
    var role = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value;
}

<main class="rp-card">
    <div class="rp-card-title"><h2>📜 Nhật Ký 20 Hoạt Động Gần Nhất</h2></div>

    <div class="rp-table-wrap">
        <table class="rp-table">
            <thead>
                <tr>
                    <th>Nhân Viên</th><th>Bắt Đầu</th><th>Kết Thúc</th><th>Doanh Thu</th><th>Trạng Thái</th><th class="rp-text-center">Thao Tác</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any()) {
                    foreach (var item in Model) {
                        <tr>
                            <td>
                                <div class="rp-avatar-wrap">
                                    <div class="rp-avatar" style="background: #6366f1;">@item.Staff.FullName.Substring(0,1).ToUpper()</div>
                                    <div><div class="rp-staff-name">@item.Staff.FullName</div><div class="rp-staff-id">ID: @item.StaffId</div></div>
                                </div>
                            </td>
                            <td>@item.StartTime.ToString("dd/MM HH:mm")</td>
                            <td>@(item.EndTime?.ToString("dd/MM HH:mm") ?? "—")</td>
                            <td><span class="rp-text-revenue">@item.Revenue.ToString("N0") K</span></td>
                            <td>
                                @if (item.Status == "ACTIVE")
                                {
                                    <span class="rp-badge rp-badge-active">Đang trực</span>
                                }
                                else
                                {
                                    <span class="rp-badge rp-badge-ended">Đã nghỉ</span>
                                }
                            </td>
                            <td class="rp-text-center">
                                <div style="display: flex; gap: 5px; justify-content: center;">
                                    <button type="button" onclick="openShiftDetails(@item.ShiftId)" class="rp-btn-s rp-btn-s-blue">👁️ Chi tiết</button>
                                    
                                    @if (role == "AD" && item.Status == "ACTIVE")
                                    {
                                        <button type="button" onclick="adminEndShift(@item.ShiftId, '@item.Staff.FullName')" class="rp-btn-s" style="background: #ef4444; color: white; border: none;">
                                            🛑 Kết thúc ca hộ
                                        </button>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                } else { <tr><td colspan="6" class="rp-text-center p-4">Không tìm thấy nhật ký làm việc.</td></tr> }
            </tbody>
        </table>
    </div>
</main>

<script>
    function adminEndShift(shiftId, staffName) {
        Swal.fire({
            title: 'Xác nhận kết thúc ca?',
            text: "Bạn đang thực hiện kết thúc ca làm việc cho nhân viên: " + staffName,
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#ef4444',
            cancelButtonColor: '#6b7280',
            confirmButtonText: 'Đúng, kết thúc ngay!',
            cancelButtonText: 'Hủy bỏ'
        }).then((result) => {
            if (result.isConfirmed) {
                $.post('/Report/AdminEndShift', { id: shiftId }, function (res) {
                    if (res.success) {
                        Swal.fire('Thành công!', res.message, 'success').then(() => {
                            // Tải lại tab Nhật ký
                            loadTabContent('history');
                        });
                    } else {
                        Swal.fire('Lỗi!', res.message, 'error');
                    }
                });
            }
        })
    }
</script>
