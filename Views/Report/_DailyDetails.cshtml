@model Delivery_System.Models.TblUser

@{
    var shifts = (ViewBag.StaffShifts as IEnumerable<Delivery_System.Models.TblWorkShift>)?.ToList() ?? new List<Delivery_System.Models.TblWorkShift>();
    var logDateLabel = ViewBag.LogDateLabel as string;
}

<div class="rp-modal-header rp-d-flex rp-justify-between rp-align-center">
    <div>
        <h3 class="rp-modal-title">Danh sách ca làm việc: <span class="rp-text-highlight">@logDateLabel</span></h3>
        <div class="rp-modal-meta">
            👤 <strong>@Model.FullName</strong> | 🆔 @Model.UserId | 🚉 @(Model.Station?.StationName ?? "N/A")
        </div>
    </div>
    <div class="rp-modal-header-right">
        <div class="rp-stat-label-mini">Tổng số ca</div>
        <div class="rp-stat-value-large">@shifts.Count</div>
    </div>
</div>

<div class="rp-modal-scroll-area">
    @if (shifts.Any()) {
        <table class="rp-table-modern">
            <thead>
                <tr>
                    <th>Bắt Đầu</th>
                    <th>Kết Thúc</th>
                    <th class="rp-text-right">Doanh Thu</th>
                    <th class="rp-text-center">Thao Tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var s in shifts) {
                    <tr>
                        <td><strong>@s.StartTime.ToString("HH:mm dd/MM/yyyy")</strong></td>
                        <td>@(s.EndTime?.ToString("HH:mm dd/MM/yyyy") ?? "Đang làm...")</td>
                        <td class="rp-text-right rp-font-bold rp-text-primary">@s.Revenue.ToString("N0") K</td>
                        <td class="rp-text-center">
                            <button type="button" class="rp-btn-s rp-btn-s-blue" onclick="openShiftDetails(@s.ShiftId)">
                                📋 Chi tiết ca
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    } else {
        <div class="rp-empty-state">
            <p>Nhân viên này không có ca làm việc nào trong khoảng thời gian đã chọn.</p>
        </div>
    }
</div>
