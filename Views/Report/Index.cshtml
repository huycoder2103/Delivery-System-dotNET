@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor

@{
    ViewData["Title"] = "Báo Cáo Hệ Thống";
    var role = HttpContextAccessor.HttpContext.Session.GetString("Role");
    var reportDate = ViewBag.ReportDate;
    var shiftHistory = ViewBag.ShiftHistory as IEnumerable<Delivery_System.Models.TblWorkShift>;
    var shiftOrders = ViewBag.ShiftOrders as IEnumerable<Delivery_System.Models.TblOrder>;
    var viewShiftId = ViewBag.ViewShiftId;
    var selectedStaffId = ViewBag.SelectedStaffId;
}

@section Styles {
    <link rel="stylesheet" href="~/css/report.css">
    
}

<div class="container-custom" style="max-width: 1600px; margin: 20px auto; padding: 0 20px;">
    
    <div class="modern-page-header" style="background: linear-gradient(135deg, #1a73e8, #0d47a1);">
        <div>
            <h3>📊 @(role == "AD" ? "BÁO CÁO & THỐNG KÊ" : "KẾT QUẢ LÀM VIỆC CÁ NHÂN")</h3>
            <div style="font-size: 0.85rem; opacity: 0.8; margin-top: 4px;">@(role == "AD" ? "Theo dõi doanh thu và hiệu suất ca làm việc toàn hệ thống" : "Theo dõi hiệu suất và lịch sử ca làm việc của bạn")</div>
        </div>
        <a asp-controller="Home" asp-action="Index" class="btn-modern" style="background: rgba(255,255,255,0.2); color: white; border: 1px solid rgba(255,255,255,0.3); text-decoration: none;">
            ← Quay lại Trang Chủ
        </a>
    </div>

    <div class="d-flex gap-3 mb-4" id="reportTabs" role="tablist">
        <button class="report-tab-btn @(viewShiftId == null ? "active" : "")" id="summary-tab" data-bs-toggle="tab" data-bs-target="#summary" type="button">📋 Tổng Quan</button>
        <button class="report-tab-btn @(viewShiftId != null ? "active" : "")" id="history-tab" data-bs-toggle="tab" data-bs-target="#history" type="button">📜 Nhật Ký Làm Việc</button>
    </div>

    <div class="tab-content" id="reportTabsContent">
        <!-- ========================== TAB 1: TỔNG QUAN ========================== -->
        <div class="tab-pane fade @(viewShiftId == null ? "show active" : "")" id="summary">
            @if (role == "AD")
            {
                <div class="modern-card mb-4">
                    <form asp-action="Index" method="GET" style="display: flex; gap: 35px; align-items: flex-end;">
                        <div style="flex: 1; max-width: 300px;">
                            <label class="stat-label" style="margin-bottom: 8px; display: block;">Chọn ngày xem dữ liệu</label>
                            <input type="date" name="reportDate" class="form-control" style="padding: 10px; border-radius: 10px; border: 1px solid #ddd; width: 100%;" value="@reportDate">
                        </div>
                        <button type="submit" class="btn-modern btn-primary-modern" style="padding: 11px 25px;">🔍 CẬP NHẬT DỮ LIỆU</button>
                        <div style="margin-left: auto;">
                            <span class="badge badge-info" style="padding: 10px 20px; font-size: 0.9rem;">📅 Ngày: <strong>@DateTime.Parse(reportDate).ToString("dd/MM/yyyy")</strong></span>
                        </div>
                    </form>
                </div>

                <div class="row mb-4" style="display: flex; gap: 20px;">
                    <div style="flex: 1;">
                        <div class="card report-card p-4 border-start border-primary border-5 shadow-sm">
                            <div class="stat-label">Doanh thu hệ thống (Ngày)</div>
                            <div class="stat-value text-primary">@string.Format("{0:N0}", ViewBag.RevenueDateVal) K</div>
                        </div>
                    </div>
                    <div style="flex: 1;">
                        <div class="card report-card p-4 border-start border-info border-5 shadow-sm">
                            <div class="stat-label">Đơn hàng mới</div>
                            <div class="stat-value text-info">@ViewBag.OrdersDateVal</div>
                        </div>
                    </div>
                    <div style="flex: 1;">
                        <div class="card report-card p-4 border-start border-warning border-5 shadow-sm">
                            <div class="stat-label">Nhân sự đang Online</div>
                            <div class="stat-value text-warning">@ViewBag.ActiveStaffCount</div>
                        </div>
                    </div>
                </div>

                <div class="card report-card p-4 mb-4">
                    <h5 class="fw-bold mb-4" style="color: #333;">🚀 Tăng Trưởng Doanh Thu Toàn Hệ Thống (7 Ngày)</h5>
                    <div style="height: 400px; width: 100%;">
                        <canvas id="realRevenueChart"></canvas>
                    </div>
                </div>

                <div class="card report-card p-4 mb-4">
                    <h5 class="fw-bold mb-4" style="color: #333;">👥 Hiệu Suất Nhân Viên Hôm Nay</h5>
                    <div class="table-responsive">
                        <table class="table align-middle">
                            <thead class="table-light">
                                <tr style="font-size: 0.75rem; text-transform: uppercase; color: #6c757d;">
                                    <th>Nhân Viên</th>
                                    <th class="text-center">Trạng Thái</th>
                                    <th class="text-center">Số Đơn Nhập</th>
                                    <th class="text-end">Doanh Thu Thu Được</th>
                                    <th class="text-center">Hành động</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (ViewBag.StaffPerformance != null)
                                {
                                    foreach (var p in ViewBag.StaffPerformance)
                                    {
                                        <tr class="leaderboard-row">
                                            <td>
                                                <div class="fw-bold text-dark">@p.StaffName</div>
                                                <div style="font-size: 0.7rem; color: #888;">ID: @p.StaffId</div>
                                            </td>
                                            <td class="text-center">
                                                <span class="badge @(p.IsWorking ? "bg-success" : "bg-light text-muted")" style="font-size: 0.65rem;">
                                                    @(p.IsWorking ? "ĐANG LÀM" : "OFFLINE")
                                                </span>
                                            </td>
                                            <td class="text-center fw-bold">@p.DayOrders</td>
                                            <td class="text-end fw-bold text-success">@string.Format("{0:N0}", p.DayRev) K</td>
                                            <td class="text-center">
                                                <a href="@Url.Action("Index", new { targetStaffId = p.StaffId })#history" class="btn-modern btn-primary-modern" style="padding: 5px 15px; font-size: 0.75rem;">Xem Nhật Ký</a>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
            else
            {
                <!-- GIAO DIỆN DÀNH RIÊNG CHO NHÂN VIÊN (US) -->
                <div class="modern-card p-5">
                    <h4 class="fw-bold mb-4 text-center">📈 TỔNG KẾT HIỆU SUẤT CÁ NHÂN</h4>
                    
                    @if (ViewBag.CurrentShift != null)
                    {
                        <div class="alert alert-info d-flex justify-content-between align-items-center" style="border-radius: 15px; padding: 20px; margin-bottom: 40px;">
                            <div>
                                <h5 class="mb-1">🟢 Bạn đang trong ca làm việc hoạt động</h5>
                                <p class="mb-0 small">Bắt đầu lúc: <strong>@ViewBag.CurrentShift.StartTime.ToString("HH:mm - dd/MM/yyyy")</strong></p>
                            </div>
                            <form asp-controller="Shift" asp-action="End" method="POST">
                                <button type="submit" class="btn-modern" style="background: #ea4335; color: white; border: none; cursor: pointer;" onclick="return confirm('Bạn muốn kết thúc ca làm việc này?')">Kết Thúc Ca</button>
                            </form>
                        </div>
                    }

                    <div style="display: flex; gap: 30px; justify-content: center;">
                        <div class="card report-card p-5 text-center border-bottom border-success border-5 shadow" style="min-width: 350px;">
                            <div class="stat-label" style="font-size: 1rem;">Đơn hàng đã giao thành công</div>
                            <div class="stat-value text-success" style="font-size: 3rem;">@ViewBag.DeliveredOrders</div>
                            <div style="color: #888; margin-top: 10px;">Tổng số đơn bạn đã nhập và hoàn thành</div>
                        </div>
                        
                        <div class="card report-card p-5 text-center border-bottom border-primary border-5 shadow" style="min-width: 350px;">
                            <div class="stat-label" style="font-size: 1rem;">Tổng doanh thu thu được</div>
                            <div class="stat-value text-primary" style="font-size: 3rem;">@string.Format("{0:N0}", ViewBag.TotalRevenue) K</div>
                            <div style="color: #888; margin-top: 10px;">Tổng số tiền cước từ các đơn hàng bạn xử lý</div>
                        </div>
                    </div>

                    <div class="mt-5 text-center">
                        <p class="text-muted italic">Dữ liệu được cập nhật thời gian thực dựa trên các đơn hàng có trạng thái "Đã chuyển".</p>
                    </div>
                </div>
            }
        </div>

        <!-- ========================== TAB 2: LỊCH SỬ CA LÀM ========================== -->
        <div class="tab-pane fade @(viewShiftId != null ? "show active" : "")" id="history">
            <div class="modern-card p-5 text-center">
                <div style="font-size: 4rem; margin-bottom: 20px;">⏰</div>
                <h3 class="fw-bold mb-3">Hệ Thống Quản Lý Ca Làm Việc Mới</h3>
                
                @if (role == "AD")
                {
                    <a asp-controller="Shift" asp-action="Index" class="btn-modern btn-primary-modern" style="padding: 15px 40px; font-size: 1.1rem;text-decoration:none;">
                        🚀 TRUY CẬP QUẢN LÝ CA TRỰC
                    </a>
                }
                else
                {
                        <a asp-controller="Shift" asp-action="MyHistory" class="btn-modern btn-primary-modern" style="padding: 15px 40px; font-size: 1.1rem;text-decoration:none;">
                        📖 XEM LỊCH SỬ LÀM VIỆC CỦA TÔI
                    </a>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        @if (role == "AD") {
            <text>
            const ctxRev = document.getElementById('realRevenueChart');
            if (ctxRev) {
                new Chart(ctxRev, {
                    type: 'line',
                    data: {
                        labels: @Html.Raw(Json.Serialize(ViewBag.ChartLabels)),
                        datasets: [{
                            label: 'Doanh thu hệ thống (K VNĐ)',
                            data: @Html.Raw(Json.Serialize(ViewBag.ChartData)),
                            borderColor: '#1a73e8',
                            backgroundColor: 'rgba(26, 115, 232, 0.1)',
                            fill: true,
                            tension: 0.4,
                            borderWidth: 3,
                            pointRadius: 5,
                            pointBackgroundColor: '#fff',
                            pointBorderColor: '#1a73e8'
                        }]
                    },
                    options: { 
                        responsive: true, 
                        maintainAspectRatio: false,
                        scales: { y: { beginAtZero: true } }
                    }
                });
            }
            </text>
        }

        var buttons = document.querySelectorAll('.report-tab-btn');
        buttons.forEach(function(btn) {
            btn.addEventListener('click', function() {
                buttons.forEach(b => b.classList.remove('active'));
                this.classList.add('active');
            });
        });

        window.addEventListener('load', function() {
            if (window.location.hash === '#history') {
                var historyTabEl = document.getElementById('history-tab');
                if (historyTabEl) {
                    var bootstrapTab = new bootstrap.Tab(historyTabEl);
                    bootstrapTab.show();
                    buttons.forEach(b => b.classList.remove('active'));
                    historyTabEl.classList.add('active');
                }
            }
        });
    </script>
}
