@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor

@{
    ViewData["Title"] = "Báo Cáo Hệ Thống";
    var role = HttpContextAccessor.HttpContext.Session.GetString("Role");
    var reportDate = ViewBag.ReportDate;
    var shiftHistory = ViewBag.ShiftHistory as IEnumerable<Delivery_System.Models.TblWorkShift>;
    var shiftOrders = ViewBag.ShiftOrders as IEnumerable<Delivery_System.Models.TblOrder>;
    var viewShiftId = ViewBag.ViewShiftId;
    var selectedStaffId = ViewBag.SelectedStaffId;
}

@section Styles {
    <link rel="stylesheet" href="~/css/report.css">
}

<div class="container-custom">
    
    <div class="modern-page-header">
        <div>
            <h3>📊 @(role == "AD" ? "BÁO CÁO & THỐNG KÊ" : "KẾT QUẢ LÀM VIỆC CÁ NHÂN")</h3>
            <div class="modern-page-header-meta">@(role == "AD" ? "Theo dõi doanh thu và hiệu suất ca làm việc toàn hệ thống" : "Theo dõi hiệu suất và lịch sử ca làm việc của bạn")</div>
        </div>
        <a asp-controller="Home" asp-action="Index" class="btn-modern btn-header-back">
            ← Quay lại Trang Chủ
        </a>
    </div>

    <div class="d-flex gap-3 mb-4" id="reportTabs" role="tablist">
        <button class="report-tab-btn @(viewShiftId == null ? "active" : "")" id="summary-tab" data-bs-toggle="tab" data-bs-target="#summary" type="button">📋 Tổng Quan</button>
        <button class="report-tab-btn @(viewShiftId != null ? "active" : "")" id="history-tab" data-bs-toggle="tab" data-bs-target="#history" type="button">📜 Nhật Ký Làm Việc</button>
    </div>

    <div class="tab-content" id="reportTabsContent">
        <!-- ========================== TAB 1: TỔNG QUAN ========================== -->
        <div class="tab-pane fade @(viewShiftId == null ? "show active" : "")" id="summary">
            @if (role == "AD")
            {
                <div class="modern-card mb-4">
                    <form asp-action="Index" method="GET" class="filter-form-row">
                        <div class="filter-input-group">
                            <label class="stat-label filter-input-label">Chọn ngày xem dữ liệu</label>
                            <input type="date" name="reportDate" class="form-control filter-input-date" value="@reportDate">
                        </div>
                        <button type="submit" class="btn-modern btn-primary-modern filter-btn-update">🔍 CẬP NHẬT DỮ LIỆU</button>
                        <div class="date-badge-container">
                            <span class="badge badge-info date-badge">📅 Ngày: <strong>@DateTime.Parse(reportDate).ToString("dd/MM/yyyy")</strong></span>
                        </div>
                    </form>
                </div>

                <div class="row mb-4 stat-cards-row">
                    <div class="stat-card-col">
                        <div class="card report-card p-4 border-start border-primary border-5 shadow-sm">
                            <div class="stat-label">Doanh thu hệ thống (Ngày)</div>
                            <div class="stat-value text-primary">@string.Format("{0:N0}", ViewBag.RevenueDateVal) K</div>
                        </div>
                    </div>
                    <div class="stat-card-col">
                        <div class="card report-card p-4 border-start border-info border-5 shadow-sm">
                            <div class="stat-label">Đơn hàng mới</div>
                            <div class="stat-value text-info">@ViewBag.OrdersDateVal</div>
                        </div>
                    </div>
                    <div class="stat-card-col">
                        <div class="card report-card p-4 border-start border-warning border-5 shadow-sm">
                            <div class="stat-label">Nhân sự đang Online</div>
                            <div class="stat-value text-warning">@ViewBag.ActiveStaffCount</div>
                        </div>
                    </div>
                </div>

                <div class="card report-card p-4 mb-4">
                    <h5 class="fw-bold mb-4" style="color: #333;">🚀 Tăng Trưởng Doanh Thu Toàn Hệ Thống (7 Ngày)</h5>
                    <div class="chart-container">
                        <canvas id="realRevenueChart"></canvas>
                    </div>
                </div>

                <div class="card report-card p-4 mb-4">
                    <h5 class="fw-bold mb-4" style="color: #333;">👥 Hiệu Suất Nhân Viên Hôm Nay</h5>
                    <div class="table-responsive">
                        <table class="table align-middle">
                            <thead class="table-light">
                                <tr class="table-header-text">
                                    <th>Nhân Viên</th>
                                    <th class="text-center">Trạng Thái</th>
                                    <th class="text-center">Số Đơn Nhập</th>
                                    <th class="text-end">Doanh Thu Thu Được</th>
                                    <th class="text-center">Hành động</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (ViewBag.StaffPerformance != null)
                                {
                                    foreach (var p in ViewBag.StaffPerformance)
                                    {
                                        <tr class="leaderboard-row">
                                            <td>
                                                <div class="fw-bold text-dark">@p.StaffName</div>
                                                <div class="staff-id-text">ID: @p.StaffId</div>
                                            </td>
                                            <td class="text-center">
                                                <span class="badge @(p.IsWorking ? "bg-success" : "bg-light text-muted") badge-status-staff">
                                                    @(p.IsWorking ? "ĐANG LÀM" : "OFFLINE")
                                                </span>
                                            </td>
                                            <td class="text-center fw-bold">@p.DayOrders</td>
                                            <td class="text-end fw-bold text-success">@string.Format("{0:N0}", p.DayRev) K</td>
                                            <td class="text-center">
                                                <a href="@Url.Action("Index", new { targetStaffId = p.StaffId })#history" class="btn-modern btn-primary-modern btn-action-view">Xem Nhật Ký</a>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
            else
            {
                <!-- GIAO DIỆN DÀNH RIÊNG CHO NHÂN VIÊN (US) -->
                <div class="modern-card p-5">
                    <h4 class="fw-bold mb-4 text-center">📈 TỔNG KẾT HIỆU SUẤT CÁ NHÂN</h4>
                    
                    @if (ViewBag.CurrentShift != null)
                    {
                        <div class="alert alert-info d-flex justify-content-between align-items-center shift-active-alert">
                            <div>
                                <h5 class="mb-1">🟢 Bạn đang trong ca làm việc hoạt động</h5>
                                <p class="mb-0 small">Bắt đầu lúc: <strong>@ViewBag.CurrentShift.StartTime.ToString("HH:mm - dd/MM/yyyy")</strong></p>
                            </div>
                            <a asp-controller="Shift" asp-action="End" class="btn-modern btn-end-shift">Kết Thúc Ca</a>
                        </div>
                    }

                    <div class="summary-cards-flex">
                        <div class="card report-card p-5 text-center border-bottom border-success border-5 shadow summary-stat-card">
                            <div class="stat-label" style="font-size: 1rem;">Đơn hàng đã giao thành công</div>
                            <div class="stat-value text-success summary-stat-value">@ViewBag.DeliveredOrders</div>
                            <div class="summary-footer-note">Tổng số đơn bạn đã nhập và hoàn thành</div>
                        </div>
                        
                        <div class="card report-card p-5 text-center border-bottom border-primary border-5 shadow summary-stat-card">
                            <div class="stat-label" style="font-size: 1rem;">Tổng doanh thu thu được</div>
                            <div class="stat-value text-primary summary-stat-value">@string.Format("{0:N0}", ViewBag.TotalRevenue) K</div>
                            <div class="summary-footer-note">Tổng số tiền cước từ các đơn hàng bạn xử lý</div>
                        </div>
                    </div>

                    <div class="mt-5 text-center">
                        <p class="text-muted italic">Dữ liệu được cập nhật thời gian thực dựa trên các đơn hàng có trạng thái "Đã chuyển".</p>
                    </div>
                </div>
            }
        </div>

        <!-- ========================== TAB 2: LỊCH SỬ CA LÀM ========================== -->
        <div class="tab-pane fade @(viewShiftId != null ? "show active" : "")" id="history">
            <div class="history-flex-container">
                <div class="history-list-col @(viewShiftId != null ? "with-detail" : "")">
                    <div class="card report-card p-4">
                        <h5 class="fw-bold mb-3 text-secondary">
                            📜 Nhật ký 20 ca làm việc gần nhất
                            @if (role == "AD") { <small class="text-primary">(Đang xem: @selectedStaffId)</small> }
                        </h5>
                        <div class="table-responsive">
                            <table class="table table-hover align-middle">
                                <thead class="table-dark">
                                    <tr>
                                        <th>Mã Ca</th>
                                        <th>Bắt đầu</th>
                                        <th>Kết thúc</th>
                                        <th>Trạng thái</th>
                                        <th class="text-center">Hành động</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (shiftHistory != null) {
                                        foreach (var s in shiftHistory)
                                        {
                                            <tr class="@(s.ShiftId == viewShiftId ? "table-info" : "")">
                                                <td><strong>#@s.ShiftId</strong></td>
                                                <td class="shift-time-text">@s.StartTime.ToString("dd/MM/yyyy HH:mm")</td>
                                                <td class="shift-time-text">@(s.EndTime?.ToString("dd/MM/yyyy HH:mm") ?? "---")</td>
                                                <td>
                                                    <span class="badge @(s.Status == "ACTIVE" ? "bg-success" : "bg-secondary")">@s.Status</span>
                                                </td>
                                                <td class="text-center">
                                                    <a href="@Url.Action("Index", new { viewShiftId = s.ShiftId, targetStaffId = selectedStaffId })#history" 
                                                       class="btn-modern btn-primary-modern btn-action-view">Chi tiết</a>
                                                </td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                @if (viewShiftId != null)
                {
                    <div class="history-detail-col">
                        <div class="card report-card p-4">
                            <h5 class="fw-bold mb-3 text-primary d-flex justify-content-between">
                                <span>📦 ĐƠN HÀNG TRONG CA #@viewShiftId</span>
                                <span class="badge badge-info">@(shiftOrders?.Count() ?? 0) đơn</span>
                            </h5>
                            <table class="table table-hover">
                                <thead class="table-light">
                                    <tr><th>Mã Đơn</th><th>Tên Hàng</th><th class="text-end">Cước</th></tr>
                                </thead>
                                <tbody>
                                    @if (shiftOrders != null) {
                                        foreach (var o in shiftOrders) {
                                            <tr>
                                                <td><strong class="order-id-highlight">@o.OrderId</strong></td>
                                                <td>@o.ItemName</td>
                                                <td class="text-end fw-bold text-success">@string.Format("{0:N0}", o.Amount ?? 0) K</td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        @if (role == "AD") {
            <text>
            const ctxRev = document.getElementById('realRevenueChart');
            if (ctxRev) {
                new Chart(ctxRev, {
                    type: 'line',
                    data: {
                        labels: @Html.Raw(Json.Serialize(ViewBag.ChartLabels)),
                        datasets: [{
                            label: 'Doanh thu hệ thống (K VNĐ)',
                            data: @Html.Raw(Json.Serialize(ViewBag.ChartData)),
                            borderColor: '#1a73e8',
                            backgroundColor: 'rgba(26, 115, 232, 0.1)',
                            fill: true,
                            tension: 0.4,
                            borderWidth: 3,
                            pointRadius: 5,
                            pointBackgroundColor: '#fff',
                            pointBorderColor: '#1a73e8'
                        }]
                    },
                    options: { 
                        responsive: true, 
                        maintainAspectRatio: false,
                        scales: { y: { beginAtZero: true } }
                    }
                });
            }
            </text>
        }

        var buttons = document.querySelectorAll('.report-tab-btn');
        buttons.forEach(function(btn) {
            btn.addEventListener('click', function() {
                buttons.forEach(b => b.classList.remove('active'));
                this.classList.add('active');
            });
        });

        window.addEventListener('load', function() {
            if (window.location.hash === '#history') {
                var historyTabEl = document.getElementById('history-tab');
                if (historyTabEl) {
                    var bootstrapTab = new bootstrap.Tab(historyTabEl);
                    bootstrapTab.show();
                    buttons.forEach(b => b.classList.remove('active'));
                    historyTabEl.classList.add('active');
                }
            }
        });
    </script>
}
