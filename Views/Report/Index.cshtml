@{
    ViewData["Title"] = "Báo Cáo Hệ Thống";
    var role = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value;
    var reportDate = ViewBag.ReportDate;
    var shiftHistory = ViewBag.ShiftHistory as IEnumerable<Delivery_System.Models.TblWorkShift>;
}

@section Styles {
    <link rel="stylesheet" href="~/css/report.css?v=@DateTime.Now.Ticks">
}

<div class="rp-container">
    
        <div class="modern-page-header">
        <div>
                <h3 class="modern-page-header h3">📊 @(role == "AD" ? "BÁO CÁO & THỐNG KÊ" : "KẾT QUẢ LÀM VIỆC CÁ NHÂN")</h3>
            <div class="moderm-header-subtext">@(role == "AD" ? "Theo dõi doanh thu và hiệu suất ca làm việc toàn hệ thống" : "Theo dõi hiệu suất và lịch sử ca làm việc của bạn")</div>
        </div>
        <a asp-controller="Home" asp-action="Index" class="rp-btn rp-btn-home">
            ← Trang Chủ
        </a>
    </div>

    <div class="rp-tabs" id="reportTabs">
        <button class="rp-tab-btn active" onclick="switchReportTab('summary', this)">📋 Tổng Quan</button>
        <button class="rp-tab-btn" onclick="switchReportTab('history', this)">📜 Nhật Ký Làm Việc</button>
    </div>

    <!-- ========================== TAB 1: TỔNG QUAN ========================== -->
    <div id="tab-summary" class="rp-tab-pane active">
        <!-- BỘ LỌC NGÀY CHUNG -->
        <div class="rp-card">
            <form asp-action="Index" method="GET" class="rp-filter-bar">
                <div class="rp-filter-group">
                    <label class="rp-filter-label">Chọn ngày xem dữ liệu</label>
                    <input type="date" name="reportDate" class="rp-filter-input" value="@reportDate">
                </div>
                <button type="submit" class="rp-btn rp-btn-primary">🔍 CẬP NHẬT DỮ LIỆU</button>
                <div class="rp-date-badge-wrapper">
                    <span class="rp-date-badge">📅 Đang xem: <strong>@DateTime.Parse(reportDate).ToString("dd/MM/yyyy")</strong></span>
                </div>
            </form>
        </div>

        @if (role == "AD")
        {
            <div class="rp-card">
                <h5 class="rp-card-title rp-text-center">🚀 Tăng Trưởng Doanh Thu Toàn Hệ Thống (7 Ngày)</h5>
                <div class="rp-chart-box">
                    <canvas id="realRevenueChart"></canvas>
                </div>
            </div>
        }
        else
        {
            <div class="rp-card">
                <h4 class="rp-summary-title">📈 Bảng Tổng Kết Hiệu Suất</h4>
                
                @if (ViewBag.CurrentShift != null)
                {
                    <div class="rp-alert-info">
                        <div>
                            <h5 class="mb-1">🟢 Bạn đang trong ca làm việc hoạt động</h5>
                            <p class="mb-0 small">Bắt đầu lúc: <strong>@ViewBag.CurrentShift.StartTime.ToString("HH:mm - dd/MM/yyyy")</strong></p>
                        </div>
                        <form asp-controller="Shift" asp-action="End" method="POST">
                            <button type="submit" class="rp-btn rp-btn-danger" onclick="return confirm('Bạn muốn kết thúc ca làm việc này?')">Kết Thúc Ca</button>
                        </form>
                    </div>
                }

                <div class="rp-goods-grid">
                    <div class="rp-goods-card">
                        <div class="rp-card-icon">📦</div>
                        <h3>@ViewBag.OrdersDateVal</h3>
                        <p>Đơn hàng đã giao thành công trong ngày @DateTime.Parse(reportDate).ToString("dd/MM")</p>
                        <span class="rp-btn-access rp-bg-blue">Đơn trong ngày</span>
                    </div>

                    <div class="rp-goods-card">
                        <div class="rp-card-icon">💰</div>
                        <h3>@ViewBag.RevenueDateVal.ToString("N0") K</h3>
                        <p>Tổng doanh thu trong ngày @DateTime.Parse(reportDate).ToString("dd/MM")</p>
                        <span class="rp-btn-access rp-bg-yellow">Cước trong ngày</span>
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- ========================== TAB 2: NHẬT KÝ LÀM VIỆC ========================== -->
    <div id="tab-history" class="rp-tab-pane">
        <main class="rp-card">
            <div class="rp-card-title rp-d-flex rp-justify-between rp-align-center">
                <h2>📜 Lịch Sử Hoạt Động gần nhất</h2>
            </div>

            <div class="rp-card" style="background: #f8fafc; border: 1px dashed #cbd5e1; margin-bottom: 20px; padding: 20px;">
                <form asp-action="Index" method="GET" class="rp-filter-bar">
                    <input type="hidden" name="reportDate" value="@reportDate" />
                    
                    @if (role == "AD")
                    {
                        <div class="rp-filter-group">
                            <label class="rp-filter-label">Theo Trạm</label>
                            <select name="stationId" class="rp-filter-input">
                                <option value="">-- Tất cả các trạm --</option>
                                @foreach (var s in ViewBag.StationList as IEnumerable<Delivery_System.Models.TblStation>)
                                {
                                    <option value="@s.StationId" selected="@(ViewBag.StationId == s.StationId ? "selected" : null)">@s.StationName</option>
                                }
                            </select>
                        </div>

                        <div class="rp-filter-group">
                            <label class="rp-filter-label">Tìm Nhân Viên (Tên/ID)</label>
                            <input type="text" name="searchStaff" class="rp-filter-input" placeholder="Nhập tên hoặc ID..." value="@ViewBag.SearchStaff" />
                        </div>
                    }

                    <div class="rp-filter-group">
                        <label class="rp-filter-label">Theo Ngày</label>
                        <input type="date" name="logDate" class="rp-filter-input" value="@ViewBag.LogDate" />
                    </div>

                    <button type="submit" class="rp-btn rp-btn-primary" onclick="sessionStorage.setItem('activeReportTab', 'history')">🔍 LỌC NHẬT KÝ</button>
                    <a asp-action="Index" asp-route-reportDate="@reportDate" class="rp-btn" style="background: #94a3b8; color: white;" onclick="sessionStorage.setItem('activeReportTab', 'history')">🔄 Reset</a>
                </form>
            </div>

            <div class="rp-table-wrap">
                <table class="rp-table">
                    <thead>
                        <tr>
                            <th>Nhân Viên</th>
                            <th>Giờ Bắt Đầu</th>
                            <th>Giờ Kết Thúc</th>
                            <th>Doanh Thu (K)</th>
                            <th>Trạng Thái</th>
                            <th class="rp-text-center">Thao Tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (shiftHistory != null && shiftHistory.Any())
                        {
                            foreach (var item in shiftHistory)
                            {
                                <tr>
                                    <td>
                                        <div class="rp-avatar-wrap">
                                            <div class="rp-avatar">
                                                @item.Staff.FullName.Substring(0,1).ToUpper()
                                            </div>
                                            <div>
                                                <div class="rp-staff-name">@item.Staff.FullName</div>
                                                <div class="rp-staff-id">ID: @item.StaffId</div>
                                            </div>
                                        </div>
                                    </td>
                                    <td>@item.StartTime.ToString("dd/MM HH:mm")</td>
                                    <td>@(item.EndTime?.ToString("dd/MM HH:mm") ?? "—")</td>
                                    <td><span class="rp-text-revenue">@item.Revenue.ToString("N0")</span></td>
                                    <td>
                                        <span class="rp-badge @(item.Status == "ACTIVE" ? "rp-badge-active" : "rp-badge-ended")">
                                            @(item.Status == "ACTIVE" ? "Đang trực" : "Đã nghỉ")
                                        </span>
                                    </td>
                                    <td class="rp-text-center">
                                        <button type="button" onclick="openShiftDetails(@item.ShiftId)" class="rp-btn-s rp-btn-s-blue">👁️ Chi tiết</button>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr><td colspan="6" class="rp-text-center p-4">Chưa có lịch sử ca làm việc</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </main>
    </div>
</div>

<!-- MODAL CHI TIẾT CA TRỰC -->
<div id="shiftDetailsModal" class="rp-modal">
    <div class="rp-modal-content">
        <div id="shiftModalBody" class="rp-modal-body"></div>
        <div class="rp-modal-footer">
            <button type="button" onclick="closeShiftDetails()" class="rp-btn-close-modal">ĐÓNG</button>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        function switchReportTab(tabId, btn) {
            document.querySelectorAll('.rp-tab-pane').forEach(p => p.classList.remove('active'));
            document.querySelectorAll('.rp-tab-btn').forEach(b => b.classList.remove('active'));
            
            document.getElementById('tab-' + tabId).classList.add('active');
            if (btn) {
                btn.classList.add('active');
            } else {
                // Find button if btn is not provided (e.g. from sessionStorage)
                document.querySelectorAll('.rp-tab-btn').forEach(b => {
                    if (b.getAttribute('onclick').includes(tabId)) b.classList.add('active');
                });
            }
            sessionStorage.setItem('activeReportTab', tabId);
        }

        window.onload = function() {
            const activeTab = sessionStorage.getItem('activeReportTab');
            if (activeTab && activeTab !== 'summary') {
                switchReportTab(activeTab);
            }
        };

        async function openShiftDetails(id) {
            const modal = document.getElementById('shiftDetailsModal');
            const body = document.getElementById('shiftModalBody');
            modal.style.display = 'flex';
            body.innerHTML = '<div class="rp-text-center p-4">Đang tải...</div>';

            try {
                const response = await fetch(`/Report/Details/${id}`);
                body.innerHTML = await response.text();
            } catch (error) {
                body.innerHTML = '<div class="rp-text-center p-4 text-danger">Lỗi tải dữ liệu</div>';
            }
        }

        function closeShiftDetails() {
            document.getElementById('shiftDetailsModal').style.display = 'none';
        }

        // Hàm chuyển Tab bên trong Modal Chi tiết ca làm việc
        function showModalInnerTab(tabName, btn) {
            // Ẩn tất cả các vùng nội dung Tab trong modal
            document.querySelectorAll('.rp-modal-inner-tab').forEach(t => t.classList.remove('active'));
            // Gỡ bỏ trạng thái active của tất cả các nút tab trong modal
            document.querySelectorAll('.rp-modal-tab-btn').forEach(l => l.classList.remove('active'));
            
            // Hiển thị vùng nội dung được chọn
            const targetTab = document.getElementById('modal-tab-' + tabName);
            if (targetTab) {
                targetTab.classList.add('active');
            }
            // Thêm trạng thái active cho nút vừa bấm
            btn.classList.add('active');
        }

        @if (role == "AD") {
            <text>
            const ctxRev = document.getElementById('realRevenueChart');
            if (ctxRev) {
                new Chart(ctxRev, {
                    type: 'line',
                    data: {
                        labels: @Html.Raw(Json.Serialize(ViewBag.ChartLabels)),
                        datasets: [{
                            label: 'Doanh thu hệ thống (K)',
                            data: @Html.Raw(Json.Serialize(ViewBag.ChartData)),
                            borderColor: '#1a73e8',
                            backgroundColor: 'rgba(26, 115, 232, 0.1)',
                            fill: true, tension: 0.4, borderWidth: 3
                        }]
                    },
                    options: { responsive: true, maintainAspectRatio: false }
                });
            }
            </text>
        }
    </script>
}
