@{
    ViewData["Title"] = "Báo Cáo Hệ Thống";
    var role = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value;
    var defaultDate = ViewBag.ReportDate as string;
}

@section Styles {
    <link rel="stylesheet" href="~/css/report.css?v=@DateTime.Now.Ticks">
}

<div class="rp-container">
    <!-- NÚT CHUYỂN TAB -->
    <div class="rp-tabs" id="reportTabs">
        <button class="rp-tab-btn" data-tab="summary" onclick="switchTab('summary')">📋 Tổng Quan</button>
        <button class="rp-tab-btn" data-tab="activity" onclick="switchTab('activity')">📦 Lịch sử Hoạt Động</button>
    </div>

    <!-- VÙNG CHỨA NỘI DUNG TAB (LOAD QUA AJAX) -->
    <div id="tabContentContainer" class="rp-tab-pane active">
        <div class="rp-loading-box rp-p-5">
            <div class="rp-spinner"></div>
            <p class="rp-mt-2">Đang tải dữ liệu báo cáo...</p>
        </div>
    </div>
</div>

<!-- MODAL POPUP (DETAILS) -->
<div id="shiftDetailsModal" class="rp-modal">
    <div class="rp-modal-content">
        <div id="shiftModalBody" class="rp-modal-body"></div>
        <div class="rp-modal-footer">
            <button type="button" onclick="closeShiftDetails()" class="rp-btn-close-modal">ĐÓNG</button>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        let currentActiveTab = sessionStorage.getItem('activeReportTab') || 'summary';
        let selectedReportDate = '@defaultDate';

        window.onload = function() {
            switchTab(currentActiveTab);
        };

        function switchTab(tabId) {
            document.querySelectorAll('.rp-tab-btn').forEach(b => {
                b.classList.toggle('active', b.dataset.tab === tabId);
            });
            sessionStorage.setItem('activeReportTab', tabId);
            loadTabContent(tabId);
        }

        async function loadTabContent(tabId, event = null) {
            if (event) event.preventDefault();

            const container = document.getElementById('tabContentContainer');
            if (!event) container.innerHTML = '<div class="rp-loading-box rp-p-5"><div class="rp-spinner"></div><p>Đang tải...</p></div>';

            let url = '';
            let params = '';

            if (event) {
                const formData = new FormData(event.target);
                params = new URLSearchParams(formData).toString();
                if (formData.has('reportDate')) selectedReportDate = formData.get('reportDate');
                if (formData.has('fromDate')) selectedReportDate = formData.get('fromDate');
            } else {
                if (tabId === 'summary') params = `reportDate=${selectedReportDate}`;
            }

            switch(tabId) {
                case 'summary': url = `/Report/GetSummary?${params}`; break;
                case 'activity': url = `/Report/GetActivity?${params}`; break;
            }

            try {
                const response = await fetch(url);
                if (!response.ok) throw new Error("Network response was not ok");
                const html = await response.text();
                container.innerHTML = html;
                
                if (tabId === 'summary') initChart();
            } catch (err) {
                container.innerHTML = '<div class="rp-alert-danger rp-text-center">Lỗi tải dữ liệu. Vui lòng tải lại trang.</div>';
            }
        }

        function initChart() {
            const ctx = document.getElementById('realRevenueChart');
            if (!ctx) return;
            const labels = JSON.parse(ctx.getAttribute('data-labels') || '[]');
            const values = JSON.parse(ctx.getAttribute('data-values') || '[]');
            new Chart(ctx, {
                type: 'line',
                data: {
                    labels: labels,
                    datasets: [{
                        label: 'Doanh thu (K)',
                        data: values,
                        borderColor: '#1a73e8',
                        backgroundColor: 'rgba(26, 115, 232, 0.1)',
                        fill: true,
                        tension: 0.4,
                        borderWidth: 3
                    }]
                },
                options: { responsive: true, maintainAspectRatio: false }
            });
        }

        async function openShiftDetails(id) {
            const modal = document.getElementById('shiftDetailsModal');
            const body = document.getElementById('shiftModalBody');
            modal.style.display = 'flex';
            body.innerHTML = '<div class="rp-loading-box"><div class="rp-spinner"></div><p>Đang tải...</p></div>';
            const resp = await fetch(`/Report/Details/${id}`);
            body.innerHTML = await resp.text();
        }

        function closeShiftDetails() {
            document.getElementById('shiftDetailsModal').style.display = 'none';
        }

        function showModalInnerTab(tabName, btn) {
            document.querySelectorAll('.rp-modal-inner-tab').forEach(t => t.classList.remove('active'));
            document.querySelectorAll('.rp-modal-tab-btn').forEach(l => l.classList.remove('active'));
            const target = document.getElementById('modal-tab-' + tabName);
            if (target) target.classList.add('active');
            btn.classList.add('active');
        }

        window.onclick = function(event) {
            const modal = document.getElementById('shiftDetailsModal');
            if (event.target == modal) {
                closeShiftDetails();
            }
        }
    </script>
}
