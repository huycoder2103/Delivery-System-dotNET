@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor

@{
    ViewData["Title"] = "Báo Cáo Hệ Thống";
    var role = HttpContextAccessor.HttpContext.Session.GetString("Role");
    var reportDate = ViewBag.ReportDate;
}

@section Styles {
    <link rel="stylesheet" href="~/css/report.css?v=@DateTime.Now.Ticks">
}

<div class="container-custom">
    
    <div class="modern-page-header report-header-gradient">
        <div>
            <h3>📊 @(role == "AD" ? "BÁO CÁO & THỐNG KÊ" : "KẾT QUẢ LÀM VIỆC CÁ NHÂN")</h3>
            <div class="report-header-subtext">@(role == "AD" ? "Theo dõi doanh thu và hiệu suất ca làm việc toàn hệ thống" : "Theo dõi hiệu suất và lịch sử ca làm việc của bạn")</div>
        </div>
        <a asp-controller="Home" asp-action="Index" class="btn-modern btn-back-home">
            ← Quay lại Trang Chủ
        </a>
    </div>

    <div class="d-flex gap-3 mb-4" id="reportTabs">
        <button class="report-tab-btn active" type="button">📋 Tổng Quan</button>
        <a href="@(role == "AD" ? Url.Action("Index", "Shift") : Url.Action("MyHistory", "Shift"))" class="report-tab-btn btn-no-decoration">📜 Nhật Ký Làm Việc</a>
    </div>

    <div class="tab-content" id="reportTabsContent">
        <!-- ========================== TAB 1: TỔNG QUAN ========================== -->
        <div class="tab-pane fade show active" id="summary">
            @if (role == "AD")
            {
                <div class="modern-card mb-4">
                    <form asp-action="Index" method="GET" class="filter-form-container">
                        <div class="filter-group-date">
                            <label class="stat-label filter-label">Chọn ngày xem dữ liệu</label>
                            <input type="date" name="reportDate" class="form-control filter-input-modern" value="@reportDate">
                        </div>
                        <button type="submit" class="btn-modern btn-primary-modern btn-update-report">🔍 CẬP NHẬT DỮ LIỆU</button>
                        <div class="date-badge-wrapper">
                            <span class="badge badge-info date-badge-modern">📅 Ngày: <strong>@DateTime.Parse(reportDate).ToString("dd/MM/yyyy")</strong></span>
                        </div>
                    </form>
                </div>

                <div class="stat-cards-flex mb-4">
                    <div class="stat-card-wrapper">
                        <div class="card report-card p-4 border-start border-primary border-5 shadow-sm">
                            <div class="stat-label">Doanh thu hệ thống (Ngày)</div>
                            <div class="stat-value text-primary">@string.Format("{0:N0}", ViewBag.RevenueDateVal) k</div>
                        </div>
                    </div>
                    <div class="stat-card-wrapper">
                        <div class="card report-card p-4 border-start border-info border-5 shadow-sm">
                            <div class="stat-label">Đơn hàng mới</div>
                            <div class="stat-value text-info">@ViewBag.OrdersDateVal</div>
                        </div>
                    </div>
                </div>

                <div class="card report-card p-4 mb-4">
                    <h5 class="fw-bold mb-4 chart-title">🚀 Tăng Trưởng Doanh Thu Toàn Hệ Thống (7 Ngày)</h5>
                    <div class="chart-box">
                        <canvas id="realRevenueChart"></canvas>
                    </div>
                </div>
            }
            else
            {
                <!-- GIAO DIỆN DÀNH RIÊNG CHO NHÂN VIÊN (US) -->
                <div class="modern-card p-5">
                    <h4 class="fw-bold mb-4 text-center">📈 TỔNG KẾT HIỆU SUẤT CÁ NHÂN</h4>
                    
                    @if (ViewBag.CurrentShift != null)
                    {
                        <div class="alert alert-info d-flex justify-content-between align-items-center active-shift-alert">
                            <div>
                                <h5 class="mb-1">🟢 Bạn đang trong ca làm việc hoạt động</h5>
                                <p class="mb-0 small">Bắt đầu lúc: <strong>@ViewBag.CurrentShift.StartTime.ToString("HH:mm - dd/MM/yyyy")</strong></p>
                            </div>
                            <form asp-controller="Shift" asp-action="End" method="POST">
                                <button type="submit" class="btn-modern btn-end-shift-modern" onclick="return confirm('Bạn muốn kết thúc ca làm việc này?')">Kết Thúc Ca</button>
                            </form>
                        </div>
                    }

                    <div class="us-stat-flex">
                        <div class="card report-card p-5 text-center border-bottom border-success border-5 shadow us-report-card">
                            <div class="stat-label us-stat-label">Đơn hàng đã giao thành công</div>
                            <div class="stat-value text-success us-stat-value">@ViewBag.DeliveredOrders</div>
                            <div class="us-footer-note">Tổng số đơn bạn đã nhập và hoàn thành</div>
                        </div>
                        
                        <div class="card report-card p-5 text-center border-bottom border-primary border-5 shadow us-report-card">
                            <div class="stat-label us-stat-label">Tổng doanh thu thu được</div>
                            <div class="stat-value text-primary us-stat-value">@string.Format("{0:N0}", ViewBag.TotalRevenue) K</div>
                            <div class="us-footer-note">Tổng số tiền cước từ các đơn hàng bạn xử lý</div>
                        </div>
                    </div>

                    <div class="mt-5 text-center">
                        <p class="text-muted italic">Dữ liệu được cập nhật thời gian thực dựa trên các đơn hàng có trạng thái "Đã chuyển".</p>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        // Hiệu ứng hold bằng JS để đảm bảo cảm giác nhấn cực nhạy
        document.querySelectorAll('.report-tab-btn').forEach(btn => {
            btn.addEventListener('mousedown', function() {
                this.style.transform = 'scale(0.92) translateY(2px)';
                this.style.filter = 'brightness(0.85)';
            });
            btn.addEventListener('mouseup', function() {
                this.style.transform = '';
                this.style.filter = '';
            });
            btn.addEventListener('mouseleave', function() {
                this.style.transform = '';
                this.style.filter = '';
            });
        });

        @if (role == "AD") {
            <text>
            const ctxRev = document.getElementById('realRevenueChart');
            if (ctxRev) {
                new Chart(ctxRev, {
                    type: 'line',
                    data: {
                        labels: @Html.Raw(Json.Serialize(ViewBag.ChartLabels)),
                        datasets: [{
                            label: 'Doanh thu hệ thống (.000 VNĐ)',
                            data: @Html.Raw(Json.Serialize(ViewBag.ChartData)),
                            borderColor: '#1a73e8',
                            backgroundColor: 'rgba(26, 115, 232, 0.1)',
                            fill: true,
                            tension: 0.4,
                            borderWidth: 3,
                            pointRadius: 5,
                            pointBackgroundColor: '#fff',
                            pointBorderColor: '#1a73e8'
                        }]
                    },
                    options: { 
                        responsive: true, 
                        maintainAspectRatio: false,
                        scales: { y: { beginAtZero: true } }
                    }
                });
            }
            </text>
        }
    </script>
}
