<div class="rp-card">
    <div class="rp-filter-bar rp-filter-bar-header">
        <form onsubmit="loadTabContent('summary', event)" class="rp-d-flex rp-align-center rp-gap-1">
            <div class="rp-filter-group">
                <input type="date" name="reportDate" value="@ViewBag.SelectedDate" class="rp-filter-input" onchange="this.form.requestSubmit()">
            </div>
            <button type="submit" class="rp-btn rp-btn-primary">Tiềm kiếm</button>
        </form>
    </div>

    <h4 class="rp-summary-title">Bảng Tổng Kết Hiệu Suất Cá Nhân</h4>
    
    @if (ViewBag.CurrentShift != null) {
        <div class="rp-alert-info">
            <div>
                <h5>🟢 Đang trong ca làm việc hoạt động</h5>
                <p>Bắt đầu lúc: <strong>@ViewBag.CurrentShift.StartTime.ToString("HH:mm - dd/MM/yyyy")</strong></p>
            </div>
            <form asp-controller="Home" asp-action="EndShift" method="POST">
                <button type="submit" class="rp-btn rp-btn-danger" onclick="return confirm('Kết thúc ca làm việc?')">Kết Thúc Ca</button>
            </form>
        </div>
    }

    <div class="rp-goods-grid">
        <a href="@Url.Action("List", "Order", new { searchStaff = User.GetUserId(), dateFilter = ViewBag.SelectedDate })" class="rp-goods-card rp-card-link">
            <h3>@ViewBag.OrdersDateVal</h3>
            <p>Đơn hàng đã nhập mới</p>
            <span class="rp-btn-access rp-bg-blue-alt">Theo dõi đơn</span>
        </a>
        <div class="rp-goods-card">
            <h3>@ViewBag.TotalPrepaid.ToString("N0") K</h3>
            <p>Cước thu từ người gửi (TR)</p>
            <span class="rp-btn-access rp-bg-yellow-alt">Tiền cước gửi</span>
        </div>
        <a href="@Url.Action("List", "Order", new { deliveredByStaff = User.GetUserId(), dateFilter = ViewBag.SelectedDate, statusFilter = "delivered" })" class="rp-goods-card rp-card-link">
            <h3>@ViewBag.TotalCOD.ToString("N0") K</h3>
            <p>Tiền COD thu khách (CT)</p>
            <span class="rp-btn-access rp-bg-green-alt">Tiền thu hộ</span>
        </a>
        <div class="rp-goods-card rp-highlight-card">
            <h2 class="text-danger">@ViewBag.CashHolding.ToString("N0") K</h2>
            <p class="font-weight-bold">TỔNG TIỀN MẶT ĐANG CẦM</p>
            <span class="rp-btn-access rp-bg-red-alt">Phải nộp cuối ca</span>
        </div>
    </div>
</div>
