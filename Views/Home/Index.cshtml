@{
    ViewData["Title"] = "Trang Chủ";
    var fullName = User.Identity.Name ?? "Nhân viên";
    var role = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value;
    var currentShift = ViewBag.CurrentShift as Delivery_System.Models.TblWorkShift;
}

@section Styles {
    <link rel="stylesheet" href="~/css/home.css" asp-append-version="true">
}

<div class="home-inner-wrapper">
    <!-- --- SHIFT MANAGEMENT WIDGET --- -->
    <div class="home-shift-widget">
        <div class="home-shift-info">
            <h4>Ca làm việc hiện tại</h4>
            <div class="home-shift-status">
                @if (currentShift != null)
                {
                    <span class="home-status-active">🟢 Đang trong ca (Mã ca: #@currentShift.ShiftId)</span>
                    <div class="home-shift-stats">
                        <div class="home-stat-item">Đã nhập: <b>@ViewBag.InputCount</b></div>
                        <div class="home-stat-item">Đã giao: <b>@ViewBag.DeliveredCount</b></div>
                        <div class="home-stat-item">Tổng thu: <b>@string.Format("{0:N0}", ViewBag.TotalRevenue) K</b></div>
                    </div>
                    <div class="home-shift-details-mini">
                        <span>TR: @string.Format("{0:N0}", ViewBag.TotalPrepaid) K</span> | 
                        <span>CT: @string.Format("{0:N0}", ViewBag.TotalCod) K</span>
                    </div>
                }
                else
                {
                    <span class="home-status-inactive">⚪ Chưa bắt đầu ca làm việc</span>
                }
            </div>
        </div>
        <div class="home-shift-actions">
            @if (currentShift == null)
            {
                <form asp-controller="Home" asp-action="StartShift" method="POST">
                    <button type="submit" class="home-btn-shift home-btn-start">BẮT ĐẦU CA</button>
                </form>
            }
            else
            {
                <form asp-controller="Home" asp-action="EndShift" method="POST" id="endShiftForm">
                    <button type="button" class="home-btn-shift home-btn-end" onclick="confirmEndShift()">KẾT THÚC CA</button>
                </form>
            }
        </div>
    </div>

    <div class="home-welcome-box">
        <h1>CHÀO MỪNG QUAY TRỞ LẠI!</h1>
        <p>Hệ thống quản lý hàng hóa & vận chuyển nội bộ</p>
        <div class="home-user-chip">
            <span>@fullName</span>
            <small>(@role)</small>
        </div>
    </div>

    <div class="home-menu-grid">
        <!-- 1. Quản lý hàng hóa -->
        <a asp-controller="Goods" asp-action="Index" class="home-menu-card no-decoration color-inherit">
            <div class="home-card-icon"><i class="bi bi-box-seam"></i></div>
            <h3>Quản lý hàng hóa</h3>
            <p>Nhập đơn hàng, bộ phận hàng, quản lý đơn hàng.</p>
            <span class="home-btn-card-action">Truy cập</span>
        </a>

        <!-- 2. Báo cáo & Thống kê -->
        <a asp-controller="Report" asp-action="Index" class="home-menu-card no-decoration color-inherit">
            <div class="home-card-icon"><i class="bi bi-bar-chart-line"></i></div>
            <h3>Báo cáo & Thống kê</h3>
            <p>Xem doanh thu, số lượng đơn theo ngày/tháng.</p>
            <span class="home-btn-card-action">Xem báo cáo</span>
        </a>

        <!-- 3. Hệ thống quản trị -->
        @if (role == "AD")
        {
            <a asp-controller="Admin" asp-action="Index" class="home-menu-card no-decoration color-inherit">
                <div class="home-card-icon"><i class="bi bi-shield-check"></i></div>
                <h3>Hệ thống quản trị</h3>
                <p>Quản lý nhân viên, cấu hình trạm xe, bảo mật.</p>
                <span class="home-btn-card-action">Vào quản trị</span>
            </a>
        }
        else
        {
            <div class="home-menu-card home-disabled">
                <div class="home-card-icon"><i class="bi bi-ban"></i></div>
                <h3>Hệ thống quản trị</h3>
                <p>Chức năng dành riêng cho Quản trị viên hệ thống.</p>
                <button type="button" class="home-btn-card-action" disabled>Bị khóa</button>
            </div>
        }
    </div>
</div>

<script>
    function confirmEndShift() {
        Swal.fire({
            title: 'Kết thúc ca làm?',
            text: "Hệ thống sẽ chốt số lượng đơn và doanh thu trong ca này của bạn!",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#d33',
            cancelButtonColor: '#3085d6',
            confirmButtonText: '🛑 Kết thúc ngay',
            cancelButtonText: 'Tiếp tục làm'
        }).then((result) => {
            if (result.isConfirmed) {
                document.getElementById('endShiftForm').submit();
            }
        })
    }
</script>
