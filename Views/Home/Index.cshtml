@{
    ViewData["Title"] = "Trang Chủ";
    var fullName = User.Identity.Name ?? "Nhân viên";
    var role = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value;
    var currentShift = ViewBag.CurrentShift as Delivery_System.Models.TblWorkShift;
}

@section Styles {
    <link rel="stylesheet" href="~/css/home.css" />
}

<div class="home-container">
    <!-- --- SHIFT MANAGEMENT WIDGET --- -->
    <div class="shift-widget">
        <div class="shift-info">
            <h4>Ca làm việc hiện tại</h4>
            <div class="shift-status">
                @if (currentShift != null)
                {
                    <span class="status-active">🟢 Đang trong ca (Mã ca: #@currentShift.ShiftId)</span>
                    <div class="shift-stats">
                        <div class="stat-item">✅ Đã giao: <b>@ViewBag.DeliveredCount</b></div>
                        <div class="stat-item">💰 Doanh thu: <b>@string.Format("{0:N0}", ViewBag.TotalRevenue) K</b></div>
                    </div>
                }
                else
                {
                    <span class="status-inactive">⚪ Chưa bắt đầu ca làm việc</span>
                }
            </div>
        </div>
        <div class="shift-actions">
            @if (currentShift == null)
            {
                <form asp-controller="Shift" asp-action="Start" method="POST">
                    <button type="submit" class="btn-shift btn-start">🚀 BẮT ĐẦU CA</button>
                </form>
            }
            else
            {
                <form asp-controller="Shift" asp-action="End" method="POST" id="endShiftForm">
                    <button type="button" class="btn-shift btn-end" onclick="confirmEndShift()">🛑 KẾT THÚC CA</button>
                </form>
            }
        </div>
    </div>

    <div class="welcome-box">
        <h1>CHÀO MỪNG QUAY TRỞ LẠI!</h1>
        <p>Hệ thống quản lý hàng hóa & vận chuyển nội bộ</p>
        <div class="user-chip">
            <span>@fullName</span>
            <small>(@role)</small>
        </div>
    </div>

    <div class="menu-grid">
        <!-- 1. Quản lý hàng hóa -->
        <a asp-controller="Goods" asp-action="Index" class="menu-card no-decoration color-inherit">
            <div class="card-icon">📦</div>
            <h3>Quản lý hàng hóa</h3>
            <p>Nhập đơn hàng, bộ phận hàng, quản lý đơn hàng.</p>
            <button type="button" class="btn-card-action">Truy cập</button>
        </a>

        <!-- 2. Báo cáo & Thống kê -->
        <a asp-controller="Report" asp-action="Index" class="menu-card no-decoration color-inherit">
            <div class="card-icon">📊</div>
            <h3>Báo cáo & Thống kê</h3>
            <p>Xem doanh thu, số lượng đơn theo ngày/tháng.</p>
            <button type="button" class="btn-card-action">Xem báo cáo</button>
        </a>

        <!-- 3. Hệ thống quản trị -->
        @if (role == "AD")
        {
            <a asp-controller="Admin" asp-action="Index" class="menu-card admin-card no-decoration color-inherit">
                <div class="card-icon">🛡️</div>
                <h3>Hệ thống quản trị</h3>
                <p>Quản lý nhân viên, cấu hình trạm xe, bảo mật.</p>
                <button type="button" class="btn-card-action">Vào quản trị</button>
            </a>
        }
        else
        {
            <div class="menu-card disabled">
                <div class="card-icon">🔒</div>
                <h3>Hệ thống quản trị</h3>
                <p>Chức năng dành riêng cho Quản trị viên hệ thống.</p>
                <button type="button" class="btn-card-action" disabled>Bị khóa</button>
            </div>
        }
    </div>
</div>

<script>
    function confirmEndShift() {
        Swal.fire({
            title: 'Kết thúc ca làm?',
            text: "Hệ thống sẽ chốt số lượng đơn và doanh thu trong ca này của bạn!",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#d33',
            cancelButtonColor: '#3085d6',
            confirmButtonText: '🛑 Kết thúc ngay',
            cancelButtonText: 'Tiếp tục làm'
        }).then((result) => {
            if (result.isConfirmed) {
                document.getElementById('endShiftForm').submit();
            }
        })
    }
</script>
