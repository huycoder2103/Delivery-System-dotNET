@model Delivery_System.Models.TblWorkShift

@{
    var addedOrders = ViewBag.AddedOrders as List<Delivery_System.Models.TblOrder>;
    var receivedOrders = ViewBag.ReceivedOrders as List<Delivery_System.Models.TblOrder>;
    var createdTrips = ViewBag.CreatedTrips as List<Delivery_System.Models.TblTrip>;
}

<div class="modal-header-custom">
    <div class="staff-info-card-mini">
        <div class="avatar-mini">@Model.Staff.FullName.Substring(0,1).ToUpper()</div>
        <div>
            <h3 class="shift-detail-header-info">@Model.Staff.FullName</h3>
            <div class="shift-detail-meta">
                Mã ca #@Model.ShiftId | <span class="shift-detail-primary-text">@Model.StartTime.ToString("HH:mm - dd/MM")</span>
            </div>
        </div>
    </div>
    <div class="shift-detail-status-section">
        <span class="badge @(Model.Status == "ACTIVE" ? "badge-active" : "badge-ended") shift-detail-status-badge">
            @(Model.Status == "ACTIVE" ? "● Đang làm việc" : "● Ca đã kết thúc")
        </span>
        <div class="shift-detail-revenue">
            💰 @string.Format("{0:N0}", ViewBag.TotalRevenue),000 VNĐ
        </div>
    </div>
</div>

<div class="activity-tabs">
    <button class="tab-btn active" onclick="showTab('added')">📦 Đã thêm (@addedOrders.Count)</button>
    <button class="tab-btn" onclick="showTab('received')">🤝 Đã giao (@receivedOrders.Count)</button>
    <button class="tab-btn" onclick="showTab('trips')">🚛 Chuyến xe (@createdTrips.Count)</button>
</div>

<div class="modal-scroll-area">
    <!-- TAB: HÀNG ĐÃ THÊM -->
    <div id="tab-added" class="activity-content tab-content-pane active">
        <table class="table-mini">
            <thead>
                <tr>
                    <th>Mã Đơn</th>
                    <th>Tên Hàng</th>
                    <th>Trạng Thái</th>
                    <th class="table-col-right">Giờ</th>
                </tr>
            </thead>
            <tbody>
                @foreach(var o in addedOrders) {
                    <tr>
                        <td>
                            <a class=" text-decoration-none" asp-controller="Order" asp-action="List" asp-route-searchPhone="@o.OrderId" title="Tìm kiếm đơn hàng này" >
                                <strong class="order-id-added">@o.OrderId</strong>
                            </a>
                        </td>
                        <td class="table-text-bold">@o.ItemName</td>
                        <td>
                            @if (o.ShipStatus == "Đã giao") {
                                <span class="badge badge-active badge-status-small">Đã giao</span>
                            } else {
                                <span class="badge badge-info badge-status-orange">@o.ShipStatus</span>
                            }
                        </td>
                        <td class="table-col-time">@o.CreatedAt?.ToString("HH:mm")</td>
                    </tr>
                }
                @if(!addedOrders.Any()) { <tr><td colspan="4" class="empty-msg">Chưa có dữ liệu hàng hóa được thêm.</td></tr> }
            </tbody>
        </table>
    </div>

    <!-- TAB: HÀNG ĐÃ GIAO -->
    <div id="tab-received" class="activity-content tab-content-pane">
        <table class="table-mini">
            <thead>
                <tr>
                    <th>Mã Đơn</th>
                    <th>Tên Hàng</th>
                    <th>Trạm Nhận</th>
                    <th class="table-col-right">Giờ</th>
                </tr>
            </thead>
            <tbody>
                @foreach(var o in receivedOrders) {
                    <tr>
                        <td>
                            <a class=" text-decoration-none" asp-controller="Order" asp-action="List" asp-route-searchPhone="@o.OrderId" title="Tìm kiếm đơn hàng này" >
                                <strong class="order-id-received">@o.OrderId</strong>
                            </a>
                        </td>
                        <td class="table-text-bold">@o.ItemName</td>
                        <td><span class="badge badge-active badge-rounded">@o.ReceiveStation</span></td>
                        <td class="table-col-time">@o.CreatedAt?.ToString("HH:mm")</td>
                    </tr>
                }
                @if(!receivedOrders.Any()) { <tr><td colspan="4" class="empty-msg">Chưa có dữ liệu hàng hóa đã giao.</td></tr> }
            </tbody>
        </table>
    </div>

    <!-- TAB: CHUYẾN XE -->
    <div id="tab-trips" class="activity-content tab-content-pane">
        <table class="table-mini">
            <thead>
                <tr>
                    <th>Mã Chuyến</th>
                    <th>Lộ Trình</th>
                    <th>Loại</th>
                    <th class="table-col-right">Giờ</th>
                </tr>
            </thead>
            <tbody>
                @foreach(var t in createdTrips) {
                    <tr>
                        <td>
                            <a class=" text-decoration-none" asp-controller="Trip" asp-action="List" asp-route-searchTruck="@t.TripId" title="Tìm kiếm chuyến xe này" >
                                <strong class="trip-id-text">@t.TripId</strong>
                            </a>
                        </td>
                        <td class="trip-route-text">@t.Departure ➔ @t.Destination</td>
                        <td><span class="badge badge-info badge-trip-type">@t.TripType</span></td>
                        <td class="table-col-time">@t.CreatedAt?.ToString("HH:mm")</td>
                    </tr>
                }
                @if(!createdTrips.Any()) { <tr><td colspan="4" class="empty-msg">Chưa có dữ liệu chuyến xe.</td></tr> }
            </tbody>
        </table>
    </div>
</div>
