@model IEnumerable<Delivery_System.Models.TblWorkShift>

@{
    ViewData["Title"] = "Quản Lý Ca Làm Việc";
}

@section Styles {
    <link rel="stylesheet" href="~/css/shift.css?v=@DateTime.Now.Ticks">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
}

<div class="shift-wrapper">
    <div class="modern-page-header">
        <div>
            <h3>⏰ @(ViewBag.IsMyHistory == true ? "Nhật Ký Làm Việc Của Tôi" : "Quản Lý Ca Làm Việc")</h3>
            <div class="modern-page-header-meta">@(ViewBag.IsMyHistory == true ? "Xem lại các ca làm việc và hiệu suất cá nhân của bạn." : "Theo dõi thời gian hoạt động của đội ngũ nhân viên.")</div>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert-box alert-success msg-success-box">
            ✅ @TempData["SuccessMessage"]
        </div>
    }

    <main class="content-card">
        <div class="section-title">
            <h2>📜 Lịch Sử Hoạt Động</h2>
            <div class="section-title-flex">
                <span class="badge badge-info">🚀 Đang trực: @Model.Count(s => s.Status == "ACTIVE")</span>
            </div>
        </div>

        <div class="filter-bar">
            <div class="search-container">
                <i>🔍</i>
                <input type="text" id="shiftSearch" placeholder="Tìm kiếm nhân viên..." oninput="filterShifts()">
            </div>
            <select id="statusFilter" onchange="filterShifts()">
                <option value="all">🎯 Tất cả trạng thái</option>
                <option value="ACTIVE">🟢 Đang hoạt động</option>
                <option value="ENDED">⚪ Đã kết thúc</option>
            </select>
        </div>

        <div class="table-responsive">
            <table>
                <thead>
                    <tr>
                        <th>Nhân Viên</th>
                        <th>Giờ Bắt Đầu</th>
                        <th>Giờ Kết Thúc</th>
                        <th>Doanh Thu (K)</th>
                        <th>Trạng Thái</th>
                        <th class="table-header-center">Thao Tác</th>
                    </tr>
                </thead>
                <tbody id="shiftTableBody">
                    @foreach (var item in Model)
                    {
                        <tr class="shift-row" data-name="@item.Staff.FullName.ToLower()" data-status="@item.Status">
                            <td>
                                <div class="staff-avatar-wrapper">
                                    <div class="avatar-circle-small">
                                        @item.Staff.FullName.Substring(0,1).ToUpper()
                                    </div>
                                    <div>
                                        <div class="staff-name-text">@item.Staff.FullName</div>
                                        <div class="staff-id-text-mini">ID: @item.StaffId</div>
                                    </div>
                                </div>
                            </td>
                            <td class="start-time-text">@item.StartTime.ToString("dd/MM/yyyy HH:mm")</td>
                            <td class="end-time-text">@(item.EndTime?.ToString("dd/MM/yyyy HH:mm") ?? "—")</td>
                            <td>
                                    <span class="text-revenue">
                                    @string.Format("{0:N0}", item.Revenue)
                                </span>
                            </td>
                            <td>
                                <span class="badge @(item.Status == "ACTIVE" ? "badge-active" : "badge-ended")">
                                    @(item.Status == "ACTIVE" ? "● Đang trực" : "● Đã nghỉ")
                                </span>
                            </td>
                            <td class="actions-cell-center">
                                <div class="action-group actions-group-center">
                                    <button type="button" onclick="openShiftDetails(@item.ShiftId)" class="btn-s btn-s-blue">
                                        👁️ Xem chi tiết
                                    </button>
                                    
                                    @if (item.Status == "ACTIVE" && ViewBag.IsMyHistory != true)
                                    {
                                        <form asp-action="ForceEnd" method="POST" class="inline-form">
                                            <input type="hidden" name="shiftId" value="@item.ShiftId" />
                                            <button type="submit" class="btn-s btn-s-red" onclick="return confirm('Xác nhận kết thúc hộ ca này?')">
                                                🛑 Kết thúc hộ
                                            </button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </main>
</div>

<!-- MODAL CHI TIẾT CA TRỰC -->
<div id="detailsModal" class="modal">
    <div class="modal-content">
        <div id="modalBody" class="modal-body-content">
            <!-- AJAX content will load here -->
        </div>
        <div class="modal-footer">
            <button type="button" onclick="closeShiftDetails()" class="btn-close-modal">ĐÓNG CỬA SỔ</button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function filterShifts() {
            const kw = document.getElementById('shiftSearch').value.toLowerCase();
            const status = document.getElementById('statusFilter').value;
            document.querySelectorAll('.shift-row').forEach(row => {
                const name = row.getAttribute('data-name');
                const rowStatus = row.getAttribute('data-status');
                row.style.display = (name.includes(kw) && (status === 'all' || rowStatus === status)) ? '' : 'none';
            });
        }

        async function openShiftDetails(id) {
            const modal = document.getElementById('detailsModal');
            const body = document.getElementById('modalBody');
            modal.style.display = 'flex';
            document.body.style.overflow = 'hidden'; 
            
            body.innerHTML = `
                <div class="loader-container">
                    <div class="spinner"></div>
                    <div class="loader-text-info">Đang truy xuất dữ liệu...</div>
                </div>`;

            try {
                const response = await fetch(`/Shift/Details/${id}`);
                const html = await response.text();
                body.innerHTML = html;
            } catch (error) {
                body.innerHTML = `<div class="empty-msg">❌ Lỗi kết nối. Vui lòng thử lại sau.</div>`;
            }
        }

        function closeShiftDetails() {
            document.getElementById('detailsModal').style.display = 'none';
            document.body.style.overflow = 'auto';
        }

        function showTab(tabId) {
            // Ẩn tất cả
            const contents = document.querySelectorAll('.activity-content');
            const buttons = document.querySelectorAll('.tab-btn');
            
            contents.forEach(c => {
                c.style.display = 'none';
                c.classList.remove('active');
            });
            buttons.forEach(b => b.classList.remove('active'));

            // Hiện tab được chọn
            const target = document.getElementById('tab-' + tabId);
            if (target) {
                target.style.display = 'block';
                // Trigger animation
                setTimeout(() => target.classList.add('active'), 10);
            }
            event.currentTarget.classList.add('active');
        }

        window.onclick = (e) => { 
            if (e.target.id === 'detailsModal') closeShiftDetails(); 
        };
    </script>
}
