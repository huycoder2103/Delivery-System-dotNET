@model Delivery_System.Models.TblWorkShift

@{
    ViewData["Title"] = "Chi Tiết Ca Làm Việc";
    var addedOrders = ViewBag.AddedOrders as List<Delivery_System.Models.TblOrder>;
    var receivedOrders = ViewBag.ReceivedOrders as List<Delivery_System.Models.TblOrder>;
    var createdTrips = ViewBag.CreatedTrips as List<Delivery_System.Models.TblTrip>;
}

@section Styles {
    <link rel="stylesheet" href="~/css/shift.css">
    <style>
        .details-header { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 30px; }
        .staff-info-card { background: white; padding: 20px; border-radius: 12px; box-shadow: var(--shadow); display: flex; gap: 20px; align-items: center; }
        .avatar-big { width: 60px; height: 60px; background: var(--primary); color: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1.5rem; font-weight: 800; }
        
        .activity-tabs { display: flex; gap: 10px; margin-bottom: 20px; border-bottom: 2px solid #e2e8f0; padding-bottom: 10px; }
        .tab-btn { padding: 10px 20px; border-radius: 8px; border: none; background: none; cursor: pointer; font-weight: 700; color: #64748b; transition: 0.3s; }
        .tab-btn.active { background: var(--primary); color: white; }
        .tab-btn span { background: rgba(0,0,0,0.1); padding: 2px 8px; border-radius: 10px; margin-left: 5px; font-size: 0.8rem; }
        .tab-btn.active span { background: rgba(255,255,255,0.2); }

        .activity-content { display: none; animation: fadeIn 0.3s ease; }
        .activity-content.active { display: block; }
        @@keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

        .stat-badge { font-size: 0.8rem; padding: 4px 10px; border-radius: 6px; font-weight: 700; }
        .stat-add { background: #e0f2fe; color: #0369a1; }
        .stat-receive { background: #dcfce7; color: #15803d; }
        .stat-trip { background: #fef3c7; color: #92400e; }
    </style>
}

<div class="shift-wrapper">
    <div class="details-header">
        <div>
            <a asp-action="Index" style="text-decoration: none; color: var(--primary); font-weight: 700; display: flex; align-items: center; gap: 5px; margin-bottom: 10px;">
                ⬅ Quay lại danh sách
            </a>
            <div class="staff-info-card">
                <div class="avatar-big">@Model.Staff.FullName.Substring(0,1).ToUpper()</div>
                <div>
                    <h2 style="margin:0">@Model.Staff.FullName</h2>
                    <div style="color: #64748b; font-size: 0.9rem;">Mã nhân viên: <strong>@Model.StaffId</strong></div>
                </div>
            </div>
        </div>
        <div style="text-align: right;">
            <div class="badge @(Model.Status == "ACTIVE" ? "badge-active" : "badge-ended")" style="font-size: 1rem; padding: 10px 20px;">
                @(Model.Status == "ACTIVE" ? "● Đang làm việc" : "● Ca đã kết thúc")
            </div>
            <div style="margin-top: 10px; font-weight: 600; color: #64748b;">
                Bắt đầu: @Model.StartTime.ToString("HH:mm dd/MM/yyyy")
            </div>
        </div>
    </div>

    <main class="content-card">
        <div class="activity-tabs">
            <button class="tab-btn active" onclick="showTab('added')">📦 Hàng đã thêm <span>@addedOrders.Count</span></button>
            <button class="tab-btn" onclick="showTab('received')">🤝 Hàng đã giao <span>@receivedOrders.Count</span></button>
            <button class="tab-btn" onclick="showTab('trips')">🚛 Chuyến xe đã tạo <span>@createdTrips.Count</span></button>
        </div>

        <!-- TAB: HÀNG ĐÃ THÊM -->
        <div id="tab-added" class="activity-content active">
            <div class="table-responsive">
                <table>
                    <thead>
                        <tr>
                            <th>Mã Đơn</th>
                            <th>Tên Hàng</th>
                            <th>Người Gửi</th>
                            <th>Người Nhận</th>
                            <th>Trạm Gửi</th>
                            <th>Thời Gian</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach(var o in addedOrders) {
                            <tr>
                                <td><strong style="color:var(--primary)">@o.OrderId</strong></td>
                                <td>@o.ItemName</td>
                                <td>@o.SenderName</td>
                                <td>@o.ReceiverName</td>
                                <td><span class="stat-badge stat-add">@o.SendStation</span></td>
                                <td>@o.CreatedAt?.ToString("HH:mm")</td>
                            </tr>
                        }
                        @if(!addedOrders.Any()) { <tr><td colspan="6" style="text-align:center; padding: 40px; color: #94a3b8;">Không có dữ liệu hàng hóa được thêm.</td></tr> }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- TAB: HÀNG ĐÃ GIAO -->
        <div id="tab-received" class="activity-content">
            <div class="table-responsive">
                <table>
                    <thead>
                        <tr>
                            <th>Mã Đơn</th>
                            <th>Tên Hàng</th>
                            <th>Người Nhận</th>
                            <th>SĐT Nhận</th>
                            <th>Trạm Nhận</th>
                            <th>Thời Gian</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach(var o in receivedOrders) {
                            <tr>
                                <td><strong style="color:#10b981">@o.OrderId</strong></td>
                                <td>@o.ItemName</td>
                                <td>@o.ReceiverName</td>
                                <td>@o.ReceiverPhone</td>
                                <td><span class="stat-badge stat-receive">@o.ReceiveStation</span></td>
                                <td>@o.CreatedAt?.ToString("HH:mm")</td>
                            </tr>
                        }
                        @if(!receivedOrders.Any()) { <tr><td colspan="6" style="text-align:center; padding: 40px; color: #94a3b8;">Không có dữ liệu hàng hóa đã giao.</td></tr> }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- TAB: CHUYẾN XE ĐÃ TẠO -->
        <div id="tab-trips" class="activity-content">
            <div class="table-responsive">
                <table>
                    <thead>
                        <tr>
                            <th>Mã Chuyến</th>
                            <th>Xe / Tài Xế</th>
                            <th>Lộ Trình</th>
                            <th>Loại Chuyến</th>
                            <th>Thời Gian</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach(var t in createdTrips) {
                            <tr>
                                <td><strong style="color:#f59e0b">@t.TripId</strong></td>
                                <td>
                                    <div style="font-weight:700">@t.Truck.LicensePlate</div>
                                    <div style="font-size:0.75rem; color:#64748b">@t.DriverName</div>
                                </td>
                                <td>
                                    <div style="font-size:0.85rem">@t.Departure ➡ @t.Destination</div>
                                </td>
                                <td><span class="stat-badge stat-trip">@t.TripType</span></td>
                                <td>@t.CreatedAt?.ToString("HH:mm")</td>
                            </tr>
                        }
                        @if(!createdTrips.Any()) { <tr><td colspan="5" style="text-align:center; padding: 40px; color: #94a3b8;">Không có chuyến xe được tạo.</td></tr> }
                    </tbody>
                </table>
            </div>
        </div>
    </main>
</div>

@section Scripts {
    <script>
        function showTab(tabId) {
            document.querySelectorAll('.activity-content').forEach(c => c.classList.remove('active'));
            document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
            
            document.getElementById('tab-' + tabId).classList.add('active');
            event.currentTarget.classList.add('active');
        }
    </script>
}
