@model Delivery_System.Models.TblWorkShift

@{
    ViewData["Title"] = "Chi Tiết Ca Làm Việc";
    var addedOrders = ViewBag.AddedOrders as List<Delivery_System.Models.TblOrder>;
    var receivedOrders = ViewBag.ReceivedOrders as List<Delivery_System.Models.TblOrder>;
    var createdTrips = ViewBag.CreatedTrips as List<Delivery_System.Models.TblTrip>;
}

@section Styles {
    <link rel="stylesheet" href="~/css/shift.css?v=@DateTime.Now.Ticks">
    <style>
        .back-link { text-decoration: none; color: var(--primary); font-weight: 700; display: flex; align-items: center; gap: 5px; margin-bottom: 10px; }
        .staff-name { margin: 0; }
        .staff-id-info { color: #64748b; font-size: 0.9rem; }
        .header-right { text-align: right; }
        .status-badge-custom { font-size: 1rem; padding: 10px 20px; }
        .start-time-info { margin-top: 10px; font-weight: 600; color: #64748b; }
        
        .order-id-added { color: var(--primary); }
        .order-id-received { color: #10b981; }
        .trip-id-text { color: #f59e0b; }
        
        .empty-data-msg { text-align: center; padding: 40px; color: #94a3b8; }
        
        .truck-plate { font-weight: 700; }
        .driver-name-mini { font-size: 0.75rem; color: #64748b; }
        .trip-route-mini { font-size: 0.85rem; }
    </style>
}

<div class="shift-wrapper">
    <div class="details-header">
        <div>
            <a asp-action="Index" class="back-link">
                ⬅ Quay lại danh sách
            </a>
            <div class="staff-info-card">
                <div class="avatar-big">@Model.Staff.FullName.Substring(0,1).ToUpper()</div>
                <div>
                    <h2 class="staff-name">@Model.Staff.FullName</h2>
                    <div class="staff-id-info">Mã nhân viên: <strong>@Model.StaffId</strong></div>
                </div>
            </div>
        </div>
        <div class="header-right">
            <div class="badge @(Model.Status == "ACTIVE" ? "badge-active" : "badge-ended") status-badge-custom">
                @(Model.Status == "ACTIVE" ? "● Đang làm việc" : "● Ca đã kết thúc")
            </div>
            <div class="start-time-info">
                Bắt đầu: @Model.StartTime.ToString("HH:mm dd/MM/yyyy")
            </div>
        </div>
    </div>

    <main class="content-card">
        <div class="activity-tabs">
            <button class="tab-btn active" onclick="showTab('added')">📦 Hàng đã thêm <span>@addedOrders.Count</span></button>
            <button class="tab-btn" onclick="showTab('received')">🤝 Hàng đã giao <span>@receivedOrders.Count</span></button>
            <button class="tab-btn" onclick="showTab('trips')">🚛 Chuyến xe đã tạo <span>@createdTrips.Count</span></button>
        </div>

        <!-- TAB: HÀNG ĐÃ THÊM -->
        <div id="tab-added" class="activity-content active">
            <div class="table-responsive">
                <table>
                    <thead>
                        <tr>
                            <th>Mã Đơn</th>
                            <th>Tên Hàng</th>
                            <th>Người Gửi</th>
                            <th>Người Nhận</th>
                            <th>Trạm Gửi</th>
                            <th>Thời Gian</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach(var o in addedOrders) {
                            <tr>
                                <td><strong class="order-id-added">@o.OrderId</strong></td>
                                <td>@o.ItemName</td>
                                <td>@o.SenderName</td>
                                <td>@o.ReceiverName</td>
                                <td><span class="stat-badge stat-add">@o.SendStation</span></td>
                                <td>@o.CreatedAt?.ToString("HH:mm")</td>
                            </tr>
                        }
                        @if(!addedOrders.Any()) { <tr><td colspan="6" class="empty-data-msg">Không có dữ liệu hàng hóa được thêm.</td></tr> }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- TAB: HÀNG ĐÃ GIAO -->
        <div id="tab-received" class="activity-content">
            <div class="table-responsive">
                <table>
                    <thead>
                        <tr>
                            <th>Mã Đơn</th>
                            <th>Tên Hàng</th>
                            <th>Người Nhận</th>
                            <th>SĐT Nhận</th>
                            <th>Trạm Nhận</th>
                            <th>Thời Gian</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach(var o in receivedOrders) {
                            <tr>
                                <td><strong class="order-id-received">@o.OrderId</strong></td>
                                <td>@o.ItemName</td>
                                <td>@o.ReceiverName</td>
                                <td>@o.ReceiverPhone</td>
                                <td><span class="stat-badge stat-receive">@o.ReceiveStation</span></td>
                                <td>@o.CreatedAt?.ToString("HH:mm")</td>
                            </tr>
                        }
                        @if(!receivedOrders.Any()) { <tr><td colspan="6" class="empty-data-msg">Không có dữ liệu hàng hóa đã giao.</td></tr> }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- TAB: CHUYẾN XE ĐÃ TẠO -->
        <div id="tab-trips" class="activity-content">
            <div class="table-responsive">
                <table>
                    <thead>
                        <tr>
                            <th>Mã Chuyến</th>
                            <th>Xe / Tài Xế</th>
                            <th>Lộ Trình</th>
                            <th>Loại Chuyến</th>
                            <th>Thời Gian</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach(var t in createdTrips) {
                            <tr>
                                <td><strong class="trip-id-text">@t.TripId</strong></td>
                                <td>
                                    <div class="truck-plate">@t.Truck.LicensePlate</div>
                                    <div class="driver-name-mini">@t.DriverName</div>
                                </td>
                                <td>
                                    <div class="trip-route-mini">@t.Departure ➡ @t.Destination</div>
                                </td>
                                <td><span class="stat-badge stat-trip">@t.TripType</span></td>
                                <td>@t.CreatedAt?.ToString("HH:mm")</td>
                            </tr>
                        }
                        @if(!createdTrips.Any()) { <tr><td colspan="5" class="empty-data-msg">Không có chuyến xe được tạo.</td></tr> }
                    </tbody>
                </table>
            </div>
        </div>
    </main>
</div>

@section Scripts {
    <script>
        function showTab(tabId) {
            document.querySelectorAll('.activity-content').forEach(c => c.classList.remove('active'));
            document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
            
            document.getElementById('tab-' + tabId).classList.add('active');
            event.currentTarget.classList.add('active');
        }
    </script>
}
