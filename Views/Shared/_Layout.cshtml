@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor

@{
    var fullName = HttpContextAccessor.HttpContext.Session.GetString("FullName") ?? "Người dùng";
    var email = HttpContextAccessor.HttpContext.Session.GetString("Email") ?? "Chưa cập nhật email";
    var role = HttpContextAccessor.HttpContext.Session.GetString("Role");
    var initial = !string.IsNullOrEmpty(fullName) ? fullName.Substring(0, 1).ToUpper() : "U";
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Delivery System</title>
    
    <link rel="stylesheet" href="~/css/main-bundle.css" />
    
    <!-- Nạp SweetAlert2 ở đầu để các trang con dùng được ngay -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    
    @RenderSection("Styles", required: false)
</head>
<body>
    <header>
        <nav class="navbar">
            <a asp-controller="Home" asp-action="Index" class="nav-brand">
                <span class="brand-logo">🚚</span>
                <span class="company-name">Delivery System</span>
            </a>

            <div class="nav-menu-container">
                <div class="nav-indicator" id="navIndicator"></div>
                <ul class="nav-links" id="navLinks">
                    <li><a asp-controller="Home" asp-action="Index" class="@(currentController == "Home" ? "active" : "")">Trang chủ</a></li>
                    <li><a asp-controller="Goods" asp-action="Index" class="@(currentController == "Goods" ? "active" : "")">Hàng hóa</a></li>
                    <li><a asp-controller="Report" asp-action="Index" class="@(currentController == "Report" ? "active" : "")">Báo cáo</a></li>
                    @if (role == "AD")
                    {
                        <li><a asp-controller="Admin" asp-action="Index" class="@(currentController == "Admin" || currentController == "Shift" ? "active" : "")">Quản trị</a></li>
                    }
                    <li><a asp-controller="About" asp-action="Index" class="@(currentController == "About" ? "active" : "")">Hướng dẫn</a></li>
                </ul>
            </div>

            <div class="nav-user-zone" id="userZone">
                <div class="user-trigger" onclick="toggleUserDropdown(event)">
                    <div class="user-avatar-small">@initial</div>
                    <span class="user-trigger-name">@fullName</span>
                </div>

                <div class="dropdown-menu" id="userDropdown">
                    <div class="dropdown-header">
                        <span class="d-name">@fullName</span>
                        <span class="d-email">@email</span>
                    </div>
                    <div class="dropdown-body">
                        <form asp-controller="Account" asp-action="Logout" method="POST" style="margin: 0;">
                            <button type="submit" class="dropdown-item" style="width:100%; border:none; background:none; cursor:pointer; color:#e53e3e; text-align: left; display: block;">
                                🚪 Đăng xuất hệ thống
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <main role="main">
        @RenderBody()
    </main>

    <footer class="main-footer">
        <div class="footer-container">
            <div class="footer-row brand-row">
                <h2>Delivery System</h2>
                <div class="brand-detail">
                    Nền tảng quản lý logistics thế hệ mới, tích hợp công nghệ mã hóa bảo mật và điều phối thời gian thực. 
                </div>
            </div>
            <div class="footer-row links-row">
                <h3>Hệ sinh thái chức năng</h3>
                <div class="quick-links-grid">
                    <a asp-controller="Home" asp-action="Index">Trang chủ</a>
                    <a asp-controller="About" asp-action="Index">📘 Hướng dẫn</a>
                    <a asp-controller="Order" asp-action="List">📦 Quản Lý Đơn Hàng</a>
                    <a asp-controller="Trip" asp-action="List">🚛 Chuyến Xe Đi</a>
                    <a asp-controller="Trip" asp-action="ArrivalList">🏁 Chuyến Xe Đến</a>
                    <a asp-controller="Report" asp-action="Index">📊 Báo cáo</a>
                </div>
            </div>
            <div class="footer-row contact-row">
                <div class="contact-info-large">
                    <div><span class="contact-label">Kỹ thuật & Bảo mật</span><span class="contact-value">📧 jayker03212k5@gmail.com</span></div>
                    <div><span class="contact-label">Liên hệ hổ trợ</span><span class="contact-value">☎ 0366 424 978 (Hoàng Huy)</span></div>
                </div>
                <div class="dev-credit">Built by Hoang Huy</div>
            </div>
        </div>
    </footer>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    
    <script>
        const navLinks = document.querySelectorAll('.nav-links li a');
        const indicator = document.getElementById('navIndicator');
        const menuContainer = document.querySelector('.nav-menu-container');

        function moveIndicator(element) {
            if (!element) return;
            const containerPadding = 6;
            indicator.style.width = element.offsetWidth + 'px';
            indicator.style.left = (element.offsetLeft + containerPadding) + 'px';
        }

        window.addEventListener('load', () => {
            const activeLink = document.querySelector('.nav-links li a.active');
            if (activeLink) moveIndicator(activeLink);
            else moveIndicator(navLinks[0]);
        });

        navLinks.forEach(link => {
            link.addEventListener('mouseenter', (e) => moveIndicator(e.target));
        });

        menuContainer.addEventListener('mouseleave', () => {
            const currentActive = document.querySelector('.nav-links li a.active');
            if (currentActive) moveIndicator(currentActive);
        });

        function toggleUserDropdown(event) {
            event.stopPropagation();
            document.getElementById('userDropdown').classList.toggle('show');
        }

        window.onclick = function(event) {
            const dropdown = document.getElementById('userDropdown');
            if (dropdown && dropdown.classList.contains('show')) {
                if (!document.getElementById('userZone').contains(event.target)) {
                    dropdown.classList.remove('show');
                }
            }
        }
    </script>
    
    @RenderSection("Scripts", required: false)
</body>
</html>
