@using System.Security.Claims
@using Delivery_System.Helpers

@{
    var fullName = User.GetFullName();
    var email = User.FindFirst("Email")?.Value ?? "Chưa cập nhật email";
    var roleCode = User.GetRole();
    var stationName = User.GetStationName();
    var stationId = User.GetStationId();
    
    var roleName = roleCode == "AD" ? "Quản trị viên" : "Nhân viên";
    var initial = !string.IsNullOrEmpty(fullName) ? fullName.Substring(0, 1).ToUpper() : "U";
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Delivery System</title>
    
    <link rel="stylesheet" href="~/css/main-bundle.css" />
    
    <!-- Nạp SweetAlert2 ở đầu để các trang con dùng được ngay -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    
    <!-- Nạp Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    
    @RenderSection("Styles", required: false)
</head>
<body>
    <header>
        <nav class="navbar">
            <a asp-controller="Home" asp-action="Index" class="nav-brand">
                <span class="brand-logo">🚚</span>
                <span class="company-name">Delivery System</span>
            </a>

            <div class="nav-menu-container">
                <div class="nav-indicator" id="navIndicator"></div>
                <ul class="nav-links" id="navLinks">
                    <li><a asp-controller="Home" asp-action="Index" class="@(currentController == "Home" ? "active" : "")">Trang chủ</a></li>
                    <li><a asp-controller="Goods" asp-action="Index" class="@(currentController == "Goods" ? "active" : "")">Hàng hóa</a></li>
                    <li><a asp-controller="Report" asp-action="Index" class="@(currentController == "Report" ? "active" : "")">Báo cáo</a></li>
                    @if (roleCode == "AD")
                    {
                        <li><a asp-controller="Admin" asp-action="Index" class="@(currentController == "Admin" || currentController == "Shift" ? "active" : "")">Quản trị</a></li>
                    }
                    <li><a asp-controller="About" asp-action="Index" class="@(currentController == "About" ? "active" : "")">Hướng dẫn</a></li>
                </ul>
            </div>

            <div class="nav-user-zone" id="userZone">
                <!-- TÌM KIẾM NHANH (XỔ XUỐNG) -->
                <div class="nav-search-wrapper">
                    <div class="search-trigger" onclick="toggleSearchDropdown(event)">
                        <i class="bi bi-search"></i>
                    </div>
                    <div class="search-dropdown" id="searchDropdown">
                        <form asp-controller="Order" asp-action="List" method="GET" class="search-inner-form">
                            <input type="text" name="searchPhone" placeholder="Nhập mã đơn / SĐT..." class="search-inner-input" id="quickSearchInput">
                            <button type="submit" class="search-inner-btn"><i class="bi bi-search"></i> TÌM KIẾM</button>
                        </form>
                    </div>
                </div>

                <!-- NÚT 3 GẠCH (QUICK MENU) -->
                <div class="nav-quick-zone">
                    <div class="quick-trigger" onclick="toggleQuickMenu(event)">
                        ☰
                    </div>
                    <div class="quick-dropdown" id="quickDropdown">
                        <div class="quick-group-label">Vận hành nhanh</div>
                        <a asp-controller="Order" asp-action="Create" class="quick-item">
                            <span class="quick-icon">➕</span> Nhập Đơn Hàng
                        </a>
                        <a asp-controller="Order" asp-action="List" class="quick-item">
                            <span class="quick-icon">📦</span> Danh Sách Đơn
                        </a>
                        <div class="quick-group-label">Điều phối xe</div>
                        <a asp-controller="Trip" asp-action="List" class="quick-item">
                            <span class="quick-icon">🚛</span> Chuyến Xe Đi
                        </a>
                        <a asp-controller="Trip" asp-action="ArrivalList" class="quick-item">
                            <span class="quick-icon">🏁</span> Chuyến Xe Đến
                        </a>
                    </div>
                </div>

                <div class="user-trigger" onclick="toggleUserDropdown(event)">
                    <div class="user-avatar-small">@initial</div>
                    <span class="user-trigger-name">@fullName</span>
                </div>

                <div class="dropdown-menu" id="userDropdown">
                    <div class="dropdown-header">
                        <span class="d-name">@fullName</span>
                        <div class="d-info-pills">
                            <span class="d-role-pill">@roleName</span>
                            @if (!string.IsNullOrEmpty(stationName))
                            {
                                <span class="d-station-pill">📍 @stationName (@stationId)</span>
                            }
                        </div>
                        <span class="d-email">@email</span>
                    </div>
                    <div class="dropdown-body">
                        <form asp-controller="Account" asp-action="Logout" method="POST" class="m-0">
                                                    <button type="submit" class="btn-logout-dropdown">
                                                        🚪 Đăng Xuất
                                                    </button>
                                                </form>
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <main role="main">
        @RenderBody()
    </main>

    <footer class="main-footer">
        <div class="footer-container">
            <div class="footer-row brand-row">
                <h2>Delivery System</h2>
                <div class="brand-detail">
                    Nền tảng quản lý logistics thế hệ mới, tích hợp công nghệ mã hóa bảo mật và điều phối thời gian thực. 
                </div>
            </div>
            <div class="footer-row links-row">
                <h3>Hệ sinh thái chức năng</h3>
                <div class="quick-links-grid">
                    <a asp-controller="Home" asp-action="Index">Trang chủ</a>
                    <a asp-controller="About" asp-action="Index">📘 Hướng dẫn</a>
                    <a asp-controller="Order" asp-action="List">📦 Quản Lý Đơn Hàng</a>
                    <a asp-controller="Trip" asp-action="List">🚛 Chuyến Xe Đi</a>
                    <a asp-controller="Trip" asp-action="ArrivalList">🏁 Chuyến Xe Đến</a>
                    <a asp-controller="Report" asp-action="Index">📊 Báo cáo</a>
                </div>
            </div>
            <div class="footer-row contact-row">
                <div class="contact-info-large">
                    <div><span class="contact-label">Kỹ thuật & Bảo mật</span><span class="contact-value">📧 jayker03212k5@gmail.com</span></div>
                    <div><span class="contact-label">Liên hệ hổ trợ</span><span class="contact-value">☎ 0366 424 978 (Hoàng Huy)</span></div>
                </div>
                <div class="dev-credit">Built by Hoang Huy</div>
            </div>
        </div>
    </footer>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    
    <script>
        const navLinks = document.querySelectorAll('.nav-links li a');
        const indicator = document.getElementById('navIndicator');
        const menuContainer = document.querySelector('.nav-menu-container');

        function moveIndicator(element) {
            if (!element) return;
            const containerPadding = 6;
            indicator.style.width = element.offsetWidth + 'px';
            indicator.style.left = (element.offsetLeft + containerPadding) + 'px';
        }

        window.addEventListener('load', () => {
            const activeLink = document.querySelector('.nav-links li a.active');
            if (activeLink) moveIndicator(activeLink);
            else moveIndicator(navLinks[0]);
        });

        // Tự động cập nhật vị trí thanh chạy khi co giãn màn hình
        window.addEventListener('resize', () => {
            const activeLink = document.querySelector('.nav-links li a.active');
            if (activeLink) moveIndicator(activeLink);
        });

        navLinks.forEach(link => {
            link.addEventListener('mouseenter', (e) => moveIndicator(e.target));
        });

        menuContainer.addEventListener('mouseleave', () => {
            const currentActive = document.querySelector('.nav-links li a.active');
            if (currentActive) moveIndicator(currentActive);
        });

        // Cấu hình SweetAlert2 Toast toàn cục
        const Toast = Swal.mixin({
            toast: true,
            position: 'top-start', // Đổi sang góc trên bên trái
            showConfirmButton: false,
            timer: 4000,
            timerProgressBar: true,
            didOpen: (toast) => {
                toast.addEventListener('mouseenter', Swal.stopTimer)
                toast.addEventListener('mouseleave', Swal.resumeTimer)
            }
        });

        // Kiểm tra thông báo từ TempData gửi từ Backend
        document.addEventListener('DOMContentLoaded', function() {
            var successMsg = '@TempData["SuccessMessage"]';
            var errorMsg = '@TempData["ErrorMessage"]';

            if (successMsg && successMsg !== '') {
                Toast.fire({
                    icon: 'success',
                    title: successMsg
                });
            }

            if (errorMsg && errorMsg !== '') {
                Toast.fire({
                    icon: 'error',
                    title: errorMsg
                });
            }
        });

        function toggleUserDropdown(event) {
            event.stopPropagation();
            document.getElementById('quickDropdown').classList.remove('show'); // Đóng menu kia
            document.getElementById('userDropdown').classList.toggle('show');
        }

        function toggleQuickMenu(event) {
            event.stopPropagation();
            document.getElementById('userDropdown').classList.remove('show');
            document.getElementById('searchDropdown').classList.remove('show'); // Đóng search
            document.getElementById('quickDropdown').classList.toggle('show');
        }

        function toggleSearchDropdown(event) {
            event.stopPropagation();
            document.getElementById('userDropdown').classList.remove('show');
            document.getElementById('quickDropdown').classList.remove('show');
            const dropdown = document.getElementById('searchDropdown');
            dropdown.classList.toggle('show');
            if (dropdown.classList.contains('show')) {
                setTimeout(() => document.getElementById('quickSearchInput').focus(), 100);
            }
        }

        window.onclick = function(event) {
            // Đóng User Dropdown
            const userDropdown = document.getElementById('userDropdown');
            if (userDropdown && userDropdown.classList.contains('show')) {
                if (!document.getElementById('userZone').contains(event.target)) {
                    userDropdown.classList.remove('show');
                }
            }

            // Đóng Quick Menu
            const quickDropdown = document.getElementById('quickDropdown');
            if (quickDropdown && quickDropdown.classList.contains('show')) {
                if (!document.querySelector('.nav-quick-zone').contains(event.target)) {
                    quickDropdown.classList.remove('show');
                }
            }

            // Đóng Search Dropdown
            const searchDropdown = document.getElementById('searchDropdown');
            if (searchDropdown && searchDropdown.classList.contains('show')) {
                if (!document.querySelector('.nav-search-wrapper').contains(event.target)) {
                    searchDropdown.classList.remove('show');
                }
            }
        }

        function showStationInfo(name, id) {
            Swal.fire({
                title: 'Thông tin trạm',
                html: `
                    <div class="text-left p-10">
                        <p><strong>Tên trạm:</strong> ${name}</p>
                        <p><strong>Mã trạm:</strong> ${id}</p>
                    </div>
                `,
                icon: 'info',
                confirmButtonText: 'Đóng',
                confirmButtonColor: '#1a73e8'
            });
        }
    </script>
    
    @RenderSection("Scripts", required: false)
</body>
</html>
