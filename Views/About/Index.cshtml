@{
    ViewData["Title"] = "Hướng dẫn sử dụng hệ thống";
    var stationList = ViewBag.StationList as IEnumerable<Delivery_System.Models.TblStation>;
}

@section Styles {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/about.css?v=@DateTime.Now.Ticks">
}

<div class="about-inner-wrapper">
    <aside class="about-sidebar-container">
        <div class="about-sidebar-card">
            <div class="about-sidebar-title">Mục lục hướng dẫn</div>
        
            <div class="about-nav-menu-box">
                <div id="sideIndicator" class="about-nav-liquid-drop"></div>
                <nav class="about-nav-menu">
                    <a href="#intro" class="about-nav-link-item active"><i class="bi bi-rocket-takeoff"></i> Bắt đầu</a>
                    <a href="#stations" class="about-nav-link-item"><i class="bi bi-geo-alt"></i> Danh sách trạm</a>
                    <a href="#workflow" class="about-nav-link-item"><i class="bi bi-arrow-repeat"></i> Quy trình chuẩn</a>
                    <a href="#shift" class="about-nav-link-item"><i class="bi bi-clock-history"></i> Ca trực & Doanh thu</a>
                    <a href="#order" class="about-nav-link-item"><i class="bi bi-box-seam"></i> Đơn hàng & TR/CT</a>
                    <a href="#trip" class="about-nav-link-item"><i class="bi bi-truck"></i> Điều phối Chuyến</a>
                    <a href="#admin" class="about-nav-link-item"><i class="bi bi-shield-lock"></i> Quản trị Admin</a>
                </nav>
            </div>

            <a href="#" class="about-btn-top-quick" onclick="window.scrollTo({top:0, behavior:'smooth'})">
                <i class="bi bi-arrow-up-short"></i> Lên đầu trang
            </a>
        </div>
    </aside>

    <main class="about-main-content">
        <header class="about-hero-banner" id="intro">
            <h1>Cẩm nang <br>Vận hành Hệ thống</h1>
            <p>Tài liệu hướng dẫn chi tiết dành cho Nhân viên và Quản trị viên của Delivery System.</p>
        </header>

        <section class="about-section" id="stations">
            <h2 class="about-section-title"><i class="bi bi-geo-alt"></i> 01. Danh sách Trạm trực thuộc</h2>
            <div class="about-doc-card">
                <p>Mã trạm (ID) là thông tin quan trọng nhất để nhập đơn và tạo chuyến xe. Vui lòng ghi nhớ mã trạm của bạn:</p>
                <div class="about-station-grid">
                    @if (stationList != null)
                    {
                        foreach (var s in stationList)
                        {
                            <div class="about-station-item">
                                <div class="about-s-id">@s.StationId</div>
                                <div class="about-s-name-text">@s.StationName</div>
                            </div>
                        }
                    }
                </div>
            </div>
        </section>

        <section class="about-section" id="workflow">
            <h2 class="about-section-title"><i class="bi bi-arrow-repeat"></i> 02. Quy trình Vận hành Chuẩn</h2>
            <div class="about-process-grid">
                <div class="about-process-card">
                    <span class="about-step-num">Bước 01</span>
                    <div class="about-icon-box" style="background: #e0f2fe; color: #0369a1;"><i class="bi bi-play-circle"></i></div>
                    <div class="about-card-title">Vào ca làm việc</div>
                    <p class="small text-muted">Bắt buộc 🟢 <b>Bắt đầu ca</b> tại Trang chủ để kích hoạt quyền tạo đơn và chuyến xe.</p>
                </div>
                <div class="about-process-card">
                    <span class="about-step-num">Bước 02</span>
                    <div class="about-icon-box" style="background: #fef3c7; color: #b45309;"><i class="bi bi-plus-square"></i></div>
                    <div class="about-card-title">Xử lý Hàng hóa</div>
                    <p class="small text-muted">Nhập đơn hàng mới. Ghi rõ số tiền TR (Trả Rồi) hoặc CT (Còn Thiếu).</p>
                </div>
                <div class="about-process-card">
                    <span class="about-step-num">Bước 03</span>
                    <div class="about-icon-box" style="background: #dcfce7; color: #15803d;"><i class="bi bi-truck"></i></div>
                    <div class="about-card-title">Điều phối Chuyến</div>
                    <p class="small text-muted">Tạo chuyến xe (TRP). Gán đơn hàng lên xe dựa trên lộ trình khớp nhau.</p>
                </div>
                <div class="about-process-card">
                    <span class="about-step-num">Bước 04</span>
                    <div class="about-icon-box" style="background: #f3e8ff; color: #7e22ce;"><i class="bi bi-stop-circle"></i></div>
                    <div class="about-card-title">Chốt ca & Đối soát</div>
                    <p class="small text-muted">Bấm 🛑 <b>Kết thúc ca</b>. Hệ thống tự động tính tổng tiền mặt bạn cần bàn giao.</p>
                </div>
            </div>
        </section>

        <section class="about-section" id="shift">
            <h2 class="about-section-title"><i class="bi bi-clock-history"></i> 03. Quản lý Ca trực & Doanh thu</h2>
            <div class="about-doc-card">
                <p>Hệ thống sử dụng cơ chế "Chốt ca thông minh" để quản lý dòng tiền:</p>
                <div class="about-info-pills">
                    <div class="about-pill pill-active"><i class="bi bi-lightning-charge"></i> Theo dõi Thời gian thực</div>
                    <div class="about-pill pill-tr"><i class="bi bi-check2-all"></i> Tự động tính tiền TR</div>
                    <div class="about-pill pill-ct"><i class="bi bi-cash-stack"></i> Cộng dồn tiền COD khi giao</div>
                </div>
                <ul class="about-doc-list">
                    <li><b>Ca làm việc:</b> Mỗi nhân viên chỉ có 1 ca "ACTIVE" tại một thời điểm.</li>
                    <li><b>Thống kê ca:</b> Xem số đơn đã nhập, đơn đã giao và tổng doanh thu ngay tại Trang chủ.</li>
                    <li><b>Dữ liệu chốt:</b> Sau khi Kết thúc ca, các số liệu được lưu vĩnh viễn vào lịch sử để Admin đối soát, không thể chỉnh sửa.</li>
                </ul>
            </div>
        </section>

        <section class="about-section" id="order">
            <h2 class="about-section-title"><i class="bi bi-box-seam"></i> 04. Đơn hàng & Quy ước TR/CT</h2>
            <div class="about-doc-card">
                <table class="about-table-mini">
                    <thead>
                        <tr>
                            <th>Loại phí</th>
                            <th>Tên đầy đủ</th>
                            <th>Thời điểm thu tiền</th>
                            <th>Cách nhập</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td><span class="badge bg-primary">TR</span></td>
                            <td><b>Trả Rồi</b> (Prepaid)</td>
                            <td>Thu ngay khi nhận đơn tại trạm gửi.</td>
                            <td>Nhập số tiền vào ô TR.</td>
                        </tr>
                        <tr>
                            <td><span class="badge bg-warning text-dark">CT</span></td>
                            <td><b>Còn Thiếu</b> (COD)</td>
                            <td>Thu khi khách đến trạm đích lấy hàng.</td>
                            <td>Nhập số tiền vào ô CT.</td>
                        </tr>
                    </tbody>
                </table>
                <p class="mt-4 small text-muted"><i>* Lưu ý: Đơn vị tiền tệ mặc định là <b>nghìn đồng (K)</b>. Ví dụ: nhập 50 cho 50,000 VNĐ.</i></p>
                
                <h4 class="about-sub-section-header">🔍 Công cụ tìm kiếm nhanh:</h4>
                <p>Sử dụng biểu tượng 🔍 trên thanh Navbar để tra cứu đơn hàng bằng <b>Số điện thoại</b> hoặc <b>Mã đơn hàng</b> từ bất kỳ trang nào.</p>
            </div>
        </section>

        <section class="about-section" id="trip">
            <h2 class="about-section-title"><i class="bi bi-truck"></i> 05. Điều phối & Vận hành Chuyến xe</h2>
            <div class="about-doc-card">
                <div class="about-alert-premium about-alert-info-custom">
                    <i class="bi bi-info-circle-fill"></i>
                    <div><b>QUY TẮC LỘ TRÌNH:</b> Một đơn hàng chỉ có thể gán lên xe nếu <b>Trạm đi</b> và <b>Trạm đến</b> của đơn hàng khớp hoàn toàn với lộ trình của chuyến xe.</div>
                </div>
                <ul class="about-doc-list">
                    <li><b>Tạo chuyến (TRP):</b> Mã chuyến xe được tự động sinh theo định dạng <code>TRP-xxxxxx</code>.</li>
                    <li><b>Gán hàng:</b> Sử dụng nút 📦 <b>Thêm hàng</b> trong danh sách chuyến xe. Hệ thống chỉ hiển thị các đơn hàng "Chưa chuyển" phù hợp lộ trình.</li>
                    <li><b>Xác nhận đến:</b> Khi xe cập bến, nhân viên trạm đích vào mục <b>Chuyến xe đến</b> và bấm 🏁 <b>Đã đến</b>. Hệ thống tự động chuyển trạng thái toàn bộ đơn hàng trên xe.</li>
                    <li><b>Gỡ hàng:</b> Nếu gán nhầm đơn, vào 📋 <b>Xem hàng</b> -> Bấm vào <b>Mã đơn hàng</b> để gỡ đơn đó khỏi xe.</li>
                </ul>
            </div>
        </section>

        <section class="about-section" id="admin">
            <h2 class="about-section-title"><i class="bi bi-shield-lock"></i> 06. Quyền hạn Quản trị (Admin)</h2>
            <div class="about-doc-card">
                <p>Tài khoản Quản trị (AD) có các đặc quyền cao cấp để xử lý sự cố:</p>
                <div class="about-process-grid">
                    <div class="about-process-card" style="border-left: 4px solid var(--about-danger);">
                        <div class="about-card-title">Kết thúc ca hộ</div>
                        <p class="small text-muted">Admin có thể đóng ca cho nhân viên tại Tab Hoạt động nếu họ quên bấm kết thúc khi hết ca.</p>
                    </div>
                    <div class="about-process-card" style="border-left: 4px solid var(--about-indigo);">
                        <div class="about-card-title">Báo cáo Tổng hợp</div>
                        <p class="small text-muted">Xem biểu đồ doanh thu toàn hệ thống, doanh thu theo trạm và chi tiết từng ca làm việc.</p>
                    </div>
                    <div class="about-process-card" style="border-left: 4px solid var(--about-success);">
                        <div class="about-card-title">Quản lý Tài nguyên</div>
                        <p class="small text-muted">Cấu hình Danh sách Trạm, Xe tải, Tài xế và phân quyền Tài khoản nhân viên.</p>
                    </div>
                </div>
            </div>
        </section>

        <footer class="about-footer">
            &copy; @DateTime.Now.Year Delivery System - Nền tảng Logistics Thông minh. <br>
            Phiên bản v2.0 | Phát triển bởi Hoang Huy
        </footer>
    </main>
</div>

@section Scripts {
    <script>
        const drop = document.getElementById('sideIndicator');
        const links = document.querySelectorAll('.about-nav-link-item');
        const sections = document.querySelectorAll('.about-section, .about-hero-banner');

        function updateDrop(activeLink) {
            if (activeLink) {
                drop.style.opacity = '1';
                drop.style.top = (activeLink.offsetTop + 5) + 'px';
                drop.style.height = activeLink.offsetHeight + 'px';
            }
        }

        links.forEach(link => {
            link.addEventListener('click', function(e) {
                e.preventDefault();
                const targetId = this.getAttribute('href');
                const targetElement = document.querySelector(targetId);
                
                if (targetElement) {
                    const offset = 120; 
                    const elementPosition = targetElement.getBoundingClientRect().top;
                    const offsetPosition = elementPosition + window.pageYOffset - offset;

                    window.scrollTo({
                        top: offsetPosition,
                        behavior: 'smooth'
                    });
                }
            });
        });

        window.addEventListener('scroll', () => {
            let current = '';
            sections.forEach(section => {
                const sectionTop = section.offsetTop;
                if (window.pageYOffset >= (sectionTop - 150)) {
                    current = section.getAttribute('id');
                }
            });

            links.forEach(link => {
                link.classList.remove('active');
                if (link.getAttribute('href') === '#' + current) {
                    link.classList.add('active');
                    updateDrop(link);
                }
            });
        });

        window.addEventListener('load', () => {
            const activeLink = document.querySelector('.about-nav-link-item.active');
            updateDrop(activeLink);
        });
    </script>
}
