@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor

@{
    ViewData["Title"] = "Cẩm nang Vận hành - Smart Layout";
}

@section Styles {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/about.css?v=@DateTime.Now.Ticks">
}

<div class="docs-inner-wrapper">
    <!-- SIDENAV (SMART STICKY) -->
    <aside class="docs-sidebar-container">
        <div class="docs-sidebar-card">
            <div class="sidebar-title">Hướng dẫn nhanh</div>
            
            <div class="nav-menu-box">
                <!-- GIỌT NƯỚC -->
                <div id="sideIndicator" class="nav-liquid-drop"></div>
                
                <nav class="nav-menu">
                    <a href="#intro" class="nav-link-item active"><i class="bi bi-compass"></i> Giới thiệu</a>
                    <a href="#payment" class="nav-link-item"><i class="bi bi-wallet2"></i> Quy ước TR & CT</a>
                    <a href="#shift" class="nav-link-item"><i class="bi bi-clock-history"></i> Quy trình Ca trực</a>
                    <a href="#order" class="nav-link-item"><i class="bi bi-box-seam"></i> Nhập hàng gửi</a>
                    <a href="#trip" class="nav-link-item"><i class="bi bi-truck"></i> Điều phối Chuyến</a>
                    <a href="#arrival" class="nav-link-item"><i class="bi bi-flag"></i> Nhận hàng đến</a>
                    <a href="#history" class="nav-link-item"><i class="bi bi-journal-text"></i> Xem Nhật ký</a>
                </nav>
            </div>

            <a href="#" class="btn-top-quick" onclick="window.scrollTo({top:0, behavior:'smooth'})">
                <i class="bi bi-arrow-up-short"></i> Lên đầu trang
            </a>
        </div>
    </aside>

    <!-- MAIN CONTENT -->
    <main class="docs-main-content">
        <header class="hero-banner" id="intro">
            <h1>Cẩm nang <br>Nhân viên</h1>
            <p>Quy trình vận hành chuẩn cho hệ thống quản lý trạm.</p>
        </header>

        <!-- 01. QUY ƯỚC -->
        <section id="payment">
            <h2 class="section-title"><i class="bi bi-currency-dollar"></i> 01. Quy ước TR & CT</h2>
            <div class="doc-card">
                <div class="alert-premium">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                    <div><b>QUY ĐỊNH THANH TOÁN:</b> </div>
                </div>
                
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
                    
                    <div style="background: #f0fff4; padding: 25px; border-radius: 16px; border: 1px solid #c6f6d5;">
                        <span class="badge-step" style="background:#10b981">Cột TR</span>
                        <h4>Người gửi đã Trả Rồi</h4>
                        <p style="font-size: 0.85rem; opacity: 0.8;">Người Gửi sẽ thanh toán tiền trước khi giao.</p>
                    </div>
                    <div style="background: #fffaf0; padding: 25px; border-radius: 16px; border: 1px solid #feebc8;">
                        <span class="badge-step" style="background:#f59e0b">Cột CT</span>
                        <h4>Người gửi Chưa Trả</h4>
                        <p style="font-size: 0.85rem; opacity: 0.8;">Người Nhận thanh toán khi nhận hàng.</p>
                    </div>
                </div>
                <p style="margin-top: 25px;"><b>Cách nhập:</b> Chỉ nhập phần số nghìn. Ví dụ: <kbd>100</kbd> = 100.000 VNĐ.</p>
            </div>
        </section>

        <!-- 02. CA TRỰC -->
        <section id="shift">
            <h2 class="section-title"><i class="bi bi-clock-history"></i> 02. Quy trình Ca làm việc</h2>
            <div class="doc-card">
                <span class="badge-step">Bước 1</span>
                <h4>Bắt đầu ca làm việc</h4>
                <p>Ngay sau khi đăng nhập, tại Trang chủ, nhấn nút 🟢 <b>Bắt đầu ca</b> để hệ thống ghi nhận phiên làm việc cá nhân của bạn.</p>
            </div>
            <div class="doc-card">
                <span class="badge-step">Bước 2</span>
                <h4>Kết thúc ca làm việc</h4>
                <p>Trước khi ra về, nhấn nút 🛑 <b>Kết thúc ca</b> tại trang Báo cáo để hệ thống chốt số liệu và tổng hợp doanh thu trong ngày.</p>
            </div>
        </section>

        <!-- 03. NHẬP ĐƠN -->
        <section id="order">
            <h2 class="section-title"><i class="bi bi-box-seam"></i> 03. Nghiệp vụ Nhập hàng gửi</h2>
            <div class="doc-card">
                <p>Hướng dẫn tạo đơn hàng chuẩn:</p>
                <ul style="padding-left: 20px; line-height: 2;">
                    <li>Truy cập menu <b>Hàng hóa</b> -> <b>Nhập hàng gửi</b>.</li>
                    <li>Nhập đầy đủ Họ tên & SĐT của người gửi và nhận.</li>
                    <li>Lựa chọn chính xác <b>Trạm nhận</b> (Nơi hàng sẽ đến).</li>
                    <li>Nhập tiền cước vào ô <b>Tr</b> hoặc <b>Ct</b> (Chưa trả).</li>
                </ul>
            </div>
        </section>

        <!-- 04. ĐIỀU PHỐI -->
        <section id="trip">
            <h2 class="section-title"><i class="bi bi-truck"></i> 04. Điều phối Chuyến xe</h2>
            <div class="doc-card">
                <h4 style="color: var(--sys-primary);">Giai đoạn A: Tạo Chuyến</h4>
                <p>Vào menu <b>Chuyến xe</b> -> <b>Thêm chuyến mới</b>. Chọn Xe và trạm đến.</p>
                <h4 style="color: var(--sys-primary); margin-top: 20px;">Giai đoạn B: Gán hàng</h4>
                <p>Nhấn 🚛 <b>Gán hàng</b>, tích chọn các đơn hàng rồi nhấn xác nhận để đưa hàng lên xe.</p>
            </div>
        </section>

        <!-- 05. XE ĐẾN -->
        <section id="arrival">
            <h2 class="section-title"><i class="bi bi-flag"></i> 05. Quy trình Nhận hàng đến</h2>
            <div class="doc-card">
                <ol style="padding-left: 20px; line-height: 2;">
                    <li>Vào menu <b>Chuyến xe</b> -> <b>Danh sách xe đến</b>.</li>
                    <li>Xác định đúng mã chuyến xe vừa cập bến.</li>
                    <li>Nhấn nút 🏁 <b>Đã đến</b> để đưa hàng vào kho.</li>
                </ol>
            </div>
        </section>

        <!-- 06. NHẬT KÝ -->
        <section id="history">
            <h2 class="section-title"><i class="bi bi-journal-text"></i> 06. Xem lại Nhật ký làm việc</h2>
            <div class="doc-card">
                <p>Kiểm tra lại toàn bộ lịch sử thao tác tại tab 📜 <b>Nhật ký làm việc</b> trong trang Báo cáo. Nhấn vào <b>Chi tiết</b> để xem danh sách hàng hóa mình đã xử lý.</p>
            </div>
        </section>

        <footer style="margin-top: 50px; padding-top: 30px; border-top: 1px solid var(--sys-border); text-align: center; color: var(--sys-muted); font-size: 0.85rem;">
            &copy; @DateTime.Now.Year Delivery Operation Framework. Smart & Synced Layout.
        </footer>
    </main>
</div>

@section Scripts {
    <script>
        const drop = document.getElementById('sideIndicator');
        const links = document.querySelectorAll('.nav-link-item');
        const sections = document.querySelectorAll('section, header');

        function updateDrop(activeLink) {
            if (activeLink) {
                drop.style.opacity = '1';
                drop.style.top = (activeLink.offsetTop + 5) + 'px';
                drop.style.height = activeLink.offsetHeight + 'px';
            }
        }

        links.forEach(link => {
            link.addEventListener('click', function(e) {
                e.preventDefault();
                const targetId = this.getAttribute('href');
                const targetElement = document.querySelector(targetId);
                
                if (targetElement) {
                    const offset = 130; 
                    const elementPosition = targetElement.getBoundingClientRect().top;
                    const offsetPosition = elementPosition + window.pageYOffset - offset;

                    window.scrollTo({
                        top: offsetPosition,
                        behavior: 'smooth'
                    });
                }
            });
        });

        window.addEventListener('scroll', () => {
            let current = '';
            sections.forEach(section => {
                const sectionTop = section.offsetTop;
                if (window.pageYOffset >= (sectionTop - 160)) {
                    current = section.getAttribute('id');
                }
            });

            links.forEach(link => {
                link.classList.remove('active');
                if (link.getAttribute('href') === '#' + current) {
                    link.classList.add('active');
                    updateDrop(link);
                }
            });
        });

        window.addEventListener('load', () => {
            const activeLink = document.querySelector('.nav-link-item.active');
            updateDrop(activeLink);
        });
    </script>
}
