@model IEnumerable<Delivery_System.Models.VwTripList>

@{
    ViewData["Title"] = "Danh Sách Chuyến Xe Đi";
    var stationList = ViewBag.StationList as IEnumerable<Delivery_System.Models.TblStation>;
}

@section Styles {
    <link rel="stylesheet" href="~/css/list_trip.css" />
    <style>
        .sticky-filter-bar {
            position: sticky;
            top: 155px;
            z-index: 800;
            background: rgba(255, 255, 255, 0.98) !important;
            backdrop-filter: blur(10px);
            border: 2px solid #1a73e8;
            margin-top: -10px;
            border-radius: 15px !important;
            padding: 15px 20px !important;
            box-shadow: 0 8px 20px rgba(0,0,0,0.1);
        }
        .loading-overlay { opacity: 0.5; pointer-events: none; transition: opacity 0.2s; }
    </style>
}

<div style="max-width: 1550px; margin: 20px auto; padding: 0 20px;">
    
    <div class="modern-page-header" style="background: linear-gradient(135deg, #1a73e8, #0d47a1);">
        <div>
            <h3>📤 DANH SÁCH CHUYẾN XE ĐI</h3>
            <div id="tripCount" style="font-size: 0.85rem; opacity: 0.8; margin-top: 4px;">Tổng: @(Model?.Count() ?? 0) chuyến</div>
        </div>
        
        <div style="display: flex; gap: 10px;">
            <a asp-controller="Order" asp-action="List" class="btn-modern" style="background: rgba(255,255,255,0.2); color: white; border: 1px solid rgba(255,255,255,0.3); text-decoration: none;">
                📦 Quản Lý Đơn Hàng
            </a>
            <a asp-controller="Trip" asp-action="ArrivalList" class="btn-modern" style="background: rgba(255,255,255,0.2); color: white; border: 1px solid rgba(255,255,255,0.3); text-decoration: none;">
                📥 Chuyến Xe Đến
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert-success">✅ @TempData["SuccessMessage"]</div>
    }

    <div class="modern-card sticky-filter-bar">
        <div style="display:flex; gap:10px; flex-wrap: wrap; align-items: center;">
            <select id="filterDeparture" style="padding: 8px; border-radius: 8px; border: 1px solid #ddd;">
                <option value="">-- Từ Trạm (Đi) --</option>
                @if (stationList != null)
                {
                    foreach (var s in stationList)
                    {
                        <option value="@s.StationName">@s.StationName</option>
                    }
                }
            </select>

            <select id="filterDestination" style="padding: 8px; border-radius: 8px; border: 1px solid #ddd;">
                <option value="">-- Đến Trạm (Dừng) --</option>
                @if (stationList != null)
                {
                    foreach (var s in stationList)
                    {
                        <option value="@s.StationName">@s.StationName</option>
                    }
                }
            </select>

            <div style="position: relative;">
                <input type="text" id="filterTruck" placeholder="Tìm biển số..." 
                       value="@ViewBag.SearchTruck" style="width: 200px; padding: 8px 40px 8px 12px; border-radius: 8px; border: 1px solid #ddd;">
                <span style="position: absolute; right: 12px; top: 50%; transform: translateY(-50%); color: #aaa;">🔍</span>
            </div>

            <button onclick="resetFilters()" class="btn-modern btn-secondary-modern">🔄 Làm mới</button>
            
            <a asp-action="Create" class="btn-modern btn-success-modern" style="text-decoration:none;">
                ➕ Thêm Chuyến Xe
            </a>
        </div>
    </div>

    <div class="modern-card" style="padding: 0; overflow-x: auto;">
        <table class="modern-table" id="tripTable">
            <thead>
                <tr>
                    <th>Mã Chuyến</th>
                    <th>Trạm Đi</th>
                    <th>Trạm Đến</th>
                    <th>Biển Số Xe</th>
                    <th>Giờ Đi</th>
                    <th>Tài Xế</th>
                    <th>Trạng Thái</th>
                    <th>NV Tạo</th>
                    <th>Thời Gian Tạo</th>
                    <th>Thao Tác</th>
                </tr>
            </thead>
            <tbody id="tripTableBody">
                <partial name="_TripTableBody" model="Model" />
            </tbody>
        </table>
    </div>

    <div style="margin-top: 20px;">
        <a asp-controller="Order" asp-action="List" class="btn-back" style="text-decoration: none;">⬅ Quay lại DS Đơn Hàng</a>
    </div>
</div>

@section Scripts {
    <script>
        let searchTimeout;

        document.getElementById('filterDeparture').addEventListener('change', triggerSearch);
        document.getElementById('filterDestination').addEventListener('change', triggerSearch);
        document.getElementById('filterTruck').addEventListener('input', function() {
            clearTimeout(searchTimeout);
            searchTimeout = setTimeout(triggerSearch, 300);
        });

        function triggerSearch() {
            const departure = document.getElementById('filterDeparture').value;
            const destination = document.getElementById('filterDestination').value;
            const truck = document.getElementById('filterTruck').value;

            const tableBody = document.getElementById('tripTableBody');
            const tableContainer = document.getElementById('tripTable');
            tableContainer.classList.add('loading-overlay');

            const url = `@Url.Action("List", "Trip")?departureFilter=${encodeURIComponent(departure)}&destinationFilter=${encodeURIComponent(destination)}&searchTruck=${encodeURIComponent(truck)}`;

            fetch(url, { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
            .then(response => response.text())
            .then(html => {
                tableBody.innerHTML = html;
                tableContainer.classList.remove('loading-overlay');
                const rowCount = tableBody.querySelectorAll('tr:not(:has(.no-data-msg))').length;
                document.getElementById('tripCount').innerText = `Tổng: ${rowCount} chuyến`;
            })
            .catch(err => {
                console.error('Error:', err);
                tableContainer.classList.remove('loading-overlay');
            });
        }

        function resetFilters() {
            document.getElementById('filterDeparture').value = '';
            document.getElementById('filterDestination').value = '';
            document.getElementById('filterTruck').value = '';
            triggerSearch();
        }
    </script>
}
