@model IEnumerable<Delivery_System.Models.VwTripList>

@{
    ViewData["Title"] = "Danh Sách Chuyến Xe Đi";
    var stationList = ViewBag.StationList as IEnumerable<Delivery_System.Models.TblStation>;
}

@section Styles {
    <link rel="stylesheet" href="~/css/list_trip.css" />
}

<div style="max-width: 1550px; margin: 20px auto; padding: 0 20px;">
    
    <div class="modern-page-header">
        <div>
            <h3>🚚 DANH SÁCH CHUYẾN XE ĐI</h3>
            <div style="font-size: 0.85rem; opacity: 0.8; margin-top: 4px;">Tổng: @(Model?.Count() ?? 0) chuyến</div>
        </div>
        
        <div style="display: flex; gap: 10px;">
            <a asp-controller="Order" asp-action="List" class="btn-modern" style="background: rgba(255,255,255,0.2); color: white; border: 1px solid rgba(255,255,255,0.3); text-decoration: none;">
                📦 Quản Lý Đơn Hàng
            </a>
            <a asp-controller="Trip" asp-action="ArrivalList" class="btn-modern" style="background: rgba(255,255,255,0.2); color: white; border: 1px solid rgba(255,255,255,0.3); text-decoration: none;">
                📥 Chuyến Xe Đến
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert-success">✅ @TempData["SuccessMessage"]</div>
    }

    <div class="modern-card">
        <div style="display: flex; flex-direction: column; gap: 15px;">
            <form asp-action="List" method="GET" style="display:flex; gap:10px; flex-wrap: wrap; align-items: center;">
                <select name="departureFilter" style="padding: 8px; border-radius: 8px; border: 1px solid #ddd;">
                    <option value="">-- Từ Trạm (Đi) --</option>
                    @if (stationList != null)
                    {
                        foreach (var s in stationList)
                        {
                            <option value="@s.StationName">@s.StationName</option>
                        }
                    }
                </select>

                <select name="destinationFilter" style="padding: 8px; border-radius: 8px; border: 1px solid #ddd;">
                    <option value="">-- Đến Trạm (Dừng) --</option>
                    @if (stationList != null)
                    {
                        foreach (var s in stationList)
                        {
                            <option value="@s.StationName">@s.StationName</option>
                        }
                    }
                </select>

                <input type="date" name="dateFilter" style="padding: 8px; border-radius: 8px; border: 1px solid #ddd;">
                <input type="submit" value="🔍 Lọc Dữ Liệu" class="btn-modern btn-primary-modern">
                <a asp-action="Create" class="btn-modern btn-success-modern" style="text-decoration: none; padding-top: 10px;">➕ Thêm Chuyến Mới</a>
            </form>
            
            <form asp-action="List" method="GET" style="display:flex; gap:10px; align-items: center;">
                <input type="text" name="searchTruck" placeholder="Nhập biển số xe cần tìm..." 
                       value="@ViewBag.SearchTruck" style="min-width:280px; padding: 8px; border-radius: 8px; border: 1px solid #ddd;">
                <input type="submit" value="🔎 Tìm Xe" class="btn-modern btn-primary-modern">
                <a asp-action="List" class="btn-modern btn-secondary-modern" style="text-decoration: none; padding-top: 10px;">🔄 Làm mới</a>
            </form>
        </div>
    </div>

    <div class="modern-card" style="padding: 0; overflow: hidden;">
        <table class="modern-table">
            <thead>
                <tr>
                    <th>Mã Chuyến</th>
                    <th>Trạm Đi</th>
                    <th>Trạm Đến</th>
                    <th>Biển Số Xe</th>
                    <th>Giờ Đi</th>
                    <th>Tài Xế</th>
                    <th>Trạng Thái</th>
                    <th>NV Tạo</th>
                    <th>Thời Gian Tạo</th>
                    <th>Thao Tác</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var t in Model)
                    {
                        <tr>
                            <td><strong style="color: #1a73e8;">@t.TripId</strong></td>
                            <td class="td-departure" style="color: red; font-weight: 500;">@t.Departure</td>
                            <td class="td-destination" style="color: #219150;font-weight: 500;">@t.Destination</td>
                            <td class="td-truck">@t.LicensePlate</td>
                            <td class="td-time">@t.DepartureTime</td>
                            <td>@t.DriverName</td>
                            <td>
                                @if (t.Status == "Đang đi")
                                {
                                    <span class="badge-status-m badge-going">🚛 Đang đi</span>
                                }
                                else
                                {
                                    <span class="badge-status-m badge-arrived">🏁 Đã cập bến</span>
                                }
                            </td>
                            <td>@t.StaffCreatedName</td>
                            <td class="td-created-at">@t.CreatedAt?.ToString("dd/MM/yyyy HH:mm")</td>
                            <td style="min-width: 130px;">
                                <div class="action-btns-grid">
                                    @if (t.Status == "Đang đi")
                                    {
                                        <a asp-action="AssignGoods" asp-route-id="@t.TripId" class="btn-action-trip btn-assign-goods" style="text-decoration: none;">📦 Thêm hàng</a>
                                    }
                                    <a asp-action="ViewGoods" asp-route-id="@t.TripId" class="btn-action-trip" style="text-decoration: none;">📋 Xem hàng hóa</a>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="10" style="padding: 50px; color: #999; text-align: center;">📭 Chưa có chuyến xe nào xuất phát.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div style="margin-top: 20px;">
        <a asp-controller="Order" asp-action="List" class="btn-back" style="text-decoration: none; display: inline-block;">⬅ Quay lại DS Đơn Hàng</a>
    </div>
</div>
