@model IEnumerable<Delivery_System.Models.VwTripList>

<style>
    /* CSS đồng bộ cho bảng chuyến xe */
    .col-route { min-width: 200px; width: 200px; text-align: center; }
    
    .route-container {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        font-weight: 500;
        font-size: 14px;
    }

    .station-send { color: #1a73e8; }
    .station-receive { color: #d93025; }
    .route-arrow { color: #ccc; }

    .trip-id-text { color: #1a73e8; font-size: 13px; font-weight: 500; }

    /* Style cho các nút action của chuyến xe */
    .action-btns-grid { display: flex; flex-direction: column; gap: 5px; align-items: center; }
    .btn-action-trip { 
        display: inline-block; text-align: center; text-decoration: none;
        padding: 8px 10px; border-radius: 8px; font-weight: 700; cursor: pointer; 
        width: 110px; font-size: 12px; border: none; transition: all 0.2s;
    }
    .btn-action-trip:hover { transform: translateY(-2px); box-shadow: 0 4px 8px rgba(0,0,0,0.1); }
    
    .btn-status-arrived { background: #e6f4ea; color: #1e8e3e; width:130px}
    .btn-status-assign { background: #e6f4ea; color: #1e8e3e; }
    .btn-status-view { background: #e8f0fe; color: #1a73e8; }
</style>

@if (Model != null && Model.Any())
{
    foreach (var t in Model)
    {
        <tr>
            <td><span class="trip-id-text">@t.TripId</span></td>
            <td class="col-route">
                <div class="route-container">
                    <span class="station-send">@t.Departure</span>
                    <span class="route-arrow">➔</span>
                    <span class="station-receive">@t.Destination</span>
                </div>
            </td>
            <td style="font-weight: 600;">@t.LicensePlate</td>
            <td>@t.DepartureTime</td>
            <td>@t.DriverName</td>
            <td>
                @if (t.Status == "Đang đi")
                {
                    <span class="badge-status-m badge-going">🚛 Đang đi</span>
                }
                else
                {
                    <span class="badge-status-m badge-arrived">🏁 Đã cập bến</span>
                }
            </td>
            <td style="font-weight: 600;">@t.StaffCreated</td>
            <td style="font-size: 1rem;">@t.CreatedAt?.ToString("dd/MM/yyyy HH:mm")</td>
            <td style="min-width: 130px;">
                <div class="action-btns-grid">
                    @{
                        var orderCounts = ViewBag.OrderCounts as Dictionary<string, int>;
                        int count = (orderCounts != null && orderCounts.ContainsKey(t.TripId)) ? orderCounts[t.TripId] : 0;
                    }
                    
                    @* Nút xác nhận đến (Dùng SweetAlert2) *@
                    @if (ViewBag.IsArrivalPage == true && t.Status == "Đang đi")
                    {
                        <button type="button" class="btn-action-trip btn-status-arrived"
                                onclick="confirmArrive('@t.TripId')">🏁 Đã đến</button>
                        
                        <form id="arriveForm-@t.TripId" asp-action="Arrive" method="POST" style="display:none;">
                            <input type="hidden" name="id" value="@t.TripId" />
                        </form>
                    }

                    @if (t.Status == "Đang đi" && ViewBag.IsArrivalPage != true)
                    {
                        <a asp-action="AssignGoods" asp-route-id="@t.TripId" class="btn-action-trip btn-status-assign">📦 Thêm hàng</a>
                    }
                    <a asp-action="ViewGoods" asp-route-id="@t.TripId" class="btn-action-trip btn-status-view">
                        📋 Xem hàng (@count)
                    </a>
                </div>
            </td>
        </tr>
    }
}
else
{
    <tr>
        <td colspan="10" style="padding: 50px; color: #999; text-align: center;">📭 Không tìm thấy chuyến xe nào phù hợp!</td>
    </tr>
}
