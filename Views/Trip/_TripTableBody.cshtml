@model IEnumerable<Delivery_System.Models.VwTripList>


@if (Model != null && Model.Any())
{
    var stationList = ViewBag.StationList as IEnumerable<Delivery_System.Models.TblStation>;
    var stationDict = stationList?.ToDictionary(s => s.StationName, s => s.StationId.ToString());
    var currentPage = (int)(ViewBag.CurrentPage ?? 1);
    var pageSize = 10;
    var index = (currentPage - 1) * pageSize + 1;

    foreach (var t in Model)
    {
        <tr>
            <td>@index</td>
            <td><span class="tr-id-text">@t.TripId</span></td>
            <td class="tr-col-route">
                <div class="tr-route-box">
                    @{
                        var depID = (stationDict != null && t.Departure != null && stationDict.ContainsKey(t.Departure) ? stationDict[t.Departure] : t.Departure);
                        var destID = (stationDict != null && t.Destination != null && stationDict.ContainsKey(t.Destination) ? stationDict[t.Destination] : t.Destination);
                    }
                    <span class="tr-station-send" onclick="showStationInfo('@t.Departure', '@depID')">@depID</span>
                    <span class="tr-route-arrow">➔</span>
                    <span class="tr-station-receive" onclick="showStationInfo('@t.Destination', '@destID')">@destID</span>
                </div>
            </td>
            <td class="tr-col-plate-bold">@t.LicensePlate</td>
            <td>@t.DepartureTime</td>
            <td>@t.DriverName</td>
            <td>
                @if (t.Status == "Đang đi")
                {
                    <span class="tr-badge tr-badge-going">Đang đi</span>
                }
                else
                {
                    <span class="tr-badge tr-badge-arrived">Đã cập bến</span>
                }
            </td>
            @* HIỂN THỊ MÃ NHÂN VIÊN TẠO *@
            <td class="tr-col-staff"><strong>@t.StaffCreated</strong></td>
            <td>@t.CreatedAt?.ToString("dd/MM HH:mm")</td>

            @if (ViewBag.IsArrivalPage == true)
            {
                <td>
                    @if (t.Notes != null && t.Notes.StartsWith("[ARRIVED]"))
                    {
                        var parts = t.Notes.Replace("[ARRIVED] ", "").Split('|');
                        @* HIỂN THỊ MÃ NHÂN VIÊN TIẾP NHẬN *@
                        <div class="tr-id-text">@parts[0].Trim()</div>
                        <div>@(parts.Length > 1 ? parts[1].Trim() : "")</div>
                    }
                    else
                    {
                        <span class="text-muted">—</span>
                    }
                </td>
            }

            <td class="tr-col-act">
                <div class="tr-action-grid">
                    @{
                        var orderCounts = ViewBag.OrderCounts as Dictionary<string, int>;
                        int count = (orderCounts != null && orderCounts.ContainsKey(t.TripId)) ? orderCounts[t.TripId] : 0;
                    }
                    
                    @* Nút xác nhận đến (Dùng SweetAlert2) *@
                    @if (ViewBag.IsArrivalPage == true && t.Status == "Đang đi")
                    {
                        <button type="button" class="tr-btn-s tr-btn-s-arrived" onclick="confirmArrive('@t.TripId')"> <i class="bi bi-check-circle"></i> Đã đến</button>
                        
                        <form id="arriveForm-@t.TripId" asp-action="Arrive" method="POST" class="hidden-form">
                            <input type="hidden" name="id" value="@t.TripId" />
                        </form>
                    }

                    @if (t.Status == "Đang đi" && ViewBag.IsArrivalPage != true)
                    {
                        <a asp-action="AssignGoods" asp-route-id="@t.TripId" class="tr-btn-s tr-btn-s-assign"><i class="bi bi-box-seam"></i> Thêm hàng</a>
                    }
                    <a asp-action="ViewGoods" asp-route-id="@t.TripId" class="tr-btn-s tr-btn-s-view"> <i class="bi bi-card-list"></i>
                        Xem hàng (@count)
                    </a>
                </div>
            </td>
        </tr>
        index++;
    }
}
else
{
    <tr>
        <td colspan="11" class="tr-no-data">📭 Không tìm thấy chuyến xe nào phù hợp!</td>
    </tr>
}

<!-- Hidden data for AJAX Dashboard Update -->
<input type="hidden" id="ajaxCountDeparting" value="@ViewBag.CountDeparting" />
<input type="hidden" id="ajaxCountArrived" value="@ViewBag.CountArrived" />
<input type="hidden" id="ajaxCountAll" value="@ViewBag.CountAll" />
<input type="hidden" id="ajaxTotalPages" value="@ViewBag.TotalPages" />

