@model IEnumerable<Delivery_System.Models.TblOrder>

@{
    ViewData["Title"] = "Danh Sách Hàng Trên Xe";
    var trip = ViewBag.Trip as Delivery_System.Models.VwTripList;
    var stations = ViewBag.StationList as IEnumerable<Delivery_System.Models.TblStation> ?? new List<Delivery_System.Models.TblStation>();
}

@section Styles {
    <link rel="stylesheet" href="~/css/view_goods.css?v=@DateTime.Now.Ticks">
}

<div class="page-wrap">
    <div class="hdr">
        <h3>📋 DANH SÁCH HÀNG TRÊN CHUYẾN XE</h3>
        @if (trip != null)
        {
            <div class="meta">
                <span class="badge">Chuyến: @trip.TripId</span>
                <span class="badge">Lộ trình: @trip.RouteInfo</span>
                <span class="badge">Biển số: @trip.LicensePlate</span>
            </div>
        }
    </div>

    <div class="body">
        @if (Model != null && Model.Any())
        {
            <table>
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Mã Đơn</th>
                        <th>Tên Hàng</th>
                        <th>Người Gửi</th>
                        <th>Người Nhận</th>
                        <th>Trạm</th>
                        <th>TR</th>
                        <th>CT</th>
                    </tr>
                </thead>
                <tbody>
                    @{ int i = 1; }
                    @foreach (var o in Model)
                    {
                        var sendStationId = stations.FirstOrDefault(s => s.StationName == o.SendStation)?.StationId;
                        var receiveStationId = stations.FirstOrDefault(s => s.StationName == o.ReceiveStation)?.StationId;
                        
                        <tr>
                            <td>@(i++)</td>
                            <td>
                                @if (o.ShipStatus == "Đang chuyển")
                                {
                                    <strong class="order-id-link" onclick="confirmRemove('@o.OrderId', '@trip?.TripId')" title="Bấm để gỡ hàng xuống xe">
                                        @o.OrderId
                                    </strong>
                                    <form id="removeForm-@o.OrderId" asp-controller="Order" asp-action="RemoveFromTrip" method="POST" style="display:none;">
                                        <input type="hidden" name="orderId" value="@o.OrderId">
                                        <input type="hidden" name="tripId" value="@trip?.TripId">
                                    </form>
                                }
                                else
                                {
                                    <strong class="text-blue-600">@o.OrderId</strong>
                                }
                            </td>
                            <td>@o.ItemName</td>
                            <td>@o.SenderName <br>@o.SenderPhone</td>
                            <td>@o.ReceiverName <br>@o.ReceiverPhone</td>
                            <td>
                                <span>
                                    @(sendStationId?.ToString() ?? "??") ➔ @(receiveStationId?.ToString() ?? "??")
                                </span>
                            </td>
                            <td><span style="color:#27ae60; font-weight:700;">@o.Tr</span></td>
                            <td><span style="color:#e67e22; font-weight:700;">@o.Ct</span></td>
                            
                        </tr>
                    }
                </tbody>
            </table>

        }
        else
        {
            <div class="no-data" style="text-align:center; padding:40px; color:#888;">
                <div style="font-size:2rem;margin-bottom:8px;">📭</div>
                <p>Hiện chưa có đơn hàng nào trên chuyến xe này.</p>
            </div>
        }

        <div style="margin-top: 20px;">
            <a asp-controller="Trip" asp-action="List" class="btn-back" style="text-decoration:none; display:inline-block; text-align:center;">⬅ Quay lại DS Chuyến Xe</a>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@@11"></script>
    <script>
        function confirmRemove(orderId, tripId) {
            Swal.fire({
                title: 'Bỏ hàng xuống xe?',
                text: `Bạn có chắc chắn muốn gỡ đơn hàng ${orderId} khỏi chuyến xe này?`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#3085d6',
                confirmButtonText: 'Đúng, gỡ ngay!',
                cancelButtonText: 'Hủy'
            }).then((result) => {
                if (result.isConfirmed) {
                    document.getElementById('removeForm-' + orderId).submit();
                }
            })
        }
    </script>
}
