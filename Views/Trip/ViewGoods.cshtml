@model IEnumerable<Delivery_System.Models.TblOrder>

@{
    ViewData["Title"] = "Danh Sách Hàng Trên Xe";
    var trip = ViewBag.Trip as Delivery_System.Models.VwTripList;
    var stations = ViewBag.StationList as IEnumerable<Delivery_System.Models.TblStation> ?? new List<Delivery_System.Models.TblStation>();
}

@section Styles {
    <link rel="stylesheet" href="~/css/view_goods.css?v=@DateTime.Now.Ticks">
    }

    <div class="page-wrap">
        <div class="hdr">
            <h3>📋 DANH SÁCH HÀNG TRÊN CHUYẾN XE</h3>
            @if (trip != null)
            {
                <div class="meta">
                    <span class="badge">Chuyến: @trip.TripId</span>
                    <span class="badge">Lộ trình: @trip.RouteInfo</span>
                    <span class="badge">Biển số: @trip.LicensePlate</span>
                    <span class="badge">Tổng đơn: @(Model?.Count() ?? 0) đơn</span>
                </div>
            }
        </div>

        <div class="body">
            @if (Model != null && Model.Any())
            {
                <table>
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Mã Đơn</th>
                            <th>Tên Hàng</th>
                            <th>Người Gửi</th>
                            <th>Người Nhận</th>
                            <th>Trạm</th>
                            <th>TR</th>
                            <th>CT</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            int i = 1;
                            decimal totalTr = 0;
                            decimal totalCt = 0;
                        }
                        @foreach (var o in Model)
                        {
                            var sendStationId = stations.FirstOrDefault(s => s.StationName == o.SendStation)?.StationId;
                            var receiveStationId = stations.FirstOrDefault(s => s.StationName == o.ReceiveStation)?.StationId;
                            totalTr += o.Tr ?? 0;
                            totalCt += o.Ct ?? 0;
                        
                            <tr>
                                <td>@(i++)</td>
                                <td>
                                    @if (o.ShipStatus == "Đang chuyển")
                                    {
                                        <strong class="order-id-link" onclick="confirmRemove('@o.OrderId', '@trip?.TripId')" title="Bấm để gỡ hàng xuống xe">
                                            @o.OrderId
                                        </strong>
                                        <form id="removeForm-@o.OrderId" asp-controller="Order" asp-action="RemoveFromTrip" method="POST" class="hidden-form">
                                            <input type="hidden" name="orderId" value="@o.OrderId">
                                            <input type="hidden" name="tripId" value="@trip?.TripId">
                                        </form>
                                    }
                                    else
                                    {
                                        <strong class="text-blue-600">@o.OrderId</strong>
                                    }
                                </td>
                                <td class="col-item-name">@o.ItemName</td>
                                <td class="col-name-std">@o.SenderName <br><hr />@o.SenderPhone</td>
                                <td class="col-name-std">@o.ReceiverName <br><hr />@o.ReceiverPhone</td>
                                <td>
                                    <span class="station-container">
                                        <span class="station-send" onclick="showStationInfo('@o.SendStation', '@(sendStationId?.ToString() ?? "??")')">@(sendStationId?.ToString() ?? "??")</span>
                                        <span class="station-arrow"> ➔ </span>
                                        <span class="station-receive" onclick="showStationInfo('@o.ReceiveStation', '@(receiveStationId?.ToString() ?? "??")')">@(receiveStationId?.ToString() ?? "??")</span>
                                    </span>
                                </td>
                                <td><span class="price-tr">@(o.Tr?.ToString("N0") ?? "0")</span></td>
                                <td><span class="price-ct">@(o.Ct?.ToString("N0") ?? "0")</span></td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr class="table-summary-row">
                            <td colspan="6" class="summary-label">Tổng cộng:</td>
                            <td class="summary-value value-total-tr">@totalTr.ToString("N0")</td>
                            <td class="summary-value value-total-ct">@totalCt.ToString("N0")</td>
                        </tr>
                    </tfoot>
                </table>
            }
            else
            {
                <div class="no-data no-data-msg">
                    <div class="no-data-icon">📭</div>
                    <p>Hiện chưa có đơn hàng nào trên chuyến xe này.</p>
                </div>
            }

            <div class="back-link-container">
                <a asp-controller="Trip" asp-action="List" class="btn-back">⬅ Quay lại DS Chuyến Xe</a>
            </div>
        </div>
    </div>

    @section Scripts {
        <script>
            function confirmRemove(orderId, tripId) {
            Swal.fire({
            title: 'Bỏ hàng xuống xe?',
            text: `Bạn có chắc chắn muốn gỡ đơn hàng ${orderId} khỏi chuyến xe này?`,
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#d33',
            cancelButtonColor: '#3085d6',
            confirmButtonText: 'Đúng, gỡ ngay!',
            cancelButtonText: 'Hủy'
            }).then((result) => {
            if (result.isConfirmed) {
            document.getElementById('removeForm-' + orderId).submit();
            }
            })
            }
        </script>
    }
