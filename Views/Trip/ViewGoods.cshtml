@model IEnumerable<Delivery_System.Models.TblOrder>

@{
    ViewData["Title"] = "Danh Sách Hàng Trên Xe";
    var trip = ViewBag.Trip as Delivery_System.Models.VwTripList;
    var stations = ViewBag.StationList as IEnumerable<Delivery_System.Models.TblStation> ?? new List<Delivery_System.Models.TblStation>();
}

@section Styles {
    <link rel="stylesheet" href="~/css/list_trip.css" asp-append-version="true">
}

<div class="tr-container">
    @Html.AntiForgeryToken()
    <div class="tr-page-wrap">
        <div class="tr-hdr">
            <div class="tr-hdr-btn-wrap">
                <a href="@Url.Action("PrintGoodsList", "Trip", new { id = trip?.TripId })" target="_blank" 
                           class="tr-btn tr-btn-print tr-btn-header">
                    🖨️ IN DANH SÁCH HÀNG
                </a>
            </div>
            <h3 class="mb-0">📋 DANH SÁCH HÀNG TRÊN CHUYẾN XE</h3>

            @if (trip != null)
            {
                <div class="meta">
                    <span class="badge">
                        Chuyến: 
                        <a href="@Url.Action("List", "Trip", new { searchTruck = trip.TripId })" 
                           class="tr-header-link" title="Xem chi tiết chuyến xe này trong danh sách">
                            @trip.TripId
                        </a>
                    </span>
                    <span class="badge">Lộ trình: @trip.RouteInfo</span>
                    <span class="badge">Biển số: @trip.LicensePlate</span>
                    <span class="badge">Tổng đơn: @(Model?.Count() ?? 0) đơn</span>
                </div>
            }
        </div>

        <div class="tr-body">
            @if (Model != null && Model.Any())
            {
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Mã Đơn</th>
                            <th>Tên Hàng</th>
                            <th>Người Gửi</th>
                            <th>Người Nhận</th>
                            <th>Trạm</th>
                            <th>Trạng Thái</th>
                            <th>NV Giao</th>
                            <th>TR</th>
                            <th>CT</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            int i = 1;
                            decimal totalTr = 0;
                            decimal totalCt = 0;
                        }
                        @foreach (var o in Model)
                        {
                            var sendStationId = stations.FirstOrDefault(s => s.StationName == o.SendStation)?.StationId;
                            var receiveStationId = stations.FirstOrDefault(s => s.StationName == o.ReceiveStation)?.StationId;
                            totalTr += o.Tr ?? 0;
                            totalCt += o.Ct ?? 0;
                        
                            <tr>
                                <td>@(i++)</td>
                                <td>
                                    @if (o.ShipStatus == "Đang chuyển")
                                    {
                                        <strong class="tr-id-link" onclick="confirmRemove('@o.OrderId', '@trip?.TripId')" title="Bấm để gỡ hàng xuống xe">
                                            @o.OrderId
                                        </strong>
                                        <form id="removeForm-@o.OrderId" asp-controller="Order" asp-action="RemoveFromTrip" method="POST" class="hidden-form">
                                            <input type="hidden" name="orderId" value="@o.OrderId">
                                            <input type="hidden" name="tripId" value="@trip?.TripId">
                                        </form>
                                    }
                                    else
                                    {
                                        <a href="@Url.Action("List", "Order", new { statusFilter = "all", searchPhone = o.OrderId })" 
                                           class="tr-id-delivery-link" title="Đi tới trang giao hàng">
                                            @o.OrderId
                                        </a>
                                    }
                                </td>
                                <td>@o.ItemName</td>
                                <td class="tr-col-name-std">@o.SenderName <br><small class="text-muted">@o.SenderPhone</small></td>
                                <td class="tr-col-name-std">@o.ReceiverName <br><small class="text-muted">@o.ReceiverPhone</small></td>
                                <td>
                                    <span class="tr-station-container">
                                        <span class="tr-station-send" onclick="showStationInfo('@o.SendStation', '@(sendStationId?.ToString() ?? "??")')">@(sendStationId?.ToString() ?? "??")</span>
                                        <span class="tr-route-arrow"> ➔ </span>
                                        <span class="tr-station-receive" onclick="showStationInfo('@o.ReceiveStation', '@(receiveStationId?.ToString() ?? "??")')">@(receiveStationId?.ToString() ?? "??")</span>
                                    </span>
                                </td>
                                <td>
                                    @if (o.ShipStatus == "Đã giao")
                                    {
                                        <span class="tr-badge tr-badge-delivered">✅ Đã giao</span>
                                    }
                                    else if (o.ShipStatus == "Đã đến")
                                    {
                                        <span class="tr-badge tr-badge-arrived-new">📥 Đã đến</span>
                                    }
                                    else
                                    {
                                        <span class="tr-badge tr-badge-going">🚛 @o.ShipStatus</span>
                                    }
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(o.StaffReceive))
                                    {
                                        <div class="tr-staff-id-small">@o.StaffReceive</div>
                                        <div class="tr-time-small">@o.ReceiveDate</div>
                                    }
                                    else
                                    {
                                        <span class="text-muted">—</span>
                                    }
                                </td>
                                <td><span class="tr-price-tr">@(o.Tr?.ToString("N0") ?? "0")</span></td>
                               <td><span class="tr-price-ct">@(o.Ct?.ToString("N0") ?? "0")</span></td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr class="tr-summary-row">
                            <td colspan="8" class="tr-summary-label">Tổng cộng (TR + CT):</td>
                            <td colspan="2" class="tr-summary-value tr-value-total-highlight">
                                @((totalTr + totalCt).ToString("N0"))
                            </td>
                        </tr>
                    </tfoot>
                </table>
            }
            else
            {
                <div class="tr-no-data py-5">
                    <div class="tr-no-data-icon">📭</div>
                    <p>Hiện chưa có đơn hàng nào trên chuyến xe này.</p>
                </div>
            }

            <div class="mt-4">
                <a asp-controller="Trip" asp-action="List" class="tr-btn tr-btn-secondary">⬅ Quay lại DS Chuyến Xe</a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function confirmRemove(orderId, tripId) {
            Swal.fire({
                title: 'Bỏ hàng xuống xe?',
                text: `Bạn có chắc chắn muốn gỡ đơn hàng ${orderId} khỏi chuyến xe này?`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#3085d6',
                confirmButtonText: 'Đúng, gỡ ngay!',
                cancelButtonText: 'Hủy'
            }).then((result) => {
                if (result.isConfirmed) {
                    document.getElementById('removeForm-' + orderId).submit();
                }
            })
        }

        function deliverOrder(orderId) {
            Swal.fire({
                title: 'Xác nhận giao hàng?',
                text: `Đơn hàng ${orderId} đã được khách đến lấy và thanh toán đầy đủ?`,
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: '#28a745',
                cancelButtonColor: '#6c757d',
                confirmButtonText: '✅ Xác nhận đã giao',
                cancelButtonText: 'Hủy'
            }).then((result) => {
                if (result.isConfirmed) {
                    const token = $('input[name="__RequestVerificationToken"]').val();
                    $.ajax({
                        url: '@Url.Action("Deliver", "Order")',
                        type: 'POST',
                        data: { 
                            id: orderId,
                            __RequestVerificationToken: token
                        },
                        success: function (res) {
                            if (res.success) {
                                Swal.fire('Thành công!', res.message, 'success').then(() => {
                                    location.reload();
                                });
                            } else {
                                Swal.fire('Lỗi', res.message, 'error');
                            }
                        },
                        error: function (xhr) {
                            console.error(xhr.responseText);
                            Swal.fire('Lỗi', 'Không thể kết nối đến máy chủ hoặc lỗi xác thực.', 'error');
                        }
                    });
                }
            });
        }
    </script>
}
