@model IEnumerable<Delivery_System.Models.TblOrder>

@{
    ViewData["Title"] = "Danh Sách Hàng Trên Xe";
    var trip = ViewBag.Trip as Delivery_System.Models.VwTripList;
}

@section Styles {
    <link rel="stylesheet" href="~/css/view_goods.css" />
}

<div class="page-wrap">
    <div class="hdr">
        <h3>📋 DANH SÁCH HÀNG TRÊN CHUYẾN XE</h3>
        @if (trip != null)
        {
            <div class="meta">
                <span class="badge">Chuyến: @trip.TripId</span>
                <span class="badge">Lộ trình: @trip.RouteInfo</span>
                <span class="badge">Biển số: @trip.LicensePlate</span>
            </div>
        }
    </div>

    <div class="body">
        @if (Model != null && Model.Any())
        {
            <table>
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Mã Đơn</th>
                        <th>Tên Hàng</th>
                        <th>Người Gửi</th>
                        <th>Người Nhận</th>
                        <th>Trạm Nhận</th>
                        <th>Cước (K)</th>
                        <th>Trạng Thái</th>
                    </tr>
                </thead>
                <tbody>
                    @{ int i = 1; }
                    @foreach (var o in Model)
                    {
                        <tr>
                            <td>@(i++)</td>
                            <td><strong class="text-blue-600">@o.OrderId</strong></td>
                            <td><strong>@o.ItemName</strong></td>
                            <td>@o.SenderName <br><small class="text-muted-small">@o.SenderPhone</small></td>
                            <td>@o.ReceiverName <br><small class="text-muted-small">@o.ReceiverPhone</small></td>
                            <td>@o.ReceiveStation</td>
                            <td class="text-green-bold">@string.Format("{0:N0}", o.Amount ?? 0)</td>
                            <td>
                                <span class="badge @(o.ShipStatus == "Đã chuyển" ? "badge-success" : "badge-warning")">
                                    @o.ShipStatus
                                </span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

        }
        else
        {
            <div class="no-data" style="text-align:center; padding:40px; color:#888;">
                <div style="font-size:2rem;margin-bottom:8px;">📭</div>
                <p>Hiện chưa có đơn hàng nào trên chuyến xe này.</p>
            </div>
        }

        <div style="margin-top: 20px;">
            <a asp-controller="Trip" asp-action="List" class="btn-back">⬅ Quay lại DS Chuyến Xe</a>
        </div>
    </div>
</div>
