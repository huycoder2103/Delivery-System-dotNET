@model IEnumerable<Delivery_System.Models.TblOrder>

@{
    ViewData["Title"] = "Gán Hàng Lên Xe";
    var trip = ViewBag.Trip as Delivery_System.Models.VwTripList;
}

@section Styles {
    <link rel="stylesheet" href="~/css/assign_goods.css">
}

<div class="page-wrap">
    <div class="hdr">
        <h3>📦 GÁN HÀNG LÊN CHUYẾN XE</h3>
        @if (trip != null)
        {
            <div class="meta">
                <span class="badge">Chuyến: @trip.TripId</span>
                <span class="badge">Lộ trình: @trip.RouteInfo</span>
                <span class="badge">Xuất phát: @trip.Departure</span>
            </div>
        }
    </div>

    <div class="body">
        @if (TempData["SuccessMessage"] != null)
        {
            <div style="background:#d4edda;color:#155724;padding:9px 14px;border-radius:4px;margin-bottom:12px;font-weight:600;">
                ✅ @TempData["SuccessMessage"]
            </div>
        }

        <div class="info">
            Các đơn hàng <strong>Chưa Chuyển</strong> có trạm gửi là
            <strong>"@trip?.Departure"</strong> — sẵn sàng gán lên chuyến này.
        </div>

        @if (Model != null && Model.Any())
        {
            <table>
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Mã Đơn</th>
                        <th>Tên Hàng</th>
                        <th>Người Gửi</th>
                        <th>Người Nhận</th>
                        <th>Trạm Nhận</th>
                        <th>Cước</th>
                        <th>Trạng Thái</th>
                        <th>Thao Tác</th>
                    </tr>
                </thead>
                <tbody>
                    @{ int i = 1; }
                    @foreach (var o in Model)
                    {
                        <tr>
                            <td>@(i++)</td>
                            <td><strong style="color:#2980b9">@o.OrderId</strong></td>
                            <td><strong>@o.ItemName</strong></td>
                            <td>@o.SenderName <br><small style="color:#888">@o.SenderPhone</small></td>
                            <td>@o.ReceiverName <br><small style="color:#888">@o.ReceiverPhone</small></td>
                            <td>@o.ReceiveStation</td>
                            <td class="money">@string.Format("{0:N0}", o.Amount ?? 0)đ</td>
                            <td><span class="badge-pending">@o.Tr</span></td>
                            <td>
                                <form asp-controller="Order" asp-action="AssignToTrip" method="POST" style="display:inline;"
                                      onsubmit="return confirm('Gán đơn @o.OrderId lên chuyến @trip?.TripId?');">
                                    <input type="hidden" name="orderId" value="@o.OrderId">
                                    <input type="hidden" name="tripId" value="@trip?.TripId">
                                    <input type="hidden" name="source" value="trip">
                                    <input type="submit" value="📦 Gán lên xe" class="btn-assign">
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="no-data">
                <div style="font-size:2rem;margin-bottom:8px;">📭</div>
                <p>Không có đơn hàng chưa chuyển từ trạm <strong>"@trip?.Departure"</strong>.</p>
            </div>
        }

        <a asp-controller="Trip" asp-action="List" class="btn-back" style="text-decoration:none; display:inline-block; text-align:center;">⬅ Quay lại DS Chuyến Xe</a>
    </div>
</div>
