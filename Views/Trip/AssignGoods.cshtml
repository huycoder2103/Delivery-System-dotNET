@model IEnumerable<Delivery_System.Models.TblOrder>

@{
    ViewData["Title"] = "Gán Hàng Lên Xe";
    var trip = ViewBag.Trip as Delivery_System.Models.VwTripList;
}

@section Styles {
    <link rel="stylesheet" href="~/css/list_trip.css?v=@DateTime.Now.Ticks" />
}

<div class="tr-container">
    <div class="tr-page-wrap tr-assign-mode">
        <div class="tr-hdr tr-hdr-assign">
            <h3><i class="bi bi-box-seam"></i> GÁN HÀNG LÊN CHUYẾN XE</h3><br>   
            @if (trip != null)
            {
                <div class="tr-header-meta">
                    <span class="badge">Chuyến: @trip.TripId</span>
                    <span class="badge">Lộ trình: @trip.RouteInfo</span>
                    <span class="badge">Xuất phát: @trip.DepartureTime</span>
                </div>
            }
        </div>

        <div class="tr-body">
            <div class="tr-info-box">
                Các đơn hàng <strong>Chưa Chuyển</strong> có trạm gửi là
                <strong>"@trip?.Departure"</strong> và trạm nhận là <strong>"@trip?.Destination"</strong> — sẵn sàng gán lên chuyến này.
            </div>

            @if (Model != null && Model.Any())
            {
                <form id="bulkAssignForm" asp-controller="Order" asp-action="AssignToTrip" method="POST">
                    <input type="hidden" name="tripId" value="@trip?.TripId">
                    <input type="hidden" name="source" value="trip">
                    
                    <div class="tr-bulk-actions">
                        <label class="tr-select-all">
                            <input type="checkbox" id="selectAll" class="tr-checkbox-all"> <span class="ms-2">Chọn tất cả</span>
                        </label>
                        <button type="button" class="tr-btn tr-btn-success" onclick="confirmBulkAssign()">
                            Gán các đơn đã chọn lên xe
                        </button>
                    </div>

                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th class="text-center">Chọn</th>
                                <th>Mã Đơn</th>
                                <th>Tên Hàng</th>
                                <th>Người Gửi</th>
                                <th>Người Nhận</th>
                                <th>Trạm Gửi</th>
                                <th>Trạm Nhận</th>
                                <th>Thao Tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var o in Model)
                            {
                                <tr>
                                    <td class="text-center">
                                        <input type="checkbox" name="orderIds" value="@o.OrderId" class="order-checkbox tr-order-checkbox">
                                    </td>
                                    <td><strong class="tr-id-text">@o.OrderId</strong></td>
                                    <td>@o.ItemName</td>
                                    <td>@o.SenderName <br>@o.SenderPhone</td>
                                    <td>@o.ReceiverName <br>@o.ReceiverPhone</td>
                                    <td>@o.SendStation</td>
                                    <td>@o.ReceiveStation</td>
                                    <td>
                                        <button type="button" class="tr-btn-assign" onclick="confirmSingleAssign('@o.OrderId')">Gán lẻ</button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </form>
            }
            else
            {
                <div class="tr-no-data py-5">
                    <div class="tr-no-data-icon">📭</div>
                    <p>Không có đơn hàng chưa chuyển từ trạm <strong>"@trip?.Departure"</strong> đến trạm <strong>"@trip?.Destination"</strong>.</p>
                </div>
            }
            <br>
            <div class="mt-4">
                <a asp-controller="Trip" asp-action="List" class="tr-btn tr-btn-secondary">⬅ Quay lại DS Chuyến Xe</a>
            </div>
        </div>
    </div>
</div>

<script>
    document.getElementById('selectAll').addEventListener('change', function() {
        const isChecked = this.checked;
        document.querySelectorAll('.order-checkbox').forEach(cb => cb.checked = isChecked);
    });

    function confirmBulkAssign() {
        const selected = document.querySelectorAll('.order-checkbox:checked');
        if (selected.length === 0) {
            Swal.fire('Chú ý', 'Vui lòng chọn ít nhất một đơn hàng!', 'warning');
            return;
        }

        Swal.fire({
            title: 'Gán ' + selected.length + ' đơn hàng?',
            text: "Xác nhận đưa các đơn hàng này lên chuyến xe @trip?.TripId?",
            icon: 'question',
            showCancelButton: true,
            confirmButtonColor: '#27ae60',
            cancelButtonColor: '#d33',
            confirmButtonText: ' Gán ngay',
            cancelButtonText: 'Hủy'
        }).then((result) => {
            if (result.isConfirmed) {
                // Vô hiệu hóa nút để tránh bấm nhiều lần
                const bulkBtn = document.querySelector('.tr-btn-success');
                if (bulkBtn) {
                    bulkBtn.disabled = true;
                    bulkBtn.innerHTML = "⌛ Đang xử lý...";
                }
                
                // Vô hiệu hóa tất cả nút gán lẻ
                document.querySelectorAll('.tr-btn-assign').forEach(btn => {
                    btn.disabled = true;
                });

                document.getElementById('bulkAssignForm').submit();
            }
        })
    }

    function confirmSingleAssign(orderId) {
        // Bỏ chọn tất cả và chỉ chọn đơn hiện tại
        document.querySelectorAll('.order-checkbox').forEach(cb => cb.checked = false);
        const cb = document.querySelector(`.order-checkbox[value="${orderId}"]`);
        if (cb) cb.checked = true;
        
        confirmBulkAssign();
    }
</script>
