@model Delivery_System.Models.TblTrip

@{
    ViewData["Title"] = "Thêm Chuyến Xe Đi";
    var stationList = ViewBag.StationList as IEnumerable<Delivery_System.Models.TblStation>;
    var truckList = ViewBag.TruckList as IEnumerable<Delivery_System.Models.TblTruck>;
}

@section Styles {
    <link rel="stylesheet" href="~/css/list_trip.css?v=@DateTime.Now.Ticks" />
}

<div class="tr-container-small @(ViewBag.HasActiveShift == false ? "tr-content-blurred" : "")">
    <form id="tripForm" asp-action="Create" method="POST" onsubmit="return validateTripStations()">
        <div class="tr-page-header">
            <div>
                <h2>🚛 THÊM CHUYẾN XE MỚI</h2>
                <div class="tr-header-meta">Khởi tạo lộ trình vận chuyển hàng hóa</div>
            </div>
        </div>

        <div asp-validation-summary="All" class="alert alert-danger mb-4"></div>

        <div class="tr-card">
            <!-- Dòng 1: Xe và Trạm -->
            <div class="tr-form-row">
                <div class="tr-form-group">
                    <label class="form-label">Biển Số Xe <span class="tr-required">*</span></label>
                    <select asp-for="TruckId" class="form-select tr-form-control" required>
                        <option value="">-- Chọn Xe Vận Chuyển --</option>
                        @if (truckList != null)
                        {
                            foreach (var truck in truckList)
                            {
                                string statusLabel = (truck.Status == true) ? "" : " (Đang đi)";
                                <option value="@truck.TruckId">@truck.LicensePlate @statusLabel</option>
                            }
                        }
                    </select>
                </div>

                <div class="tr-form-group">
                    <label class="form-label">Trạm Xuất Phát <span class="tr-required">*</span></label>
                    <select asp-for="Departure" id="departure" class="form-select tr-form-control" required disabled="@(!User.IsInRole("AD"))">
                        <option value="">-- Chọn Trạm Đi --</option>
                        @if (stationList != null)
                        {
                            foreach (var s in stationList)
                            {
                                bool isUserStation = (s.StationName == ViewBag.UserStationName);
                                <option value="@s.StationName" selected="@(isUserStation)">@s.StationName (@s.StationId)</option>
                            }
                        }
                    </select>
                    @if (!User.IsInRole("AD"))
                    {
                        <input type="hidden" asp-for="Departure" value="@ViewBag.UserStationName" />
                    }
                </div>

                <div class="tr-form-group">
                    <label class="form-label">Trạm Đích <span class="tr-required">*</span></label>
                    <select asp-for="Destination" id="destination" class="form-select tr-form-control" required>
                        <option value="">-- Chọn Trạm Đến --</option>
                        @if (stationList != null)
                        {
                            foreach (var s in stationList)
                            {
                                if (!User.IsInRole("AD") && s.StationName == ViewBag.UserStationName) continue;
                                <option value="@s.StationName">@s.StationName (@s.StationId)</option>
                            }
                        }                    </select>
                </div>
            </div>

            <!-- Dòng 2: Đồng hồ bên trái, Tên lái/phụ bên phải xếp chồng -->
            <div class="tr-form-row tr-form-row-top">
                <!-- Cột trái: Đồng hồ -->
                <div class="tr-form-group tr-time-picker-col">
                    <label class="form-label">Giờ Xuất Phát <span class="tr-required">*</span></label>
                    <input type="hidden" asp-for="DepartureTime" id="finalDepartureTime" required>
                    
                    <div class="tr-time-picker">
                        <div class="tr-time-unit">
                            <button type="button" class="tr-arrow-btn" onclick="adjustTime('hourInp', 1)">▲</button>
                            <input type="number" id="hourInp" class="tr-time-input" min="1" max="12" value="08" oninput="validateInput(this, 1, 12)">
                            <button type="button" class="tr-arrow-btn" onclick="adjustTime('hourInp', -1)">▼</button>
                        </div>

                        <div class="tr-time-separator">:</div>

                        <div class="tr-time-unit">
                            <button type="button" class="tr-arrow-btn" onclick="adjustTime('minuteInp', 1)">▲</button>
                            <input type="number" id="minuteInp" class="tr-time-input" min="0" max="59" value="00" oninput="validateInput(this, 0, 59)">
                            <button type="button" class="tr-arrow-btn" onclick="adjustTime('minuteInp', -1)">▼</button>
                        </div>

                        <div class="tr-ampm-switch">
                            <button type="button" class="tr-btn-ampm active" id="btnAM" onclick="setAMPM('AM')">AM</button>
                            <button type="button" class="tr-btn-ampm" id="btnPM" onclick="setAMPM('PM')">PM</button>
                        </div>
                    </div>
                </div>

                <!-- Cột phải: Tài xế (trên) và Phụ xe (dưới) -->
                <div class="tr-form-group tr-driver-info-col">
                    <div class="tr-input-group-vertical mb-3">
                        <label class="form-label">Tài Xế Phụ Trách</label>
                        <input asp-for="DriverName" type="text" placeholder="Họ tên tài xế..." class="form-control tr-form-control tr-full-width-input">
                    </div>
                    <div class="tr-input-group-vertical">
                        <label class="form-label">Nhân Viên Phụ Xe</label>
                        <input asp-for="AssistantName" type="text" placeholder="Họ tên phụ xe..." class="form-control tr-form-control tr-full-width-input">
                    </div>
                </div>
            </div>
        </div>
    </form>

    <div class="tr-form-actions-row mt-4">
        <a asp-action="List" class="tr-btn tr-btn-secondary">⬅ Quay lại danh sách</a>
        <input type="submit" form="tripForm" value="💾 Lưu Chuyến Xe" class="tr-btn tr-btn-success tr-btn-save-trip" @(ViewBag.HasActiveShift == false ? "disabled" : "")>
    </div>
</div>

@if (ViewBag.HasActiveShift == false)
{
    <div id="shiftRequiredModal" class="tr-modal-blur">
        <div class="tr-modal-content">
            <div class="tr-modal-icon">⏰</div>
            <h2 class="tr-modal-title">Chưa Vào Ca Làm Việc!</h2>
            <p class="tr-modal-desc">Bạn cần phải bắt đầu ca làm việc trước khi có thể khởi tạo chuyến xe mới.</p>
            
            <form asp-controller="Home" asp-action="StartShift" method="POST">
                <button type="submit" class="tr-btn-start-shift">
                    🚀 BẮT ĐẦU CA NGAY
                </button>
            </form>
            
            <div class="tr-modal-footer">
                <a asp-action="List" class="tr-link-modal-back">Quay lại danh sách</a>
            </div>
        </div>
    </div>
}

<script>
    let currentAMPM = 'AM';

    function setAMPM(val) {
        currentAMPM = val;
        document.getElementById('btnAM').classList.toggle('active', val === 'AM');
        document.getElementById('btnPM').classList.toggle('active', val === 'PM');
        updateFinalValue();
    }

    function adjustTime(id, amount) {
        const inp = document.getElementById(id);
        let val = parseInt(inp.value) + amount;
        
        if (id === 'hourInp') {
            if (val > 12) val = 1;
            if (val < 1) val = 12;
        } else {
            if (val > 59) val = 0;
            if (val < 0) val = 59;
        }
        
        inp.value = val.toString().padStart(2, '0');
        updateFinalValue();
    }

    function validateInput(inp, min, max) {
        let val = parseInt(inp.value);
        if (isNaN(val)) return;
        if (val < min && inp.value.length >= 2) inp.value = min.toString().padStart(2, '0');
        if (val > max) inp.value = max.toString().padStart(2, '0');
        updateFinalValue();
    }

    function updateFinalValue() {
        const h = document.getElementById('hourInp').value.padStart(2, '0');
        const m = document.getElementById('minuteInp').value.padStart(2, '0');
        document.getElementById('finalDepartureTime').value = `${h}:${m} ${currentAMPM}`;
    }

    function validateTripStations() {
        var dep = document.getElementById("departure").value;
        var dest = document.getElementById("destination").value;
        if (dep === dest && dep !== "") {
            Swal.fire({ icon: 'error', title: 'Lỗi chọn trạm', text: 'Trạm đi và trạm đến không được trùng nhau!' });
            return false;
        }

        // Ngăn chặn bấm nút nhiều lần
        const submitBtn = document.querySelector('input[type="submit"][form="tripForm"]');
        if (submitBtn) {
            submitBtn.disabled = true;
            submitBtn.value = "⌛ Đang lưu...";
        }

        return true;
    }

    window.addEventListener('DOMContentLoaded', () => {
        updateFinalValue();
    });
</script>
