@model IEnumerable<Delivery_System.Models.VwTripList>

@{
    ViewData["Title"] = "Danh Sách Chuyến Xe Đến";
    var stationList = ViewBag.StationList as IEnumerable<Delivery_System.Models.TblStation>;
}

@section Styles {
    <link rel="stylesheet" href="~/css/list_trip.css?v=@DateTime.Now.Ticks" />
}

<div class="tr-container">
    
    <div class="tr-page-header tr-page-header-Arival">
        <div>
            <h2>📥 DANH SÁCH CHUYẾN XE ĐẾN</h2>
            <div id="tripCount" class="tr-header-meta tr-btn-sum tr-btn-header">Tổng: @(Model?.Count() ?? 0) chuyến</div>
        </div>
        
        <div class="tr-header-actions">
            <a asp-controller="Order" asp-action="List" class="tr-btn tr-btn-header">
                📦 Quản Lý Đơn Hàng
            </a>
            <a asp-controller="Trip" asp-action="List" class="tr-btn tr-btn-header">
                📤 Chuyến Xe Đi
            </a>
        </div>
    </div>

    <div class="tr-sticky-filter tr-sticky-filter-Arival">
        <div class="tr-filter-group">
            <select id="filterDeparture" class="tr-filter-select">
                <option value="">-- Từ Trạm (Đi) --</option>
                @if (stationList != null)
                {
                    foreach (var s in stationList)
                    {
                        <option value="@s.StationName" selected="@(s.StationName == ViewBag.DepartureFilter ? "selected" : null)">@s.StationName (@s.StationId)</option>
                    }
                }            </select>

            <select id="filterDestination" class="tr-filter-select">
                <option value="">-- Đến Trạm (Dừng) --</option>
                @if (stationList != null)
                {
                    foreach (var s in stationList)
                    {
                        <option value="@s.StationName" selected="@(s.StationName == ViewBag.DestinationFilter ? "selected" : null)">@s.StationName (@s.StationId)</option>
                    }
                }
            </select>

            <div class="tr-search-wrapper">
                <input type="text" id="filterTruck" placeholder="Tìm biển số, ID chuyến" 
                       value="@ViewBag.SearchTruck" class="tr-search-input">
            </div>


            <button onclick="resetFilters()" class="tr-btn tr-btn-secondary">🔄 Làm mới</button>
        </div>
    </div>

    <div class="tr-card tr-card-table tr-page-wrap">
        <table class="table table-hover" id="tripTable">
            <thead>
                <tr>
                    <th style="width: 40px;">STT</th>
                    <th class="tr-col-id">Mã Chuyến</th>
                    <th class="tr-col-route">Lộ trình</th>
                    <th class="tr-col-plate">Biển Số Xe</th>
                    <th class="tr-col-time">Giờ Đi</th>
                    <th class="tr-col-staff">Tài Xế</th>
                    <th class="tr-col-act">Trạng Thái</th>
                    <th class="tr-col-staff">NV Tạo</th>
                    <th class="tr-col-time">Thời Gian Tạo</th>
                    <th class="tr-col-staff">NV Tiếp Nhận</th>
                    <th class="tr-col-act">Thao Tác</th>
                </tr>
            </thead>
            <tbody id="tripTableBody">
                <partial name="_TripTableBody" model="Model" />
            </tbody>
        </table>
    </div>

    <!-- Pagination Controls -->
    <div class="tr-pagination">
        @if (ViewBag.TotalPages > 1)
        {
            var currentPage = (int)ViewBag.CurrentPage;
            var totalPages = (int)ViewBag.TotalPages;

            <button class="tr-btn tr-btn-secondary" onclick="changePage(@(currentPage - 1))" @(currentPage == 1 ? "disabled" : "")>
                « Trang trước
            </button>
            
            <div class="tr-page-info px-3">
                Trang @currentPage / @totalPages
            </div>

            <button class="tr-btn tr-btn-secondary" onclick="changePage(@(currentPage + 1))" @(currentPage == totalPages ? "disabled" : "")>
                Trang sau »
            </button>
        }
    </div>

    <div class="tr-footer-actions mt-4">
        <a asp-controller="Home" asp-action="Index" class="tr-btn tr-btn-secondary">⬅ Quay lại Trang Chủ</a>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.1/signalr.min.js"></script>
    <script>
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/deliveryHub")
            .withAutomaticReconnect()
            .build();

        let isProcessingSelf = false;

        connection.on("UpdateOrderList", function () {
            // Khi có đơn hàng thay đổi, số lượng hàng trên xe cũng thay đổi nên cần refresh
            refreshDashboard(isProcessingSelf);
            isProcessingSelf = false;
        });

        connection.start().then(() => {
            // Dùng Station ID thay cho Name để đảm bảo tính chính xác
            const userStationId = '@Delivery_System.Helpers.UserExtensions.GetStationId(User)';
            const userRole = '@(User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value)';
            connection.invoke("JoinStationGroup", userStationId, userRole);
        }).catch(err => console.error(err.toString()));

        let searchTimeout;
        let currentPage = @(ViewBag.CurrentPage ?? 1);

        function refreshDashboard(skipToast = false) {
            const departure = document.getElementById('filterDeparture').value;
            const destination = document.getElementById('filterDestination').value;
            const truck = document.getElementById('filterTruck').value;

            const url = `@Url.Action("ArrivalList", "Trip")?departureFilter=${encodeURIComponent(departure)}&destinationFilter=${encodeURIComponent(destination)}&searchTruck=${encodeURIComponent(truck)}&page=${currentPage}`;

            $.ajax({
                url: url,
                type: 'GET',
                headers: { "X-Requested-With": "XMLHttpRequest" },
                success: function (data) {
                    $('#tripTableBody').html(data);
                    
                    // Cập nhật text tổng ở header
                    const cAll = $('#ajaxCountAll').val();
                    $('#tripCount').text(`Tổng: ${cAll} chuyến`);

                    if (!skipToast) {
                        const Toast = Swal.mixin({
                            toast: true,
                            position: 'top-end',
                            showConfirmButton: false,
                            timer: 2000,
                            timerProgressBar: true
                        });
                        Toast.fire({ icon: 'info', title: 'Danh sách chuyến xe vừa được cập nhật!' });
                    }
                }
            });
        }

        document.getElementById('filterDeparture').addEventListener('change', () => { currentPage = 1; triggerSearch(); });
        document.getElementById('filterDestination').addEventListener('change', () => { currentPage = 1; triggerSearch(); });
        document.getElementById('filterTruck').addEventListener('input', function() {
            clearTimeout(searchTimeout);
            searchTimeout = setTimeout(() => { currentPage = 1; triggerSearch(); }, 300);
        });

        function changePage(page) {
            currentPage = page;
            triggerSearch();
        }

        function triggerSearch() {
            refreshDashboard(true);
            
            const departure = document.getElementById('filterDeparture').value;
            const destination = document.getElementById('filterDestination').value;
            const truck = document.getElementById('filterTruck').value;
            const newUrl = `@Url.Action("ArrivalList", "Trip")?departureFilter=${encodeURIComponent(departure)}&destinationFilter=${encodeURIComponent(destination)}&searchTruck=${encodeURIComponent(truck)}&page=${currentPage}`;
            window.history.pushState({path:newUrl},'',newUrl);
        }

        function resetFilters() {
            window.location.href = `@Url.Action("ArrivalList", "Trip")`;
        }

        function confirmArrive(tripId) {
            Swal.fire({
                title: 'Xác nhận xe đã đến?',
                text: "Hệ thống sẽ ghi nhận bạn là người tiếp nhận chuyến xe này!",
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: '#28a745',
                cancelButtonColor: '#6c757d',
                confirmButtonText: '🏁 Đúng, xe đã đến',
                cancelButtonText: 'Hủy'
            }).then((result) => {
                if (result.isConfirmed) {
                    isProcessingSelf = true;
                    // Sử dụng AJAX để Arrive thay vì submit form truyền thống để mượt hơn
                    const token = $('input[name="__RequestVerificationToken"]').val();
                    $.ajax({
                        url: '@Url.Action("Arrive", "Trip")',
                        type: 'POST',
                        data: { 
                            id: tripId,
                            __RequestVerificationToken: token
                        },
                        success: function () {
                            Swal.fire({
                                title: 'Thành công!',
                                text: 'Đã xác nhận chuyến xe cập bến.',
                                icon: 'success',
                                timer: 1500,
                                showConfirmButton: false
                            }).then(() => {
                                refreshDashboard(true);
                            });
                        },
                        error: function (xhr) {
                            isProcessingSelf = false;
                            Swal.fire('Lỗi', 'Không thể xác nhận chuyến xe cập bến.', 'error');
                        }
                    });
                }
            })
        }
    </script>
}

