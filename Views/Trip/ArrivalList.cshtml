@model IEnumerable<Delivery_System.Models.VwTripList>

@{
    ViewData["Title"] = "Danh Sách Chuyến Xe Đến";
    var stationList = ViewBag.StationList as IEnumerable<Delivery_System.Models.TblStation>;
}

@section Styles {
    <link rel="stylesheet" href="~/css/list_trip.css?v=@DateTime.Now.Ticks" />
}

<div class="arrival-list-container">
    
    <div class="modern-page-header arrival-header">
        <div>
            <h3>📥 DANH SÁCH CHUYẾN XE ĐẾN</h3>
            <div id="tripCount" class="trip-count-meta">Tổng: @(Model?.Count() ?? 0) chuyến</div>
        </div>
        
        <div class="header-actions">
            <a asp-controller="Order" asp-action="List" class="btn-modern btn-header-action">
                📦 Quản Lý Đơn Hàng
            </a>
            <a asp-controller="Trip" asp-action="List" class="btn-modern btn-header-action">
                📤 Chuyến Xe Đi
            </a>
        </div>
    </div>

    <div class="modern-card sticky-filter-bar">
        <div class="filter-controls-group">
            <select id="filterDeparture" class="filter-select">
                <option value="">-- Từ Trạm (Đi) --</option>
                @if (stationList != null)
                {
                    foreach (var s in stationList)
                    {
                        <option value="@s.StationName" selected="@(s.StationName == ViewBag.DepartureFilter ? "selected" : null)">@s.StationName (@s.StationId)</option>
                    }
                }            </select>

            <select id="filterDestination" class="filter-select">
                <option value="">-- Đến Trạm (Dừng) --</option>
                @if (stationList != null)
                {
                    foreach (var s in stationList)
                    {
                        <option value="@s.StationName" selected="@(s.StationName == ViewBag.DestinationFilter ? "selected" : null)">@s.StationName (@s.StationId)</option>
                    }
                }
            </select>

            <div class="search-input-wrapper">
                <input type="text" id="filterTruck" placeholder="Tìm biển số, ID chuyến" 
                       value="@ViewBag.SearchTruck" class="search-input-field">
            </div>


            <button onclick="resetFilters()" class="btn-modern btn-secondary-modern">🔄 Làm mới</button>
        </div>
    </div>

    <div class="modern-card trip-table-card">
        <table class="modern-table" id="tripTable">
            <thead>
                <tr>
                    <th class="col-id">Mã Chuyến</th>
                    <th class="col-route">Lộ trình</th>
                    <th class="col-plate">Biển Số Xe</th>
                    <th class="col-time">Giờ Đi</th>
                    <th class="col-staff">Tài Xế</th>
                    <th class="col-act">Trạng Thái</th>
                    <th class="col-staff">NV Tạo</th>
                    <th class="col-time">Thời Gian Tạo</th>
                    <th class="col-act">Thao Tác</th>
                </tr>
            </thead>
            <tbody id="tripTableBody">
                <partial name="_TripTableBody" model="Model" />
            </tbody>
        </table>
    </div>

    <!-- Pagination Controls -->
    <div class="pagination-flex">
        @if (ViewBag.TotalPages > 1)
        {
            var currentPage = (int)ViewBag.CurrentPage;
            var totalPages = (int)ViewBag.TotalPages;

            <button class="btn-modern btn-secondary-modern" onclick="changePage(@(currentPage - 1))" @(currentPage == 1 ? "disabled" : "")>
                « Trang trước
            </button>
            
            <div class="page-info-text">
                Trang @currentPage / @totalPages
            </div>

            <button class="btn-modern btn-secondary-modern" onclick="changePage(@(currentPage + 1))" @(currentPage == totalPages ? "disabled" : "")>
                Trang sau »
            </button>
        }
    </div>

    <div class="footer-actions-row">
        <a asp-controller="Home" asp-action="Index" class="btn-back btn-footer-back">⬅ Quay lại Trang Chủ</a>
    </div>
</div>

@section Scripts {
    <script>
        let searchTimeout;
        let currentPage = @(ViewBag.CurrentPage ?? 1);

        document.getElementById('filterDeparture').addEventListener('change', () => { currentPage = 1; triggerSearch(); });
        document.getElementById('filterDestination').addEventListener('change', () => { currentPage = 1; triggerSearch(); });
        document.getElementById('filterTruck').addEventListener('input', function() {
            clearTimeout(searchTimeout);
            searchTimeout = setTimeout(() => { currentPage = 1; triggerSearch(); }, 300);
        });

        function changePage(page) {
            currentPage = page;
            triggerSearch();
        }

        function triggerSearch() {
            const departure = document.getElementById('filterDeparture').value;
            const destination = document.getElementById('filterDestination').value;
            const truck = document.getElementById('filterTruck').value;

            const url = `@Url.Action("ArrivalList", "Trip")?departureFilter=${encodeURIComponent(departure)}&destinationFilter=${encodeURIComponent(destination)}&searchTruck=${encodeURIComponent(truck)}&page=${currentPage}`;
            window.location.href = url;
        }

        function resetFilters() {
            window.location.href = `@Url.Action("ArrivalList", "Trip")`;
        }

        function confirmArrive(tripId) {
            Swal.fire({
                title: 'Xác nhận xe đến?',
                text: "Chuyến xe " + tripId + " đã cập bến an toàn?",
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: '#1a73e8',
                cancelButtonColor: '#d33',
                confirmButtonText: '🏁 Đúng, đã đến!',
                cancelButtonText: 'Hủy'
            }).then((result) => {
                if (result.isConfirmed) {
                    document.getElementById('arriveForm-' + tripId).submit();
                }
            })
        }
    </script>
}
