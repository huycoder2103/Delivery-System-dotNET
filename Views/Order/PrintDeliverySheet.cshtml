@model Delivery_System.Models.TblOrder

@{
    Layout = null;
    var currentUserID = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
    
    string MaskPhone(string phone) 
    {
        if (string.IsNullOrEmpty(phone) || phone.Length < 4) return phone;
        return "******" + phone.Substring(phone.Length - 4);
    }
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <title>In Phiếu Gửi Hàng A5 - @Model.OrderId</title>
    <link rel="stylesheet" href="~/css/list_order.css" asp-append-version="true" />
</head>

<body class="od-print-body">
    <div class="od-print-toolbar no-print">
        <button class="od-print-btn od-print-btn-main" onclick="window.print()">🖨️ XÁC NHẬN IN PHƠI</button>
        <button class="od-print-btn od-print-btn-close" onclick="window.close()">ĐÓNG</button>
    </div>

    <div class="od-a5-ticket">
        <div class="od-a5-route">@Model.SendStation &lt;&gt; @Model.ReceiveStation</div>
        <div class="od-a5-content">@Model.ItemName</div>

        <div class="od-a5-main-info">
            <div class="od-a5-details">
                <div class="od-a5-info-row">
                    <span class="od-a5-label">GỬI</span>: <span class="od-a5-value">@Model.SenderName - @Model.SenderPhone</span>
                </div>

                <div class="od-a5-info-row">
                    <span class="od-a5-label">NHẬN</span>: <span class="od-a5-value">@Model.ReceiverName - @MaskPhone(Model.ReceiverPhone)</span>
                </div>

                <div class="od-a5-meta">
                    @{
                        string payInfo = "";
                        if (Model.Tr.HasValue && Model.Tr != 0) payInfo += $"Phí Đã Thu: {Model.Tr.Value.ToString("N0")}.000 VNĐ";
                        if (Model.Ct.HasValue && Model.Ct != 0) 
                        {
                            if (payInfo != "") payInfo += " - ";
                            payInfo += $"Phí chưa thu: {Model.Ct.Value.ToString("N0")}.000 VNĐ";
                        }
                        if (string.IsNullOrEmpty(payInfo)) payInfo = "Phí Đã Thu: 0k - Phí chưa thu: 0k";
                    }
                    @payInfo <br>
                    MANV: @Model.StaffInput - NGÀY: @Model.CreatedAt?.ToString("dd/MM/yyyy HH:mm")
                </div>

                <div class="od-a5-staff-line">
                    NvN: - NvIN: @currentUserID - @ViewBag.PrintTime
                </div>
            </div>

            <div class="od-a5-barcode">
                <div class="od-a5-qr-wrapper">
                    @{
                        var trackingUrl = $"{Context.Request.Scheme}://{Context.Request.Host}/Order/Tracking/{Model.OrderId}";
                        var qrUrl = $"https://quickchart.io/qr?text={Uri.EscapeDataString(trackingUrl)}&size=150&margin=0";
                    }
                    <img src="@qrUrl" alt="QR Code" />
                </div>
            </div>
        </div>
    </div>

</body>
</html>
