@model Delivery_System.Models.TblOrder

@{
    ViewData["Title"] = "Chỉnh sửa đơn hàng";
    var stationList = ViewBag.StationList as IEnumerable<Delivery_System.Models.TblStation>;
}

@section Styles {
    <link rel="stylesheet" href="~/css/list_order.css?v=@DateTime.Now.Ticks" />
}

<div class="od-container od-container-edit">
    <div class="od-card" style="padding:0; overflow:hidden;">
        <div class="od-page-header" style="position:static; border-radius:0; margin-bottom:0; padding:15px 30px;">
            <div style="text-align:center; width:100%;">
                <h2 style="text-decoration:underline;">Chỉnh sửa đơn hàng #@Model.OrderId</h2>
                <div class="od-header-meta">Cập nhật thông tin hàng hóa và khách hàng</div>
            </div>
        </div>

        <div class="od-toolbar">
            <div class="od-toolbar-label">📝 Thông tin chi tiết</div>
            <button type="submit" form="editForm" class="od-btn od-btn-success" style="padding:8px 25px;">LƯU THAY ĐỔI</button>
        </div>

        @if (TempData["Error"] != null)
        {
            <div class="od-alert od-alert-danger" style="margin: 15px 20px;">
                <span>@TempData["Error"]</span>
            </div>
        }

        <form id="editForm" asp-action="Edit" method="POST" class="od-form-body">
            <input type="hidden" asp-for="OrderId" />
            <input type="hidden" asp-for="CreatedAt" />
            <input type="hidden" asp-for="StaffInput" />
            <input type="hidden" asp-for="TripId" />

            <div class="od-section-label">📦 Thông tin hàng hóa</div>
            <div class="od-form-row">
                <div class="od-form-group" style="flex: 2;">
                    <label>Tên Hàng Gửi <span class="od-required">*</span></label>
                    <input asp-for="ItemName" type="text" class="od-form-control" required>
                </div>
            </div>

            <div class="od-form-row-2">
                <div class="od-form-group">
                    <label>Trạm Gửi <span class="od-required">*</span></label>
                    <select asp-for="SendStation" class="od-form-control" required disabled="@(!User.IsInRole("AD"))">
                        @foreach (var s in stationList)
                        {
                            <option value="@s.StationName">@s.StationName (@s.StationId)</option>
                        }
                    </select>
                    @if (!User.IsInRole("AD"))
                    {
                        <input type="hidden" asp-for="SendStation" />
                    }
                </div>
                <div class="od-form-group">
                    <label>Trạm Nhận <span class="od-required">*</span></label>
                    <select asp-for="ReceiveStation" class="od-form-control" required>
                        @foreach (var s in stationList)
                        {
                            <option value="@s.StationName">@s.StationName (@s.StationId)</option>
                        }
                    </select>
                </div>
            </div>

            <hr class="od-divider">
            <div class="od-section-label">👤 Thông tin khách hàng</div>

            <div class="od-form-row-2">
                <div class="od-form-group">
                    <label>Người Gửi</label>
                    <input asp-for="SenderName" type="text" class="od-form-control">
                </div>
                <div class="od-form-group">
                    <label>SĐT Gửi <span class="od-required">*</span></label>
                    <input asp-for="SenderPhone" type="text" class="od-form-control" required>
                </div>
            </div>

            <div class="od-form-row-2">
                <div class="od-form-group">
                    <label>Người Nhận</label>
                    <input asp-for="ReceiverName" type="text" class="od-form-control">
                </div>
                <div class="od-form-group">
                    <label>SĐT Nhận <span class="od-required">*</span></label>
                    <input asp-for="ReceiverPhone" type="text" class="od-form-control" required>
                </div>
            </div>

            <hr class="od-divider">
            <div class="od-section-label">💰 Thanh toán & Ghi chú</div>

            <div class="od-form-row-3">
                <div class="od-form-group">
                    <label>Đã trả (TR)</label>
                    <input asp-for="Tr" type="number" class="od-form-control">
                </div>
                <div class="od-form-group">
                    <label>Chưa trả (CT)</label>
                    <input asp-for="Ct" type="number" class="od-form-control">
                </div>
                <div class="od-form-group">
                    <label>Giờ cập nhật</label>
                    <input type="text" value="@DateTime.Now.ToString("HH:mm dd/MM/yyyy")" class="od-form-control" readonly style="background:#eee;">
                </div>
            </div>

            <div class="od-form-group">
                <label>Ghi chú</label>
                <textarea asp-for="Note" class="od-form-control od-textarea"></textarea>
            </div>
        </form>

        <div style="padding:0 20px 20px; display:flex; gap:10px;">
            <a asp-action="List" class="od-btn od-btn-secondary" style="padding:9px 25px;">HỦY BỎ</a>
        </div>
    </div>

    <div style="text-align:center; margin-top:15px;">
        <a asp-action="List" style="text-decoration:none; color:#666; font-size:14px;">⬅ Quay lại danh sách đơn hàng</a>
    </div>
</div>
