@model Delivery_System.Models.TblOrder

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <title>In Biên Lai K80 - @Model.OrderId</title>
    <link rel="stylesheet" href="~/css/list_order.css?v=@DateTime.Now.Ticks" />
</head>
<body class="od-print-body">

    <div class="od-print-toolbar no-print">
        <button class="od-print-btn od-print-btn-main" onclick="window.print()">🖨️ XÁC NHẬN IN BIÊN LAI</button>
        <button class="od-print-btn od-print-btn-close" style="background:#666;" onclick="window.close()">ĐÓNG</button>
    </div>

    <div class="od-k80-ticket">
        <div class="od-k80-header">
            <div style="font-size: 14px; text-transform: uppercase;">Delivery System</div>
            <div style="font-size: 14px; text-transform: uppercase;">(@Model.SendStation)</div>
            <h2>BIÊN LAI HÀNG HÓA</h2>
            <div style="font-size: 14px; margin-bottom: 10px;">@ViewBag.PrintTime</div>
        </div>

        <div class="od-k80-item-name">
            @Model.ItemName
        </div>

        <div style="margin: 15px 0;">
            <div class="od-k80-info-row"><span class="od-k80-label">NG.GỬI:</span> <span class="od-k80-value">@Model.SenderName</span></div>
            <div class="od-k80-info-row"><span class="od-k80-label">NG.NHẬN:</span> <span class="od-k80-value">@Model.ReceiverName</span></div>
            <div class="od-k80-info-row"><span class="od-k80-label">SĐT GỬI:</span> <span class="od-k80-value">@Model.SenderPhone</span></div>
        </div>

        <div class="od-k80-route">
            @Model.SendStation &lt;&gt; @Model.ReceiveStation
        </div>

        <div class="od-k80-payment">
            @{
                string payInfo = "";
                if (Model.Tr.HasValue && Model.Tr != 0) payInfo += $"Phí đã thu: {Model.Tr.Value.ToString("N0")}.000 VNĐ";
                if (Model.Ct.HasValue && Model.Ct != 0) 
                {
                    if (payInfo != "") payInfo += " - ";
                    payInfo += $"Phí chưa thu: {Model.Ct.Value.ToString("N0")}.000 VNĐ";
                }
                if (string.IsNullOrEmpty(payInfo)) payInfo = "Chưa có thông tin phí";
            }
            @payInfo
        </div>

        <div style="font-size: 14px; margin-top: 10px;">
            <div>NV: <span style="font-weight: bold;">@Model.StaffInput</span></div>
            <div style="font-size: 16px; font-weight: bold; margin-top: 2px;">@Model.OrderId</div>
        </div>

        <div class="od-k80-footer">
            - Trường hợp xảy ra mất hoặc thất lạc, công ty bồi thường tối đa 50% giá trị hàng. Đối với hàng lúc gửi không khai báo trị giá bồi thường gấp 10 lần tiền cước phí. <br>
            <strong>Lưu ý:</strong> Biên nhận này có giá trị trong 15 ngày
        </div>
    </div>

</body>
</html>
