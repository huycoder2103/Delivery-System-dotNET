@model Delivery_System.Models.TblOrder

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Xem trước Biên nhận - @Model.OrderId</title>
    <link rel="stylesheet" href="~/css/print_receipt.css?v=@DateTime.Now.Ticks" />
</head>
<body>

    <div class="preview-toolbar">
        <div style="color: white; font-weight: bold;">BẢN XEM TRƯỚC BIÊN NHẬN</div>
        <button class="btn-print-main" onclick="window.print()">🖨️ XÁC NHẬN IN</button>
        <button class="btn-close-preview" onclick="window.close()">HỦY BỎ</button>
    </div>

    <div class="receipt-page">
        <div class="receipt-content">
            <div class="header">
                <h2>DELIVERY SYSTEM</h2>
                @* <p>Hotline: 1900 xxxx</p> *@
                <p>Ngày: @ViewBag.PrintTime</p>
            </div>

            <div class="order-code">
                MÃ ĐƠN: @Model.OrderId
            </div>

            <div class="section-title">Thông tin gửi hàng</div>
            <div class="info-row">
                <span class="label">Hàng hóa:</span>
                <span class="value">@Model.ItemName</span>
            </div>
            <div class="info-row">
                <span class="label">Lộ trình:</span>
                <span class="value">@Model.SendStation → @Model.ReceiveStation</span>
            </div>

            <div class="section-title">Khách hàng</div>
            <div class="info-row">
                <span class="label">Gửi:</span>
                <span class="value">@Model.SenderName <br> @Model.SenderPhone</span>
            </div>
            <div style="height: 5px;"></div>
            <div class="info-row">
                <span class="label">Nhận:</span>
                <span class="value">@Model.ReceiverName <br> @Model.ReceiverPhone</span>
            </div>

            <div class="section-title">Thanh toán</div>
            <div class="info-row">
                <span class="label">Đã trả (Tr):</span>
                <span class="value">@Model.Tr k</span>
            </div>
            <div class="info-row">
                <span class="label">Chưa trả (Ct):</span>
                <span class="value">@Model.Ct k</span>
            </div>

            @* <div class="total-box">
                <div class="info-row">
                    <span>TỔNG CƯỚC:</span>
                    <span>@string.Format("{0:N0}", Model.Amount ?? 0) k</span>
                </div>
            </div> *@

            @if(!string.IsNullOrEmpty(Model.Note))
            {
                <div style="margin-top: 15px; font-size: 0.8rem;">
                    <b>Ghi chú:</b> @Model.Note
                </div>
            }

            <div class="footer-note">
                Cảm ơn quý khách! <br>
                Nhân viên: @Model.StaffInput
            </div>
        </div>
    </div>

</body>
</html>
