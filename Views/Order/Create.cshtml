@model Delivery_System.Models.TblOrder

@{
    ViewData["Title"] = "Nhập Hàng Gửi";
    var stationList = ViewBag.StationList as IEnumerable<Delivery_System.Models.TblStation>;
}

@section Styles {
    <link rel="stylesheet" href="~/css/create_order.css?v=@DateTime.Now.Ticks" />
}

<div class="order-container-modern @(ViewBag.HasActiveShift == false ? "content-blurred" : "")">
    <form id="orderForm" asp-action="Create" method="POST" onsubmit="return validateOrderForm()">
        @* ... existing form content ... *@
        <div class="modern-page-header">
            <div>
                <h2>📦 NHẬP HÀNG GỬI MỚI</h2>
                <div style="font-size: 0.85rem; opacity: 0.8; margin-top: 4px;">Điền đầy đủ thông tin đơn hàng bên dưới</div>
            </div>
        </div>

        <div class="modern-card">
            <div class="section-title">✨ Thông tin hàng hóa</div>
            <div class="form-group">
                <label>Tên Hàng Gửi <span class="required-star">*</span></label>
                <input asp-for="ItemName" type="text"  required>
            </div>

            <div class="form-row" style="margin-top: 20px;">
                <div class="form-group">
                    <label>Trạm Gửi <span class="required-star">*</span></label>
                    <select asp-for="SendStation" id="sendStation" required>
                        <option value="">-- Chọn Trạm Gửi --</option>
                        @if (stationList != null)
                        {
                            foreach (var s in stationList)
                            {
                                <option value="@s.StationName">@s.StationName</option>
                            }
                        }
                    </select>
                </div>
                <div class="form-group">
                    <label>Trạm Nhận <span class="required-star">*</span></label>
                    <select asp-for="ReceiveStation" id="receiveStation" required>
                        <option value="">-- Chọn Trạm Nhận --</option>
                        @if (stationList != null)
                        {
                            foreach (var s in stationList)
                            {
                                <option value="@s.StationName">@s.StationName</option>
                            }
                        }
                    </select>
                </div>
            </div>
        </div>

        <div class="modern-card">
            <div class="section-title">👤 Thông tin khách hàng</div>
            <div class="form-row">
                <div class="form-group">
                    <label>Người Gửi</label>
                    <input asp-for="SenderName" type="text" placeholder="Tên khách hàng gửi...">
                </div>
                <div class="form-group">
                    <label>Số Điện Thoại Gửi <span class="required-star">*</span></label>
                    <input asp-for="SenderPhone" id="senderPhone" type="text" required placeholder="Nhập SĐT người gửi...">
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label>Người Nhận</label>
                    <input asp-for="ReceiverName" type="text" placeholder="Tên khách hàng nhận...">
                </div>
                <div class="form-group">
                    <label>Số Điện Thoại Nhận <span class="required-star">*</span></label>
                    <input asp-for="ReceiverPhone" id="receiverPhone" type="text" required placeholder="Nhập SĐT người nhận...">
                </div>
            </div>
        </div>

        <div class="modern-card">
            <div class="section-title">💰 Thanh toán & Ghi chú</div>
            <div class="form-row">
                <div class="form-group">
                    <label>Đã Thanh Toán (Tr) - Đơn vị K</label>
                    <input asp-for="Tr" id="trField" type="number" placeholder="0">
                </div>
                <div class="form-group">
                    <label>Chưa Thanh Toán (Ct) - Đơn vị K</label>
                    <input asp-for="Ct" id="ctField" type="number" placeholder="0">
                </div>
            </div>

            <div class="form-group">
                <label>Ghi Chú Đơn Hàng</label>
                <textarea asp-for="Note" rows="3" placeholder="Nhập các lưu ý đặc biệt về hàng hóa..."></textarea>
            </div>
        </div>
    </form>

    <div style="margin-bottom: 40px; display: flex; justify-content: space-between; align-items: center;">
        <a asp-action="List" class="btn-modern-back" style="text-decoration: none;">⬅ Quay lại danh sách</a>
        <input type="submit" form="orderForm" value="💾 Lưu Đơn Hàng" class="btn-modern-save" style="padding: 12px 40px; min-width: 200px;" @(ViewBag.HasActiveShift == false ? "disabled" : "")>
    </div>
</div>

@if (ViewBag.HasActiveShift == false)
{
    <div id="shiftRequiredModal" class="modal" style="display: flex; position: fixed; z-index: 10000; left: 0; top: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.6); align-items: center; justify-content: center; backdrop-filter: blur(5px);">
        <div class="modal-content" style="background: white; padding: 40px; border-radius: 20px; width: 450px; text-align: center; box-shadow: 0 20px 40px rgba(0,0,0,0.3);">
            <div style="font-size: 4rem; margin-bottom: 20px;">⏰</div>
            <h2 style="color: #1e293b; margin-bottom: 15px; font-weight: 800;">Chưa Vào Ca Làm Việc!</h2>
            <p style="color: #64748b; margin-bottom: 30px; line-height: 1.6;">Bạn cần phải bắt đầu ca làm việc trước khi có thể nhập hàng mới vào hệ thống.</p>
            
            <form asp-controller="Shift" asp-action="Start" method="POST">
                <button type="submit" class="btn-modern-save" style="width: 100%; padding: 15px; font-size: 1.1rem; background: linear-gradient(135deg, #6366f1, #4f46e5); border: none; cursor: pointer;">
                    🚀 BẮT ĐẦU CA NGAY
                </button>
            </form>
            
            <div style="margin-top: 20px;">
                <a asp-action="List" style="color: #94a3b8; text-decoration: none; font-weight: 600;">Quay lại danh sách</a>
            </div>
        </div>
    </div>
}



<script>
    function validateOrderForm() {
        var tr = document.getElementById("trField").value.trim();
        var ct = document.getElementById("ctField").value.trim();
        var sPhone = document.getElementById("senderPhone").value.trim();
        var rPhone = document.getElementById("receiverPhone").value.trim();
        var send = document.getElementById("sendStation").value;
        var receive = document.getElementById("receiveStation").value;

        if (send === receive && send !== "") {
            Swal.fire({ icon: 'error', title: 'Trùng trạm', text: 'Trạm gửi và trạm nhận không được trùng nhau!' });
            return false;
        }

        if (sPhone === "" || rPhone === "") {
            Swal.fire({ icon: 'warning', title: 'Thiếu thông tin', text: 'Số điện thoại người gửi và người nhận không được để trống!' });
            return false;
        }

        if (tr === "" && ct === "") {
            Swal.fire({ icon: 'info', title: 'Thanh toán', text: 'Bạn phải nhập thông tin tiền thanh toán (Tr) hoặc chưa thanh toán (Ct)!' });
            return false;
        }
        return true;
    }
</script>
