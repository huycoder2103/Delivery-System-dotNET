@model Delivery_System.Models.TblOrder

@{
    ViewData["Title"] = "Nhập Hàng Mới";
    var stationList = ViewBag.StationList as IEnumerable<Delivery_System.Models.TblStation>;
}

@section Styles {
    <link rel="stylesheet" href="~/css/list_order.css" asp-append-version="true" />
}

<div class="od-container od-container-small @(ViewBag.HasActiveShift == false ? "od-content-blurred" : "")">
    <form id="orderForm" asp-action="Create" method="POST" onsubmit="return validateForm()">
        <div class="od-page-header">
            <div>
                <h2><i class="bi bi-box-seam"></i> NHẬP ĐƠN HÀNG MỚI</h2>
                <div class="od-header-meta">Điền đầy đủ thông tin đơn hàng bên dưới</div>
            </div>
        </div>

        <div asp-validation-summary="All" class="od-text-danger od-mb-20"></div>

        <div class="od-card">
            <!-- Hàng 1: Tên hàng và Trạm -->
            <div class="od-form-row">
                <div class="od-form-group od-form-flex-2">
                    <label>Tên Hàng Gửi <span class="od-required">*</span></label>
                    <input asp-for="ItemName" type="text" class="od-form-control" required placeholder="Nhập tên hàng hóa...">
                    <span asp-validation-for="ItemName" class="od-text-danger"></span>
                </div>
                <div class="od-form-group">
                    <label>Trạm Gửi <span class="od-required">*</span></label>
                    <select asp-for="SendStation" id="sendStation" class="od-form-control" required disabled="@(!User.IsInRole("AD"))">
                        <option value="">-- Chọn Trạm Gửi --</option>
                        @if (stationList != null)
                        {
                            foreach (var s in stationList)
                            {
                                bool isUserStation = (s.StationName == ViewBag.UserStationName);
                                <option value="@s.StationName" selected="@(isUserStation)">@s.StationName (@s.StationId)</option>
                            }
                        }
                    </select>
                    @if (!User.IsInRole("AD"))
                    {
                        <input type="hidden" asp-for="SendStation" value="@ViewBag.UserStationName" />
                    }
                    <span asp-validation-for="SendStation" class="od-text-danger"></span>
                </div>
                <div class="od-form-group">
                    <label>Trạm Nhận <span class="od-required">*</span></label>
                    <select asp-for="ReceiveStation" id="receiveStation" class="od-form-control" required>
                        <option value="">-- Chọn Trạm Nhận --</option>
                        @if (stationList != null)
                        {
                            foreach (var s in stationList)
                            {
                                if (!User.IsInRole("AD") && s.StationName == ViewBag.UserStationName) continue;
                                <option value="@s.StationName">@s.StationName (@s.StationId)</option>
                            }
                        }
                    </select>
                    <span asp-validation-for="ReceiveStation" class="od-text-danger"></span>
                </div>
            </div>

            <!-- Hàng 2: Người gửi -->
            <div class="od-form-row">
                <div class="od-form-group">
                    <label>Người Gửi</label>
                    <input asp-for="SenderName" type="text" class="od-form-control" placeholder="Tên khách gửi...">
                </div>
                <div class="od-form-group">
                    <label>SĐT Gửi <span class="od-required">*</span></label>
                    <input asp-for="SenderPhone" id="senderPhone" class="od-form-control" type="text" required maxlength="11" minlength="10" pattern="\d{10,11}" placeholder="Số điện thoại người gửi...">
                    <span asp-validation-for="SenderPhone" class="od-text-danger"></span>
                </div>
            </div>

            <!-- Hàng 3: Người nhận -->
            <div class="od-form-row">
                <div class="od-form-group">
                    <label>Người Nhận</label>
                    <input asp-for="ReceiverName" type="text" class="od-form-control" placeholder="Tên khách nhận...">
                </div>
                <div class="od-form-group">
                    <label>SĐT Nhận <span class="od-required">*</span></label>
                    <input asp-for="ReceiverPhone" id="receiverPhone" class="od-form-control" type="text" required maxlength="11" minlength="10" pattern="\d{10,11}" placeholder="Số điện thoại người nhận...">
                    <span asp-validation-for="ReceiverPhone" class="od-text-danger"></span>
                </div>
            </div>

            <!-- Hàng 4: Thanh toán & Ghi chú -->
            <div class="od-form-row">
                <div class="od-form-group od-form-flex-05">
                    <label>Đã trả (K)</label>
                    <input asp-for="Tr" id="trField" type="number" class="od-form-control" step="any" placeholder="0" oninput="calculateTotal()">
                </div>
                <div class="od-form-group od-form-flex-05">
                    <label>Chưa trả (K)</label>
                    <input asp-for="Ct" id="ctField" type="number" class="od-form-control" step="any" placeholder="0" oninput="calculateTotal()">
                </div>
                <div class="od-form-group od-form-flex-05">
                    <label>Tổng cộng (K)</label>
                    <input asp-for="Amount" id="totalAmount" type="number" class="od-form-control od-total-amount-display" readonly placeholder="0">
                </div>
                <div class="od-form-group od-form-flex-15">
                    <label>Ghi Chú Đơn Hàng</label>
                    <input asp-for="Note" type="text" class="od-form-control" placeholder="Ghi chú nhanh cho đơn hàng này...">
                </div>
            </div>
        </div>
    </form>

    <div class="od-form-row od-mt-20 od-justify-between od-align-center">
        <a asp-action="List" class="od-btn od-btn-secondary od-bg-dark">⬅ Quay lại danh sách</a>
        <input type="submit" form="orderForm" value="💾 Lưu Đơn Hàng" class="od-btn od-btn-success od-btn-submit-create" @(ViewBag.HasActiveShift == false ? "disabled" : "")>
    </div>
</div>

@if (ViewBag.HasActiveShift == false)
{
    <div id="shiftRequiredModal" class="od-modal-blur">
        <div class="od-modal-content">
            <div class="od-modal-icon-large">⏰</div>
            <h2 class="od-modal-title">Chưa Vào Ca Làm Việc!</h2>
            <p class="od-modal-text">Bạn cần phải bắt đầu ca làm việc trước khi có thể nhập hàng mới vào hệ thống.</p>
            <form asp-controller="Home" asp-action="StartShift" method="POST">
                <button type="submit" class="od-btn od-btn-primary od-btn-start-shift">
                    🚀 Bắt Đầu Ca Ngay
                </button>
            </form>
            <div class="od-mt-20">
                <a asp-action="List" class="od-link-muted">Quay lại danh sách</a>
            </div>
        </div>
    </div>
}

<script>
    function calculateTotal() {
        var trInp = document.getElementById("trField");
        var ctInp = document.getElementById("ctField");
        
        var tr = parseFloat(trInp.value) || 0;
        var ct = parseFloat(ctInp.value) || 0;

        // Nếu đang nhập Tr > 0 thì reset Ct và ngược lại (Ràng buộc không nhập cả 2)
        if (document.activeElement.id === "trField" && tr > 0) {
            ctInp.value = "";
            ct = 0;
        } else if (document.activeElement.id === "ctField" && ct > 0) {
            trInp.value = "";
            tr = 0;
        }

        document.getElementById("totalAmount").value = tr + ct;
    }

    function validateForm() {
        var sPhone = document.getElementById("senderPhone").value.trim();
        var rPhone = document.getElementById("receiverPhone").value.trim();
        var send = document.getElementById("sendStation").value;
        var receive = document.getElementById("receiveStation").value;
        
        var tr = parseFloat(document.getElementById("trField").value) || 0;
        var ct = parseFloat(document.getElementById("ctField").value) || 0;

        // Ràng buộc 1 trong 2 phải có giá trị > 0
        if (tr <= 0 && ct <= 0) {
            Swal.fire({ icon: 'error', title: 'Thiếu thông tin phí', text: 'Bạn phải nhập số tiền vào ô Đã trả hoặc Chưa trả!' });
            return false;
        }

        // Ràng buộc không được cả 2 cùng > 0
        if (tr > 0 && ct > 0) {
            Swal.fire({ icon: 'error', title: 'Lỗi nhập phí', text: 'Không được phép nhập cả hai ô Đã trả và Chưa trả cùng lúc!' });
            return false;
        }

        if (send === receive && send !== "") {
            Swal.fire({ icon: 'error', title: 'Trùng trạm', text: 'Trạm gửi và trạm nhận không được trùng nhau!' });
            return false;
        }

        var phoneRegex = /^\d{10,11}$/;
        if (!phoneRegex.test(sPhone) || !phoneRegex.test(rPhone)) {
            Swal.fire({ icon: 'warning', title: 'SĐT không hợp lệ', text: 'Số điện thoại phải là chữ số và có độ dài từ 10 đến 11 ký tự!' });
            return false;
        }

        const submitBtn = document.querySelector('input[type="submit"][form="orderForm"]');
        if (submitBtn) {
            submitBtn.disabled = true;
            submitBtn.value = "⌛ Đang lưu...";
        }

        return true;
    }
</script>
