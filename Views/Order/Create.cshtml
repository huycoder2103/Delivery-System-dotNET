@model Delivery_System.Models.TblOrder

@{
    ViewData["Title"] = "Nhập Hàng Mới";
    var stationList = ViewBag.StationList as IEnumerable<Delivery_System.Models.TblStation>;
}

@section Styles {
    <link rel="stylesheet" href="~/css/create_order.css?v=@DateTime.Now.Ticks" />
}

<div class="order-container-modern @(ViewBag.HasActiveShift == false ? "content-blurred" : "")">
    <form id="orderForm" asp-action="Create" method="POST" onsubmit="return validateForm()">
        <div class="modern-page-header">
            <div>
                <h2>📦 NHẬP ĐƠN HÀNG MỚI</h2>
                <div class="modern-page-header-desc">Điền đầy đủ thông tin đơn hàng bên dưới</div>
            </div>
        </div>

        <div asp-validation-summary="All" class="text-danger mb-20"></div>

        <div class="modern-card">
            <div class="section-title">✨ Thông tin hàng hóa</div>
            <div class="form-group">
                <label>Tên Hàng Gửi <span class="required-star">*</span></label>
                <input asp-for="ItemName" type="text" required placeholder="Nhập tên hàng hóa...">
                <span asp-validation-for="ItemName" class="text-danger"></span>
            </div>

            <div class="form-row form-row-mt-20">
                <div class="form-group">
                    <label>Trạm Gửi <span class="required-star">*</span></label>
                    <select asp-for="SendStation" id="sendStation" required disabled="@(!User.IsInRole("AD"))">
                        <option value="">-- Chọn Trạm Gửi --</option>
                        @if (stationList != null)
                        {
                            foreach (var s in stationList)
                            {
                                bool isUserStation = (s.StationName == ViewBag.UserStationName);
                                <option value="@s.StationName" selected="@(isUserStation)">@s.StationName (@s.StationId)</option>
                            }
                        }
                    </select>
                    @if (!User.IsInRole("AD"))
                    {
                        <input type="hidden" asp-for="SendStation" value="@ViewBag.UserStationName" />
                    }
                    <span asp-validation-for="SendStation" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label>Trạm Nhận <span class="required-star">*</span></label>
                    <select asp-for="ReceiveStation" id="receiveStation" required>
                        <option value="">-- Chọn Trạm Nhận --</option>
                        @if (stationList != null)
                        {
                            foreach (var s in stationList)
                            {
                                if (!User.IsInRole("AD") && s.StationName == ViewBag.UserStationName) continue;
                                <option value="@s.StationName">@s.StationName (@s.StationId)</option>
                            }
                        }
                    </select>
                    <span asp-validation-for="ReceiveStation" class="text-danger"></span>
                </div>
            </div>
        </div>

        <div class="modern-card">
            <div class="section-title">👤 Thông tin khách hàng</div>
            <div class="form-row">
                <div class="form-group">
                    <label>Người Gửi</label>
                    <input asp-for="SenderName" type="text" placeholder="Tên khách hàng gửi...">
                </div>
                <div class="form-group">
                    <label>Số Điện Thoại Gửi <span class="required-star">*</span></label>
                    <input asp-for="SenderPhone" id="senderPhone" type="text" required maxlength="11" minlength="10" pattern="\d{10,11}" placeholder="Nhập SĐT người gửi...">
                    <span asp-validation-for="SenderPhone" class="text-danger"></span>
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label>Người Nhận</label>
                    <input asp-for="ReceiverName" type="text" placeholder="Tên khách hàng nhận...">
                </div>
                <div class="form-group">
                    <label>Số Điện Thoại Nhận <span class="required-star">*</span></label>
                    <input asp-for="ReceiverPhone" id="receiverPhone" type="text" required maxlength="11" minlength="10" pattern="\d{10,11}" placeholder="Nhập SĐT người nhận...">
                    <span asp-validation-for="ReceiverPhone" class="text-danger"></span>
                </div>
            </div>
        </div>

        <div class="modern-card">
            <div class="section-title">💰 Thanh toán & Ghi chú</div>
            <div class="form-row">
                <div class="form-group">
                    <label>Đã Thanh Toán (Tr) - Đơn vị K</label>
                    <input asp-for="Tr" id="trField" type="number" step="any" placeholder="0">
                    <span asp-validation-for="Tr" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label>Chưa Thanh Toán (Ct) - Đơn vị K</label>
                    <input asp-for="Ct" id="ctField" type="number" step="any" placeholder="0">
                    <span asp-validation-for="Ct" class="text-danger"></span>
                </div>
            </div>

            <div class="form-group">
                <label>Ghi Chú Đơn Hàng</label>
                <textarea asp-for="Note" rows="3" placeholder="Nhập các lưu ý đặc biệt về hàng hóa..."></textarea>
            </div>
        </div>
    </form>

    <div class="footer-actions-between">
        <a asp-action="List" class="btn-modern-back no-decoration">⬅ Quay lại danh sách</a>
        <input type="submit" form="orderForm" value="💾 Lưu Đơn Hàng" class="btn-modern-save btn-footer-save" @(ViewBag.HasActiveShift == false ? "disabled" : "")>
    </div>
</div>

@if (ViewBag.HasActiveShift == false)
{
    <div id="shiftRequiredModal" class="modal-backdrop-blur">
        <div class="modal-content-rounded">
            <div class="modal-icon-large">⏰</div>
            <h2 class="modal-title-bold">Chưa Vào Ca Làm Việc!</h2>
            <p class="modal-text-muted">Bạn cần phải bắt đầu ca làm việc trước khi có thể nhập hàng mới vào hệ thống.</p>
            <form asp-controller="Home" asp-action="StartShift" method="POST">
                <button type="submit" class="btn-full-modern">
                    🚀 Bắt Đầu Ca Ngay
                </button>
            </form>
            <div>
                <a asp-action="List" class="back-link-muted">Quay lại danh sách</a>
            </div>
        </div>
    </div>
}

<script>
    function validateForm() {
        var sPhone = document.getElementById("senderPhone").value.trim();
        var rPhone = document.getElementById("receiverPhone").value.trim();
        var send = document.getElementById("sendStation").value;
        var receive = document.getElementById("receiveStation").value;

        if (send === receive && send !== "") {
            Swal.fire({ icon: 'error', title: 'Trùng trạm', text: 'Trạm gửi và trạm nhận không được trùng nhau!' });
            return false;
        }

        var phoneRegex = /^\d{10,11}$/;
        if (!phoneRegex.test(sPhone) || !phoneRegex.test(rPhone)) {
            Swal.fire({ icon: 'warning', title: 'SĐT không hợp lệ', text: 'Số điện thoại phải là chữ số và có độ dài từ 10 đến 11 ký tự!' });
            return false;
        }

        const submitBtn = document.querySelector('input[type="submit"][form="orderForm"]');
        if (submitBtn) {
            submitBtn.disabled = true;
            submitBtn.value = "⌛ Đang lưu...";
        }

        return true;
    }
</script>
