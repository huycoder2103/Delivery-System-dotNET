@model Delivery_System.Models.TblOrder

@{
    ViewData["Title"] = "Nhập Hàng Gửi";
    var stationList = ViewBag.StationList as IEnumerable<Delivery_System.Models.TblStation>;
}

@section Styles {
    <link rel="stylesheet" href="~/css/create_order.css" />
}

<div class="order-container">
    <div class="order-header">
        <h2>NHẬP HÀNG GỬI</h2>
    </div>

    <form asp-action="Create" method="POST" onsubmit="return validateOrderForm()">
        <div class="order-toolbar">
            <span>Thông tin hàng gửi mới</span>
            <input type="submit" value="Lưu đơn hàng" class="btn-save">
        </div>

        <div class="form-body">
            <div class="form-group">
                <label>Tên Hàng Gửi <span style="color:red">*</span></label>
                <input asp-for="ItemName" type="text" placeholder="Nhập Tên Hàng Gửi..." required>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label>Trạm Gửi</label>
                    <select asp-for="SendStation" id="sendStation" required>
                        <option value="">-- Chọn Trạm Gửi --</option>
                        @if (stationList != null)
                        {
                            foreach (var s in stationList)
                            {
                                <option value="@s.StationName">@s.StationName</option>
                            }
                        }
                    </select>
                </div>
                <div class="form-group">
                    <label>Trạm Nhận</label>
                    <select asp-for="ReceiveStation" id="receiveStation" required>
                        <option value="">-- Chọn Trạm Nhận --</option>
                        @if (stationList != null)
                        {
                            foreach (var s in stationList)
                            {
                                <option value="@s.StationName">@s.StationName</option>
                            }
                        }
                    </select>
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label>Người Gửi</label>
                    <input asp-for="SenderName" type="text" placeholder="Tên người gửi...">
                </div>
                <div class="form-group">
                    <label>SĐT Gửi <span style="color:red">*</span></label>
                    <input asp-for="SenderPhone" id="senderPhone" type="text" required placeholder="SĐT người gửi...">
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label>Người Nhận</label>
                    <input asp-for="ReceiverName" type="text" placeholder="Tên người nhận...">
                </div>
                <div class="form-group">
                    <label>SĐT Nhận <span style="color:red">*</span></label>
                    <input asp-for="ReceiverPhone" id="receiverPhone" type="text" required placeholder="SĐT người nhận...">
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label>Đã Thanh Toán (Tr)</label>
                    <input asp-for="Tr" id="trField" type="text" placeholder="Ví dụ: 50">
                </div>
                <div class="form-group">
                    <label>Chưa Thanh Toán (Ct)</label>
                    <input asp-for="Ct" id="ctField" type="text" placeholder="Ví dụ: 100">
                </div>
            </div>

            <div class="form-group">
                <label>Ghi Chú</label>
                <textarea asp-for="Note" rows="3" placeholder="Ghi chú nếu có..."></textarea>
            </div>
        </div>
    </form>
</div>

<div class="back-container">
    <a asp-action="List" class="btn-back" style="text-decoration:none; display:inline-block; text-align:center;">⬅ Quay lại</a>
</div>

<script>
    function validateOrderForm() {
        var tr = document.getElementById("trField").value.trim();
        var ct = document.getElementById("ctField").value.trim();
        var sPhone = document.getElementById("senderPhone").value.trim();
        var rPhone = document.getElementById("receiverPhone").value.trim();
        var send = document.getElementById("sendStation").value;
        var receive = document.getElementById("receiveStation").value;

        if (send === receive && send !== "") {
            alert("❌ Trạm gửi và trạm nhận không được trùng nhau!");
            return false;
        }

        if (sPhone === "" || rPhone === "") {
            alert("❌ Số điện thoại người gửi và người nhận không được để trống!");
            return false;
        }

        if (tr === "" && ct === "") {
            alert("❌ Bạn phải nhập thông tin tiền thanh toán (Tr) hoặc chưa thanh toán (Ct)!");
            return false;
        }
        return true;
    }
</script>
