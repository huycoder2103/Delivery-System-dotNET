@model IEnumerable<Delivery_System.Models.TblOrder>

@{
    ViewData["Title"] = "Thùng Rác Đơn Hàng";
}

@section Styles {
    <link rel="stylesheet" href="~/css/list_order.css?v=@DateTime.Now.Ticks">
}

<div class="od-container od-container-trash">
    <div class="od-page-header od-page-header-trash">
        <div>
            <h3>🗑️ Thùng Rác Đơn Hàng</h3>
            <div class="od-header-meta">Danh sách đơn hàng đã bị xóa tạm thời</div>
        </div>
        <a asp-action="List" class="od-btn od-btn-header">📦 Quay lại Danh Sách</a>
    </div>

    <div class="od-card od-card-table">
        <table class="od-table">
            <thead>
                <tr>
                    <th>Mã Đơn</th>
                    <th>Tên Hàng</th>
                    <th>Người Gửi</th>
                    <th>Người Nhận</th>
                    <th>Trạm Gửi</th>
                    <th>Trạm Nhận</th>
                    <th>Ngày Xóa</th>
                    <th>Thao Tác</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var o in Model)
                    {
                        <tr>
                            <td><span class="od-font-bold" style="color: var(--od-danger);">@o.OrderId</span></td>
                            <td class="od-col-item">@o.ItemName</td>
                            <td>@o.SenderName</td>
                            <td>@o.ReceiverName</td>
                            <td>@o.SendStation</td>
                            <td>@o.ReceiveStation</td>
                            <td style="font-size:0.75rem; color:#888;">@o.CreatedAt?.ToString("dd/MM/yyyy HH:mm")</td>
                            <td class="od-col-act">
                                <div style="display:flex; gap:5px; justify-content:center;">
                                    <form asp-action="Restore" asp-route-id="@o.OrderId" method="POST">
                                        <button type="submit" class="od-btn-s od-btn-s-restore" title="Khôi phục">🔄</button>
                                    </form>
                                    <button type="button" class="od-btn-s od-btn-s-delete" onclick="confirmHardDelete('@o.OrderId')" title="Xóa vĩnh viễn">🗑️</button>
                                    
                                    <form id="hardDeleteForm-@o.OrderId" asp-action="HardDelete" method="POST" style="display:none;">
                                        <input type="hidden" name="id" value="@o.OrderId" />
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="8" class="od-empty-state">Thùng rác trống rỗng.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        function confirmHardDelete(id) {
            Swal.fire({
                title: 'Xóa vĩnh viễn?',
                text: "Đơn hàng này sẽ bị xóa khỏi hệ thống và không thể khôi phục!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#3085d6',
                confirmButtonText: 'Xóa luôn!',
                cancelButtonText: 'Hủy'
            }).then((result) => {
                if (result.isConfirmed) {
                    document.getElementById('hardDeleteForm-' + id).submit();
                }
            })
        }
    </script>
}
