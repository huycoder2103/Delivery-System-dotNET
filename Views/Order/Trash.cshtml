@model IEnumerable<Delivery_System.Models.TblOrder>

@{
    ViewData["Title"] = "Thùng Rác Đơn Hàng";
}

@section Styles {
    <link rel="stylesheet" href="~/css/list_order.css?v=@DateTime.Now.Ticks">
}

<div class="trash-container">
    <div class="modern-page-header">
        <div>
            <h3>🗑️ Thùng Rác Đơn Hàng</h3>
            <div class="trash-subtitle">Danh sách đơn hàng đã bị xóa tạm thời</div>
        </div>
        <a asp-action="List" class="btn-back">📦 Quay lại Danh Sách</a>
    </div>

    <div class="modern-card trip-table-card">
        <table class="modern-table">
            <thead>
                <tr>
                    <th>Mã Đơn</th>
                    <th>Tên Hàng</th>
                    <th>Người Gửi</th>
                    <th>Người Nhận</th>
                    <th>Trạm Gửi</th>
                    <th>Trạm Nhận</th>
                    <th>Ngày Xóa</th>
                    <th>Thao Tác</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var o in Model)
                    {
                        <tr>
                            <td><span class="text-order-id">@o.OrderId</span></td>
                            <td class="col-item-name">@o.ItemName</td>
                            <td class="col-customer">@o.SenderName</td>
                            <td class="col-customer">@o.ReceiverName</td>
                            <td class="col-staff">@o.SendStation</td>
                            <td class="col-staff">@o.ReceiveStation</td>
                            <td class="time-cell">@o.CreatedAt?.ToString("dd/MM/yyyy HH:mm")</td>
                            <td class="col-act">
                                <div class="action-flex-gap">
                                    <form asp-action="Restore" asp-route-id="@o.OrderId" method="POST">
                                        <button type="submit" class="btn-action-text btn-s-edit" title="Khôi phục">🔄</button>
                                    </form>
                                    <button type="button" class="btn-action-text btn-s-delete" onclick="confirmHardDelete('@o.OrderId')" title="Xóa vĩnh viễn">🗑️</button>
                                    
                                    <form id="hardDeleteForm-@o.OrderId" asp-action="HardDelete" method="POST" class="hidden-form">
                                        <input type="hidden" name="id" value="@o.OrderId" />
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="8" class="no-trash-msg">Thùng rác trống rỗng.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        function confirmHardDelete(id) {
            Swal.fire({
                title: 'Xóa vĩnh viễn?',
                text: "Đơn hàng này sẽ bị xóa khỏi hệ thống và không thể khôi phục!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#3085d6',
                confirmButtonText: 'Xóa luôn!',
                cancelButtonText: 'Hủy'
            }).then((result) => {
                if (result.isConfirmed) {
                    document.getElementById('hardDeleteForm-' + id).submit();
                }
            })
        }
    </script>
}
