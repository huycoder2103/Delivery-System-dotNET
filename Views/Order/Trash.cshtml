@model IEnumerable<Delivery_System.Models.TblOrder>

@{
    ViewData["Title"] = "Thùng Rác Đơn Hàng";
}

@section Styles {
    <link rel="stylesheet" href="~/css/trash_order.css" />
}

<div class="trash-container">
    
    <div class="trash-page-header">
        <div>
            <h3>🗑 THÙNG RÁC ĐƠN HÀNG</h3>
            <div class="trash-page-header-desc">Danh sách đơn hàng đã bị xóa tạm thời</div>
        </div>
        <a asp-action="List" class="btn-modern-back">📦 Quay lại Danh Sách</a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert-success-modern">✅ @TempData["SuccessMessage"]</div>
    }

    <div class="modern-card-trash">
        <table class="trash-table">
            <thead>
                <tr>
                    <th>Mã Đơn</th>
                    <th>Tên Hàng</th>
                    <th>Trạm Gửi</th>
                    <th>Trạm Nhận</th>
                    <th>Người Gửi</th>
                    <th>Người Nhận</th>
                    <th>Thao Tác</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var o in Model)
                    {
                        <tr>
                            <td><strong>@o.OrderId</strong></td>
                            <td>@o.ItemName</td>
                            <td>@o.SendStation</td>
                            <td>@o.ReceiveStation</td>
                            <td>@o.SenderName <br><small>@o.SenderPhone</small></td>
                            <td>@o.ReceiverName <br><small>@o.ReceiverPhone</small></td>
                            <td>
                                <div class="trash-actions-group">
                                    <form asp-action="Restore" method="POST">
                                        <input type="hidden" name="id" value="@o.OrderId" />
                                        <button type="submit" class="btn-restore">🔄 Khôi phục</button>
                                    </form>
                                    <form id="hardDeleteForm-@o.OrderId" asp-action="HardDelete" method="POST" style="display:none;">
                                        <input type="hidden" name="id" value="@o.OrderId" />
                                    </form>
                                    <button type="button" class="btn-hard-delete" onclick="confirmHardDelete('@o.OrderId')">💀 Xóa vĩnh viễn</button>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="8" class="trash-no-data-cell">Thùng rác trống rỗng.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<script>
    function confirmHardDelete(id) {
        Swal.fire({
            title: 'Xóa vĩnh viễn?',
            text: "Dữ liệu đơn hàng " + id + " sẽ không thể khôi phục lại!",
            icon: 'error',
            showCancelButton: true,
            confirmButtonColor: '#d33',
            cancelButtonColor: '#3085d6',
            confirmButtonText: '💀 Xóa ngay',
            cancelButtonText: 'Hủy'
        }).then((result) => {
            if (result.isConfirmed) {
                document.getElementById('hardDeleteForm-' + id).submit();
            }
        })
    }
</script>
