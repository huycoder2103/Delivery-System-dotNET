@model IEnumerable<Delivery_System.Models.TblOrder>

@{
    ViewData["Title"] = "Danh Sách Đơn Hàng";
    var currentUserRole = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value;
    var currentUserID = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
    var stationList = ViewBag.StationList as IEnumerable<Delivery_System.Models.TblStation>;
}

@section Styles {
    <link rel="stylesheet" href="~/css/list_order.css" />
}

<div class="order-list-container">
    
    <div class="modern-page-header">
        <div>
            <h3>📦 Quản Lý Đơn Hàng</h3>
            <div id="orderCount" class="modern-page-header-meta">Tổng: @(Model?.Count() ?? 0) đơn</div>
        </div>
        
        <div class="header-actions">
            <a asp-controller="Trip" asp-action="List" class="btn-modern btn-header-action">
                📤 Chuyến Xe Đi
            </a>
            <a asp-controller="Trip" asp-action="ArrivalList" class="btn-modern btn-header-action">
                📥 Chuyến Xe Đến
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert-success">✅ @TempData["SuccessMessage"]</div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-danger-custom">❌ @TempData["ErrorMessage"]</div>
    }

    <div class="modern-card sticky-filter-bar">
        
        <div class="status-tab-group">
            <button class="btn-status-tab @(ViewBag.CurrentStatus == "all" ? "active" : "")" onclick="changeStatus('all')">
                🌐 Tất cả (@ViewBag.CountAll)
            </button>
            <button class="btn-status-tab @(ViewBag.CurrentStatus == "pending" ? "active" : "")" onclick="changeStatus('pending')">
                📥 Chờ giao (@ViewBag.CountPending)
            </button>
            <button class="btn-status-tab @(ViewBag.CurrentStatus == "shipped" ? "active" : "")" onclick="changeStatus('shipped')">
                🚛 Đang chuyển (@ViewBag.CountShipped)
            </button>
            <button class="btn-status-tab @(ViewBag.CurrentStatus == "delivered" ? "active" : "")" onclick="changeStatus('delivered')">
                ✅ Đã giao (@ViewBag.CountDelivered)
            </button>
        </div>

        <div class="filter-controls-group">
            <select id="filterSendStation" class="filter-input">
                <option value="">-- Từ Trạm (Gửi) --</option>
                @if (stationList != null)
                {
                    foreach (var s in stationList)
                    {
                        <option value="@s.StationName" selected="@(s.StationName == ViewBag.SendStationFilter ? "selected" : null)">@s.StationName (@s.StationId)</option>
                    }
                }            </select>

            <select id="filterReceiveStation" class="filter-input">
                <option value="">-- Đến Trạm (Nhận) --</option>
                @if (stationList != null)
                {
                    foreach (var s in stationList)
                    {
                        <option value="@s.StationName" selected="@(s.StationName == ViewBag.ReceiveStationFilter ? "selected" : null)">@s.StationName (@s.StationId)</option>
                    }
                }
            </select>

            <input type="date" id="filterDate" class="filter-input" value="@ViewBag.DateFilter">
            
            <div class="search-input-wrapper">
                <input type="text" id="filterSearchPhone" placeholder="Tìm SĐT hoặc Mã đơn..." 
                       value="@ViewBag.SearchPhone" class="search-input">
            </div>

            <a asp-action="Create" class="btn-modern btn-success-modern btn-link-modern" >➕ Nhập Hàng</a>
            <button onclick="resetFilters()" class="btn-modern btn-secondary-modern">🔄 Làm mới</button>
        </div>
    </div>

    <div class="modern-card table-wrapper">
        <table class="modern-table" id="orderTable">
            <thead>
                <tr>
                    <th class="col-id">Mã Đơn</th>
                    <th class="col-item-name">Tên Hàng</th>
                    <th class="col-route">Lộ trình</th>
                    <th class="col-customer">Người Gửi</th>
                    <th class="col-customer">Người Nhận</th>
                    <th class="col-staff">NV Nhập</th>
                    <th class="col-paid">TR</th>
                    <th class ="col-paid">CT</th>
                    <th class="col-note">Ghi chú</th>
                    <th class="col-time">Giờ Tạo</th>
                    <th class="col-act">Thao tác</th>
                </tr>
            </thead>
            <tbody id="orderTableBody">
                <partial name="_OrderTableBody" model="Model" />
            </tbody>
        </table>
    </div>

    <!-- Pagination Controls -->
    <div class="pagination-container">
        @if (ViewBag.TotalPages > 1)
        {
            var currentPage = (int)ViewBag.CurrentPage;
            var totalPages = (int)ViewBag.TotalPages;

            <button class="btn-modern btn-secondary-modern" onclick="changePage(@(currentPage - 1))" @(currentPage == 1 ? "disabled" : "")>
                « Trang trước
            </button>
            
            <div class="current-page">
                Trang @currentPage / @totalPages
            </div>

            <button class="btn-modern btn-secondary-modern" onclick="changePage(@(currentPage + 1))" @(currentPage == totalPages ? "disabled" : "")>
                Trang sau »
            </button>
        }
    </div>
</div>

@section Scripts {
    <script>
        let searchTimeout;
        let currentStatus = '@(ViewBag.CurrentStatus ?? "all")';
        let currentPage = @(ViewBag.CurrentPage ?? 1);

        // Add event listeners for filters
        document.getElementById('filterSendStation').addEventListener('change', () => { currentPage = 1; triggerSearch(); });
        document.getElementById('filterReceiveStation').addEventListener('change', () => { currentPage = 1; triggerSearch(); });
        document.getElementById('filterDate').addEventListener('change', () => { currentPage = 1; triggerSearch(); });
        document.getElementById('filterSearchPhone').addEventListener('input', function() {
            clearTimeout(searchTimeout);
            searchTimeout = setTimeout(() => {
                currentPage = 1;
                triggerSearch();
            }, 500);
        });

        function confirmDeleteOrder(orderId) {
            Swal.fire({
                title: 'Xóa đơn hàng?',
                text: "Xác nhận xóa đơn hàng " + orderId + "? Dữ liệu sẽ được đưa vào thùng rác.",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#3085d6',
                confirmButtonText: '🗑 Xóa ngay',
                cancelButtonText: 'Hủy'
            }).then((result) => {
                if (result.isConfirmed) {
                    document.getElementById('deleteOrderForm-' + orderId).submit();
                }
            })
        }

        function changeStatus(status) {
            currentStatus = status;
            currentPage = 1;
            triggerSearch();
        }

        function changePage(page) {
            currentPage = page;
            triggerSearch();
        }

        function showPrintOptions(orderId) {
            Swal.fire({
                title: 'CHỌN LOẠI IN',
                html: `Chọn định dạng in cho đơn hàng <b>${orderId}</b>`,
                icon: 'info',
                showCancelButton: true,
                showDenyButton: true,
                confirmButtonText: '🧾 In Biên Lai (K80)',
                denyButtonText: '📄 In Phơi Giao (A5)',
                cancelButtonText: 'Đóng',
                confirmButtonColor: '#1a73e8',
                denyButtonColor: '#e91e63',
                customClass: {
                    actions: 'my-actions',
                    cancelButton: 'order-1 right-gap',
                    confirmButton: 'order-2',
                    denyButton: 'order-3',
                },
            }).then((result) => {
                if (result.isConfirmed) {
                    window.open('/Order/PrintReceipt/' + orderId + '?type=receipt', '_blank');
                } else if (result.isDenied) {
                    window.open('/Order/PrintReceipt/' + orderId + '?type=delivery', '_blank');
                }
            })
        }

        function triggerSearch() {
            const sendStation = document.getElementById('filterSendStation').value;
            const receiveStation = document.getElementById('filterReceiveStation').value;
            const date = document.getElementById('filterDate').value;
            const phone = document.getElementById('filterSearchPhone').value;

            const url = `@Url.Action("List", "Order")?sendStationFilter=${encodeURIComponent(sendStation)}&receiveStationFilter=${encodeURIComponent(receiveStation)}&searchPhone=${encodeURIComponent(phone)}&dateFilter=${encodeURIComponent(date)}&statusFilter=${currentStatus}&page=${currentPage}`;
            
            window.location.href = url;
        }

        function resetFilters() {
            window.location.href = '@Url.Action("List", "Order")';
        }
    </script>
}
