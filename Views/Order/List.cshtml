@model IEnumerable<Delivery_System.Models.TblOrder>

@{
    ViewData["Title"] = "Danh Sách Đơn Hàng";
    var currentUserRole = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value;
    var currentUserID = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
    var stationList = ViewBag.StationList as IEnumerable<Delivery_System.Models.TblStation>;
}

@section Styles {
    <link rel="stylesheet" href="~/css/list_order.css?v=@DateTime.Now.Ticks" />
}

<div class="od-container">
    
    <div class="od-page-header">
        <div>
            <h3>📦 Quản Lý Đơn Hàng</h3>
            <div id="orderCount" class="od-header-meta">Tổng: @(Model?.Count() ?? 0) đơn</div>
        </div>
        
        <div class="od-header-actions">
            <a asp-controller="Trip" asp-action="List" class="od-btn od-btn-header">
                📤 Chuyến Xe Đi
            </a>
            <a asp-controller="Trip" asp-action="ArrivalList" class="od-btn od-btn-header">
                📥 Chuyến Xe Đến
            </a>
        </div>
    </div>

    <div class="od-card od-sticky-filter">
        
        <div class="od-status-tabs">
            <button class="od-tab-btn @(ViewBag.CurrentStatus == "all" ? "active" : "")" onclick="changeStatus('all')">
                🌐 Tất cả (@ViewBag.CountAll)
            </button>
            <button class="od-tab-btn @(ViewBag.CurrentStatus == "pending" ? "active" : "")" onclick="changeStatus('pending')">
                📥 Chờ giao (@ViewBag.CountPending)
            </button>
            <button class="od-tab-btn @(ViewBag.CurrentStatus == "shipped" ? "active" : "")" onclick="changeStatus('shipped')">
                🚛 Đang chuyển (@ViewBag.CountShipped)
            </button>
            <button class="od-tab-btn @(ViewBag.CurrentStatus == "delivered" ? "active" : "")" onclick="changeStatus('delivered')">
                ✅ Đã giao (@ViewBag.CountDelivered)
            </button>
        </div>
        <div class="od-filter-group">
            <select id="filterSendStation" class="od-filter-input od-select-station">
                <option value="">Trạm Gửi</option>
                @if (stationList != null)
                {
                    foreach (var s in stationList)
                    {
                        <option value="@s.StationName" selected="@(s.StationName == ViewBag.SendStationFilter ? "selected" : null)">@s.StationName (@s.StationId)</option>
                    }
                }
            </select>

            <select id="filterReceiveStation" class="od-filter-input od-select-station">
                <option value="">Trạm Nhận</option>
                @if (stationList != null)
                {
                    foreach (var s in stationList)
                    {
                        <option value="@s.StationName" selected="@(s.StationName == ViewBag.ReceiveStationFilter ? "selected" : null)">@s.StationName (@s.StationId)</option>
                    }
                }
            </select>

            <input type="date" id="filterDate" class="od-filter-input" value="@ViewBag.DateFilter">
            
            <div class="od-search-wrapper">
                <input type="text" id="filterSearchPhone" placeholder="Tìm..." 
                       value="@ViewBag.SearchPhone" class="od-search-input">
            </div>

            <a asp-action="Create" class="od-btn od-btn-success">➕ Nhập Hàng</a>
            <button onclick="resetFilters()" class="od-btn od-btn-secondary">🔄 Làm mới</button>
        </div>
    </div>

    <div class="od-card od-card-table">
        <table class="od-table" id="orderTable">
            <thead>
                <tr>
                    <th style="width: 40px;">STT</th>
                    <th class="od-col-id">Mã Đơn</th>
                    <th class="od-col-item">Tên Hàng</th>
                    <th class="od-col-route">Lộ trình</th>
                    <th class="od-col-customer">Người Gửi</th>
                    <th class="od-col-customer">Người Nhận</th>
                    <th class="od-col-staff">NV Nhập</th>
                    <th class="od-col-paid">TR</th>
                    <th class="od-col-paid">CT</th>
                    <th class="od-col-note">Ghi chú</th>
                    <th class="od-col-time">Giờ Tạo</th>
                    <th class="od-col-act">Thao tác</th>
                </tr>
            </thead>
            <tbody id="orderTableBody">
                <partial name="_OrderTableBody" model="Model" />
            </tbody>
        </table>
    </div>

    <!-- Pagination Controls -->
    <div class="od-pagination">
        @if (ViewBag.TotalPages > 1)
        {
            var currentPage = (int)ViewBag.CurrentPage;
            var totalPages = (int)ViewBag.TotalPages;

            <button class="od-btn od-btn-secondary" onclick="changePage(@(currentPage - 1))" @(currentPage == 1 ? "disabled" : "")>
                « Trang trước
            </button>
            
            <div class="od-page-info">
                Trang @currentPage / @totalPages
            </div>

            <button class="od-btn od-btn-secondary" onclick="changePage(@(currentPage + 1))" @(currentPage == totalPages ? "disabled" : "")>
                Trang sau »
            </button>
        }
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.1/signalr.min.js"></script>
    <script>
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/deliveryHub")
            .withAutomaticReconnect()
            .build();

        connection.on("UpdateOrderList", function () {
            const sendStation = document.getElementById('filterSendStation').value;
            const receiveStation = document.getElementById('filterReceiveStation').value;
            const date = document.getElementById('filterDate').value;
            const phone = document.getElementById('filterSearchPhone').value;

            const url = `@Url.Action("List", "Order")?sendStationFilter=${encodeURIComponent(sendStation)}&receiveStationFilter=${encodeURIComponent(receiveStation)}&searchPhone=${encodeURIComponent(phone)}&dateFilter=${encodeURIComponent(date)}&statusFilter=${currentStatus}&page=${currentPage}`;

            $.ajax({
                url: url,
                type: 'GET',
                headers: { "X-Requested-With": "XMLHttpRequest" },
                success: function (data) {
                    $('#orderTableBody').html(data);
                    const Toast = Swal.mixin({
                        toast: true,
                        position: 'top-end',
                        showConfirmButton: false,
                        timer: 2000,
                        timerProgressBar: true
                    });
                    Toast.fire({ icon: 'info', title: 'Danh sách đơn hàng vừa được cập nhật!' });
                }
            });
        });

        connection.start().catch(err => console.error(err.toString()));

        let searchTimeout;
        let currentStatus = '@(ViewBag.CurrentStatus ?? "all")';
        let currentPage = @(ViewBag.CurrentPage ?? 1);

        document.getElementById('filterSendStation').addEventListener('change', () => { currentPage = 1; triggerSearch(); });
        document.getElementById('filterReceiveStation').addEventListener('change', () => { currentPage = 1; triggerSearch(); });
        document.getElementById('filterDate').addEventListener('change', () => { currentPage = 1; triggerSearch(); });
        document.getElementById('filterSearchPhone').addEventListener('input', function() {
            clearTimeout(searchTimeout);
            searchTimeout = setTimeout(() => {
                currentPage = 1;
                triggerSearch();
            }, 500);
        });

        function confirmDeleteOrder(orderId) {
            Swal.fire({
                title: 'Xóa đơn hàng?',
                text: "Xác nhận xóa đơn hàng " + orderId + "? Dữ liệu sẽ được đưa vào thùng rác.",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#3085d6',
                confirmButtonText: '🗑 Xóa ngay',
                cancelButtonText: 'Hủy'
            }).then((result) => {
                if (result.isConfirmed) {
                    document.getElementById('deleteOrderForm-' + orderId).submit();
                }
            })
        }

        function changeStatus(status) {
            currentStatus = status;
            currentPage = 1;
            triggerSearch();
        }

        function changePage(page) {
            currentPage = page;
            triggerSearch();
        }

        function showPrintOptions(orderId) {
            Swal.fire({
                title: 'CHỌN LOẠI IN',
                html: `Chọn định dạng in cho đơn hàng <b>${orderId}</b>`,
                icon: 'info',
                showCancelButton: true,
                showDenyButton: true,
                confirmButtonText: '🧾 In Biên Lai (K80)',
                denyButtonText: '📄 In Phơi Giao (A5)',
                cancelButtonText: 'Đóng',
                confirmButtonColor: '#1a73e8',
                denyButtonColor: '#e91e63'
            }).then((result) => {
                if (result.isConfirmed) {
                    window.open('/Order/PrintReceipt/' + orderId + '?type=receipt', '_blank');
                } else if (result.isDenied) {
                    window.open('/Order/PrintReceipt/' + orderId + '?type=delivery', '_blank');
                }
            })
        }

        function triggerSearch() {
            const sendStation = document.getElementById('filterSendStation').value;
            const receiveStation = document.getElementById('filterReceiveStation').value;
            const date = document.getElementById('filterDate').value;
            const phone = document.getElementById('filterSearchPhone').value;
            const url = `@Url.Action("List", "Order")?sendStationFilter=${encodeURIComponent(sendStation)}&receiveStationFilter=${encodeURIComponent(receiveStation)}&searchPhone=${encodeURIComponent(phone)}&dateFilter=${encodeURIComponent(date)}&statusFilter=${currentStatus}&page=${currentPage}`;
            window.location.href = url;
        }

        function resetFilters() {
            window.location.href = '@Url.Action("List", "Order")';
        }
    </script>
}
