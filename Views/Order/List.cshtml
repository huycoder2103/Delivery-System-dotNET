@model IEnumerable<Delivery_System.Models.TblOrder>

@{
    ViewData["Title"] = "Danh Sách Đơn Hàng";
    var currentUserRole = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value;
    var currentUserID = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
    var stationList = ViewBag.StationList as IEnumerable<Delivery_System.Models.TblStation>;
}

@section Styles {
    <link rel="stylesheet" href="~/css/list_order.css" asp-append-version="true" />
}

<div class="od-container">
    @Html.AntiForgeryToken()
    
    <div class="od-page-header">
        <div>
            <h3>Quản Lý Đơn Hàng</h3>
            @* <div id="orderCount" class="od-header-meta">Tổng: @(Model?.Count() ?? 0) đơn</div> *@
        </div>
        
        <div class="od-header-actions">
            <a asp-controller="Trip" asp-action="List" class="od-btn od-btn-header">
                Chuyến Xe Đi
            </a>
            <a asp-controller="Trip" asp-action="ArrivalList" class="od-btn od-btn-header">
                Chuyến Xe Đến
            </a>
        </div>
    </div>

    <div class="od-card od-sticky-filter">
        <div class="od-filter-group">
            <select id="statusFilter" class="od-filter-input od-select-status" onchange="changeStatus(this.value)">
                <option value="all" selected="@(ViewBag.CurrentStatus == "all" ? "selected" : null)">Tất cả đơn (@ViewBag.CountAll)</option>
                <option value="waiting" selected="@(ViewBag.CurrentStatus == "waiting" ? "selected" : null)">⏳ Chờ xe (@ViewBag.CountWaiting)</option>
                <option value="shipping" selected="@(ViewBag.CurrentStatus == "shipping" ? "selected" : null)">🚛 Đang chuyển (@ViewBag.CountShipping)</option>
                <option value="arrived" selected="@(ViewBag.CurrentStatus == "arrived" ? "selected" : null)">📥 Chờ giao (@ViewBag.CountArrived)</option>
                <option value="delivered" selected="@(ViewBag.CurrentStatus == "delivered" ? "selected" : null)">✅ Đã giao (@ViewBag.CountDelivered)</option>
            </select>
            <select id="filterSendStation" class="od-filter-input od-select-station">
                <option value="">Trạm Gửi</option>
                @if (stationList != null)
                {
                    foreach (var s in stationList)
                    {
                        <option value="@s.StationName" selected="@(s.StationName == ViewBag.SendStationFilter ? "selected" : null)">@s.StationName (@s.StationId)</option>
                    }
                }
            </select>

            <select id="filterReceiveStation" class="od-filter-input od-select-station">
                <option value="">Trạm Nhận</option>
                @if (stationList != null)
                {
                    foreach (var s in stationList)
                    {
                        <option value="@s.StationName" selected="@(s.StationName == ViewBag.ReceiveStationFilter ? "selected" : null)">@s.StationName (@s.StationId)</option>
                    }
                }
            </select>

            <input type="date" id="filterDate" class="od-filter-input" value="@ViewBag.DateFilter">
            
            <div class="od-search-wrapper">
                <i class="bi bi-search"></i>
                <input type="text" id="filterSearchPhone" placeholder="Tìm id, sđt..."
                       value="@(string.IsNullOrEmpty(ViewBag.SearchStaff) ? ViewBag.SearchPhone : ViewBag.SearchStaff)" class="od-search-input">
            </div>

            <div class="od-filter-actions">
                <button onclick="resetFilters()" class="od-btn od-btn-secondary"><i class="bi bi-arrow-repeat"></i> Làm mới</button>
                <a asp-action="Create" class="od-btn od-btn-success od-btn-s-ship">Nhập Hàng</a>
            </div>
        </div>
    </div>

    <div class="od-card od-card-table">
        <table class="od-table" id="orderTable">
            <thead>
                <tr>
                    <th class="od-w-40">STT</th>
                    <th class="od-col-id">Mã Đơn</th>
                    <th class="od-col-item">Tên Hàng</th>
                    <th class="od-col-route">Lộ trình</th>
                    <th class="od-col-customer">Người Gửi</th>
                    <th class="od-col-customer">Người Nhận</th>
                    <th class="od-col-staff">NV Nhập</th>
                    <th class="od-col-paid">TR</th>
                    <th class="od-col-paid">CT</th>
                    <th class="od-col-note">Ghi chú</th>
                    <th class="od-col-time">Giờ Tạo</th>
                    <th class="od-col-act">Thao tác</th>
                </tr>
            </thead>
            <tbody id="orderTableBody">
                <partial name="_OrderTableBody" model="Model" />
            </tbody>
        </table>
    </div>

    <!-- Pagination Controls -->
    <div class="od-pagination" id="paginationControls">
        @if (ViewBag.TotalPages > 1)
        {
            var currentPage = (int)ViewBag.CurrentPage;
            var totalPages = (int)ViewBag.TotalPages;

            <button class="od-btn od-btn-secondary" onclick="changePage(@(currentPage - 1))" @(currentPage == 1 ? "disabled" : "")>
                « Trang trước
            </button>

            <div class="od-page-info od-page-info-box">
                Trang @currentPage / @totalPages
            </div>

            <button class="od-btn od-btn-secondary" onclick="changePage(@(currentPage + 1))" @(currentPage == totalPages ? "disabled" : "")>
                Trang sau »
            </button>
        }
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.1/signalr.min.js"></script>
    <script>
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/deliveryHub")
            .withAutomaticReconnect()
            .build();

        let isProcessingSelf = false; // Biến kiểm soát ngăn chặn double toast

        connection.on("UpdateOrderList", function () {
            // Nếu chính mình vừa thao tác xong, không cần hiện Toast SignalR
            refreshDashboard(isProcessingSelf);
            isProcessingSelf = false; // Reset sau khi dùng
        });

        connection.start().then(() => {
            // Dùng Station ID thay cho Name để đảm bảo tính chính xác
            const userStationId = '@Delivery_System.Helpers.UserExtensions.GetStationId(User)';
            const userRole = '@(User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value)';
            connection.invoke("JoinStationGroup", userStationId, userRole);
        }).catch(err => console.error(err.toString()));

        let searchTimeout;
        let currentStatus = '@(ViewBag.CurrentStatus ?? "all")';
        let currentPage = @(ViewBag.CurrentPage ?? 1);
        let onlyCod = '@(ViewBag.OnlyCod?.ToString().ToLower() ?? "false")' === 'true';

        function refreshDashboard(skipToast = false) {
            const sendStation = document.getElementById('filterSendStation').value;
            const receiveStation = document.getElementById('filterReceiveStation').value;
            const date = document.getElementById('filterDate').value;
            const phone = document.getElementById('filterSearchPhone').value;

            const url = `@Url.Action("List", "Order")?sendStationFilter=${encodeURIComponent(sendStation)}&receiveStationFilter=${encodeURIComponent(receiveStation)}&searchPhone=${encodeURIComponent(phone)}&dateFilter=${encodeURIComponent(date)}&statusFilter=${currentStatus}&page=${currentPage}&onlyCod=${onlyCod}`;

            $.ajax({
                url: url,
                type: 'GET',
                headers: { "X-Requested-With": "XMLHttpRequest" },
                success: function (data) {
                    $('#orderTableBody').html(data);
                    
                    // CẬP NHẬT CÁC CON SỐ THỐNG KÊ (Giải pháp 2)
                    updateCounts();

                    // CẬP NHẬT PHÂN TRANG
                    const totalPages = parseInt($('#ajaxTotalPages').val()) || 1;
                    updatePagination(currentPage, totalPages);

                    if (!skipToast) {
                        const Toast = Swal.mixin({
                            toast: true,
                            position: 'top-end',
                            showConfirmButton: false,
                            timer: 2000,
                            timerProgressBar: true
                        });
                        Toast.fire({ icon: 'info', title: 'Danh sách đơn hàng vừa được cập nhật!' });
                    }
                }
            });
        }

        function updatePagination(page, total) {
            const container = document.getElementById('paginationControls');
            if (total <= 1) {
                container.innerHTML = '';
                return;
            }

            let html = `
                <button class="od-btn od-btn-secondary" onclick="changePage(${page - 1})" ${page === 1 ? 'disabled' : ''}>
                    « Trang trước
                </button>
                <div class="od-page-info od-page-info-box">
                    Trang ${page} / ${total}
                </div>
                <button class="od-btn od-btn-secondary" onclick="changePage(${page + 1})" ${page === total ? 'disabled' : ''}>
                    Trang sau »
                </button>
            `;
            container.innerHTML = html;
        }

        function updateCounts() {
            // Lấy dữ liệu từ các input ẩn trong PartialView
            const cAll = $('#ajaxCountAll').val();
            const cWaiting = $('#ajaxCountWaiting').val();
            const cShipping = $('#ajaxCountShipping').val();
            const cArrived = $('#ajaxCountArrived').val();
            const cDelivered = $('#ajaxCountDelivered').val();
            
            // Cập nhật text trong Select Status
            $("#statusFilter option[value='all']").text(`Tất cả đơn (${cAll})`);
            $("#statusFilter option[value='waiting']").text(`⏳ Chờ xe (${cWaiting})`);
            $("#statusFilter option[value='shipping']").text(`🚛 Đang chuyển (${cShipping})`);
            $("#statusFilter option[value='arrived']").text(`📥 Chờ giao (${cArrived})`);
            $("#statusFilter option[value='delivered']").text(`✅ Đã giao (${cDelivered})`);
            
            // Cập nhật text tổng ở header
            $('#orderCount').text(`Tổng: ${cAll} đơn`);
        }

        document.getElementById('filterSendStation').addEventListener('change', () => { currentPage = 1; triggerSearch(); });
        document.getElementById('filterReceiveStation').addEventListener('change', () => { currentPage = 1; triggerSearch(); });
        document.getElementById('filterDate').addEventListener('change', () => { currentPage = 1; triggerSearch(); });
        document.getElementById('filterSearchPhone').addEventListener('input', function() {
            clearTimeout(searchTimeout);
            if (this.value.trim() === "") {
                currentPage = 1;
                triggerSearch();
            } else {
                searchTimeout = setTimeout(() => {
                    currentPage = 1;
                    triggerSearch();
                }, 500);
            }
        });

        function confirmDeleteOrder(orderId) {
            Swal.fire({
                title: 'Xóa đơn hàng?',
                text: "Xác nhận xóa đơn hàng " + orderId + "? Dữ liệu sẽ được đưa vào thùng rác.",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#3085d6',
                confirmButtonText: '🗑 Xóa ngay',
                cancelButtonText: 'Hủy'
            }).then((result) => {
                if (result.isConfirmed) {
                    isProcessingSelf = true;
                    document.getElementById('deleteOrderForm-' + orderId).submit();
                }
            })
        }

        function changeStatus(status) {
            currentStatus = status;
            currentPage = 1;
            triggerSearch();
        }

        function changePage(page) {
            currentPage = page;
            triggerSearch();
        }

        function showPrintOptions(orderId, status) {
            if (status === 'Đã giao') {
                window.open('/Order/PrintReceipt/' + orderId + '?type=delivered', '_blank');
                return;
            }

            Swal.fire({
                title: 'CHỌN LOẠI IN',
                html: `Chọn định dạng in cho đơn hàng <b>${orderId}</b>`,
                icon: 'info',
                showCancelButton: true,
                showDenyButton: true,
                confirmButtonText: '🧾 In Biên Lai (K80)',
                denyButtonText: '📄 In Phơi Giao (A5)',
                cancelButtonText: 'Đóng',
                confirmButtonColor: '#1a73e8',
                denyButtonColor: '#e91e63'
            }).then((result) => {
                if (result.isConfirmed) {
                    window.open('/Order/PrintReceipt/' + orderId + '?type=receipt', '_blank');
                } else if (result.isDenied) {
                    window.open('/Order/PrintReceipt/' + orderId + '?type=delivery', '_blank');
                }
            })
        }

        function triggerSearch() {
            // CHUYỂN SANG DÙNG AJAX ĐỂ TRANG KHÔNG BỊ LOAD LẠI
            refreshDashboard(true);
            
            // Cập nhật URL trình duyệt (không reload) để người dùng có thể copy link hoặc F5
            const sendStation = document.getElementById('filterSendStation').value;
            const receiveStation = document.getElementById('filterReceiveStation').value;
            const date = document.getElementById('filterDate').value;
            const phone = document.getElementById('filterSearchPhone').value;
            const newUrl = `@Url.Action("List", "Order")?sendStationFilter=${encodeURIComponent(sendStation)}&receiveStationFilter=${encodeURIComponent(receiveStation)}&searchPhone=${encodeURIComponent(phone)}&dateFilter=${encodeURIComponent(date)}&statusFilter=${currentStatus}&page=${currentPage}&onlyCod=${onlyCod}`;
            window.history.pushState({path:newUrl},'',newUrl);
        }

        function resetFilters() {
            window.location.href = '@Url.Action("List", "Order")';
        }

        function deliverOrderDirect(orderId) {
            Swal.fire({
                title: 'Xác nhận giao hàng?',
                text: `Đơn hàng ${orderId} đã được khách đến nhận?`,
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: '#28a745',
                cancelButtonColor: '#6c757d',
                confirmButtonText: '✅ Đúng, đã giao!',
                cancelButtonText: 'Hủy'
            }).then((result) => {
                if (result.isConfirmed) {
                    isProcessingSelf = true; // Đánh dấu mình đang thao tác
                    const token = $('input[name="__RequestVerificationToken"]').val();
                    $.ajax({
                        url: '@Url.Action("Deliver", "Order")',
                        type: 'POST',
                        data: { 
                            id: orderId,
                            __RequestVerificationToken: token
                        },
                        success: function (res) {
                            if (res.success) {
                                Swal.fire({
                                    title: 'Thành công!',
                                    text: res.message,
                                    icon: 'success',
                                    timer: 1500,
                                    showConfirmButton: false
                                }).then(() => {
                                    if (res.tripId) {
                                        window.location.href = '@Url.Action("ViewGoods", "Trip")/' + res.tripId;
                                    } else {
                                        refreshDashboard(true); // Cập nhật lại dashboard bằng AJAX thay vì reload
                                    }
                                });
                            } else {
                                isProcessingSelf = false;
                                Swal.fire('Lỗi', res.message, 'error');
                            }
                        },
                        error: function (xhr) {
                            isProcessingSelf = false;
                            console.error(xhr.responseText);
                            Swal.fire('Lỗi', 'Không thể kết nối đến máy chủ hoặc lỗi xác thực.', 'error');
                        }
                    });
                }
            });
        }
    </script>

}
