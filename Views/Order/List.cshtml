@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor
@model IEnumerable<Delivery_System.Models.TblOrder>

@{
    ViewData["Title"] = "Danh Sách Đơn Hàng";
    var currentUserRole = HttpContextAccessor.HttpContext.Session.GetString("Role");
    var currentUserID = HttpContextAccessor.HttpContext.Session.GetString("UserID");
    var stationList = ViewBag.StationList as IEnumerable<Delivery_System.Models.TblStation>;
}

@section Styles {
    <link rel="stylesheet" href="~/css/list_order.css" />
}

<div class="order-list-container">
    
    <div class="modern-page-header">
        <div>
            <h3>📦 Quản Lý Đơn Hàng</h3>
            <div id="orderCount" class="modern-page-header-meta">Tổng: @(Model?.Count() ?? 0) đơn</div>
        </div>
        
        <div class="header-actions">
            <a asp-controller="Trip" asp-action="List" class="btn-modern btn-header-action">
                📤 Chuyến Xe Đi
            </a>
            <a asp-controller="Trip" asp-action="ArrivalList" class="btn-modern btn-header-action">
                📥 Chuyến Xe Đến
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert-success">✅ @TempData["SuccessMessage"]</div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-danger-custom">❌ @TempData["ErrorMessage"]</div>
    }

    <div class="modern-card sticky-filter-bar">
        
        <div class="status-tab-group">
            <button class="btn-status-tab @(ViewBag.CurrentStatus == "all" ? "active" : "")" onclick="changeStatus('all')">
                🌐 Tất cả đơn hàng
            </button>
            <button class="btn-status-tab @(ViewBag.CurrentStatus == "pending" ? "active" : "")" onclick="changeStatus('pending')">
                📥 Chờ giao (Tại kho)
            </button>
            <button class="btn-status-tab @(ViewBag.CurrentStatus == "shipped" ? "active" : "")" onclick="changeStatus('shipped')">
                🚛 Đã lên xe
            </button>
        </div>

        <div class="filter-controls-group">
            <select id="filterSendStation" class="filter-input">
                <option value="">-- Từ Trạm (Gửi) --</option>
                @if (stationList != null)
                {
                    foreach (var s in stationList)
                    {
                        <option value="@s.StationName">@s.StationName</option>
                    }
                }
            </select>

            <select id="filterReceiveStation" class="filter-input">
                <option value="">-- Đến Trạm (Nhận) --</option>
                @if (stationList != null)
                {
                    foreach (var s in stationList)
                    {
                        <option value="@s.StationName">@s.StationName</option>
                    }
                }
            </select>

            <input type="date" id="filterDate" class="filter-input">
            
            <div class="search-input-wrapper">
                <input type="text" id="filterSearchPhone" class="search-input" placeholder="Tìm SĐT hoặc Mã đơn..." 
                       value="@ViewBag.SearchPhone">
            </div>

            <a asp-action="Create" class="btn-modern btn-success-modern btn-link-modern">➕ Nhập Hàng</a>
            <a asp-action="Trash" class="btn-modern btn-secondary-modern btn-link-modern">🗑 Thùng rác</a>
            <button onclick="resetFilters()" class="btn-modern btn-secondary-modern">🔄 Làm mới</button>
        </div>
    </div>

    <div class="modern-card table-wrapper">
        <table class="modern-table" id="orderTable">
            <thead>
                <tr>
                    <th>Mã Đơn</th>
                    <th class="col-item-name">Tên Hàng</th>
                    <th class="col-station">Trạm Gửi</th>
                    <th class="col-station">Trạm Nhận</th>
                    <th class="col-customer">Người Gửi</th>
                    <th class="col-customer">Người Nhận</th>
                    <th>NV Nhập</th>
                    <th>Phí TR</th>
                    <th>Phí CT</th>
                    <th>Ghi chú</th>
                    <th>Thời Gian Tạo</th>
                    <th>Trạng thái</th>
                    <th>Thao tác</th>
                </tr>
            </thead>
            <tbody id="orderTableBody">
                <partial name="_OrderTableBody" model="Model" />
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        let searchTimeout;
        let currentStatus = '@(ViewBag.CurrentStatus ?? "all")';

        document.getElementById('filterSendStation').addEventListener('change', triggerSearch);
        document.getElementById('filterReceiveStation').addEventListener('change', triggerSearch);
        document.getElementById('filterDate').addEventListener('change', triggerSearch);
        document.getElementById('filterSearchPhone').addEventListener('input', function() {
            clearTimeout(searchTimeout);
            searchTimeout = setTimeout(triggerSearch, 300);
        });

        function changeStatus(status) {
            currentStatus = status;
            document.querySelectorAll('.btn-status-tab').forEach(btn => btn.classList.remove('active'));
            event.currentTarget.classList.add('active');
            triggerSearch();
        }

        function triggerSearch() {
            const sendStation = document.getElementById('filterSendStation').value;
            const receiveStation = document.getElementById('filterReceiveStation').value;
            const date = document.getElementById('filterDate').value;
            const phone = document.getElementById('filterSearchPhone').value;

            const tableBody = document.getElementById('orderTableBody');
            const tableContainer = document.getElementById('orderTable');
            tableContainer.classList.add('loading-overlay');

            const url = `@Url.Action("List", "Order")?sendStationFilter=${encodeURIComponent(sendStation)}&receiveStationFilter=${encodeURIComponent(receiveStation)}&searchPhone=${encodeURIComponent(phone)}&dateFilter=${encodeURIComponent(date)}&statusFilter=${currentStatus}`;

            fetch(url, { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
            .then(response => response.text())
            .then(html => {
                tableBody.innerHTML = html;
                tableContainer.classList.remove('loading-overlay');
                const rowCount = tableBody.querySelectorAll('tr:not(:has(.no-data-msg))').length;
                document.getElementById('orderCount').innerText = `Tổng: ${rowCount} đơn`;
            })
            .catch(err => {
                console.error('Error:', err);
                tableContainer.classList.remove('loading-overlay');
            });
        }

        function resetFilters() {
            document.getElementById('filterSendStation').value = '';
            document.getElementById('filterReceiveStation').value = '';
            document.getElementById('filterDate').value = '';
            document.getElementById('filterSearchPhone').value = '';
            currentStatus = 'all';
            document.querySelectorAll('.btn-status-tab').forEach(btn => btn.classList.remove('active'));
            document.querySelector('.btn-status-tab:first-child').classList.add('active');
            triggerSearch();
        }
    </script>
}
