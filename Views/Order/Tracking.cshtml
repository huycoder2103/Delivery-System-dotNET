@model Delivery_System.Models.TblOrder
@{
    Layout = null;
    var trip = ViewBag.TripInfo as Delivery_System.Models.TblTrip;
    
    // Hàm che số điện thoại: 036****978
    string MaskPhone(string phone) 
    {
        if (string.IsNullOrEmpty(phone) || phone.Length < 7) return phone;
        return phone.Substring(0, 3) + "****" + phone.Substring(phone.Length - 3);
    }

    string GetStatusClass(string status) {
        return status switch {
            "Chưa Chuyển" => "status-waiting",
            "Đang chuyển" => "status-shipping",
            "Đã đến" => "status-arrived",
            "Đã giao" => "status-delivered",
            _ => ""
        };
    }
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Tra cứu đơn hàng #@Model.OrderId</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/tracking.css?v=@DateTime.Now.Ticks">
</head>
<body>
    <div class="tracking-card">
        <div class="tracking-header">
            <h4 class="mb-0">TRẠNG THÁI VẬN CHUYỂN</h4>
            <small>Mã đơn: #@Model.OrderId</small>
        </div>
        <div class="tracking-body">
            <div class="text-center">
                <span class="status-badge @GetStatusClass(Model.ShipStatus)">
                    @(Model.ShipStatus == "Chưa Chuyển" ? "⏳ Chờ vận chuyển" : 
                      Model.ShipStatus == "Đang chuyển" ? "🚛 Đang trên đường" : 
                      Model.ShipStatus == "Đã đến" ? "📥 Đã tới trạm đích" : "✅ Đã giao thành công")
                </span>
            </div>

            <div class="row info-group">
                <div class="col-6">
                    <div class="info-label">Từ trạm</div>
                    <div class="info-value">📍 @Model.SendStation</div>
                </div>
                <div class="col-6">
                    <div class="info-label">Đến trạm</div>
                    <div class="info-value">📍 @Model.ReceiveStation</div>
                </div>
            </div>

            <div class="info-group">
                <div class="info-label">Tên hàng hóa</div>
                <div class="info-value">@Model.ItemName</div>
            </div>

            <div class="row info-group">
                <div class="col-6 border-end">
                    <div class="info-label">Người gửi</div>
                    <div class="info-value">👤 @Model.SenderName</div>
                    <div class="info-value text-muted small">📞 @MaskPhone(Model.SenderPhone)</div>
                </div>
                <div class="col-6 ps-3">
                    <div class="info-label">Người nhận</div>
                    <div class="info-value">👤 @Model.ReceiverName</div>
                    <div class="info-value text-muted small">📞 @MaskPhone(Model.ReceiverPhone)</div>
                </div>
            </div>

            <h6 class="mt-4 border-bottom pb-2">Lịch trình đơn hàng</h6>
            <div class="timeline">
                @if (Model.ShipStatus == "Đã giao")
                {
                    <div class="timeline-item">
                        <div class="timeline-dot timeline-dot-success"></div>
                        <div class="timeline-content">
                            <strong>Đã giao hàng</strong><br>
                            <span class="timeline-time">Thời gian: @Model.ReceiveDate</span>
                        </div>
                    </div>
                }

                @if (trip != null && trip.Status == "Đã đến")
                {
                    <div class="timeline-item">
                        <div class="timeline-dot"></div>
                        <div class="timeline-content">
                            <strong>Đã đến trạm: @Model.ReceiveStation</strong><br>
                            <span class="timeline-time">Đơn hàng đã sẵn sàng để nhận</span>
                        </div>
                    </div>
                }

                @if (!string.IsNullOrEmpty(Model.TripId))
                {
                    <div class="timeline-item">
                        <div class="timeline-dot"></div>
                        <div class="timeline-content">
                            <strong>Đang vận chuyển</strong><br>
                            <span class="timeline-time">Chuyến xe: @Model.TripId</span>
                        </div>
                    </div>
                }

                <div class="timeline-item">
                    <div class="timeline-dot"></div>
                    <div class="timeline-content">
                        <strong>Đã tiếp nhận đơn hàng</strong><br>
                        <span class="timeline-time">Tại: @Model.SendStation - Lúc: @Model.CreatedAt?.ToString("dd/MM/yyyy HH:mm")</span>
                    </div>
                </div>
            </div>

            <div class="text-center mt-4">
                <p class="text-muted small">Cảm ơn quý khách đã sử dụng dịch vụ!<br><strong>Delivery System</strong></p>
            </div>
        </div>
    </div>
</body>
</html>