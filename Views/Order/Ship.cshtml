@model Delivery_System.Models.TblOrder

@{
    ViewData["Title"] = "Điều phối đơn hàng";
}

@section Styles {
    <link rel="stylesheet" href="~/css/list_order.css" asp-append-version="true" />
}

<div class="od-container od-container-ship">
    <div class="od-card od-card-ship" style="padding:0;">
        <div class="od-page-header od-page-header-ship">
            <div>
                <h3>ĐIỀU PHỐI ĐƠN HÀNG</h3>
                <div class="od-ship-id-highlight">#@Model.OrderId</div>
                <div class="od-header-meta">Chọn chuyến xe phù hợp để gán đơn hàng lên xe</div>
            </div>
        </div>

        <div class="od-form-body">
            @if (TempData["Success"] != null)
            {
                <div class="od-alert od-alert-success">
                    <span>✅ @TempData["Success"]</span>
                </div>
            }

            <div class="od-alert od-alert-info">
                <div>
                    <i class="bi bi-geo-alt"></i> Lộ trình đơn: <strong class="od-route-info-blue">@Model.SendStation ➔ @Model.ReceiveStation</strong><br>
                    <i class="bi bi-box-seam"></i> Hàng hóa: <strong>@Model.ItemName</strong>
                </div>
            </div>

            <div class="od-card-table">
                <table class="od-table od-table-dark-head">
                    <thead>
                        <tr>
                            <th>Mã Chuyến</th>
                            <th>Xe (Biển số)</th>
                            <th>Lộ trình xe</th>
                            <th>Trạng thái</th>
                            <th>Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (ViewBag.AvailableTrips != null && ((IEnumerable<Delivery_System.Models.VwTripList>)ViewBag.AvailableTrips).Any())
                        {
                            foreach (var trip in (IEnumerable<Delivery_System.Models.VwTripList>)ViewBag.AvailableTrips)
                            {
                                <tr>
                                    <td><strong>#@trip.TripId</strong></td>
                                    <td><span class="od-badge od-badge-info">@trip.LicensePlate</span></td>
                                    <td><span class="od-route-info-blue">@trip.Departure ➔ @trip.Destination</span></td>
                                    <td><span class="od-st-going">@trip.Status</span></td>
                                    <td>
                                        <form asp-action="AssignToTrip" method="POST">
                                            <input type="hidden" name="orderId" value="@Model.OrderId" />
                                            <input type="hidden" name="tripId" value="@trip.TripId" />
                                            <input type="hidden" name="source" value="ship" />
                                            <button type="submit" class="od-btn-s od-btn-s-pick">Gán đơn</button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="od-empty-state">
                                    <div class="od-empty-icon"><i class="bi bi-search" style="font-size: 2rem;"></i></div>                                    <p>Không tìm thấy chuyến xe nào phù hợp với lộ trình này!<br>
                                    <small>Hãy tạo chuyến xe mới trước khi điều phối.</small></p>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div style="text-align:center; margin-top:20px;">
                <a asp-action="List" class="od-btn od-btn-secondary">⬅ Quay lại danh sách đơn</a>
            </div>
        </div>
    </div>
</div>
