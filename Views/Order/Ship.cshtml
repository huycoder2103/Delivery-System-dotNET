@model IEnumerable<Delivery_System.Models.VwTripList>

@{
    ViewData["Title"] = "Chọn Chuyến Xe Chuyển Hàng";
    var order = ViewBag.OrderForShip as Delivery_System.Models.TblOrder;
}

@section Styles {
    <link rel="stylesheet" href="~/css/ship_order.css">
}

<div class="page-wrap">
    <div class="hdr">
        <h3>🚚 CHUYỂN HÀNG — CHỌN CHUYẾN XE</h3>
        @if (order != null)
        {
            <div class="meta">
                <span class="badge">Đơn: @order.OrderId</span>
                <span class="badge">Hàng: @order.ItemName</span>
                <span class="badge">Trạm gửi: @order.SendStation</span>
                <span class="badge">Trạm nhận: @order.ReceiveStation</span>
            </div>
        }
    </div>

    <div class="body">
        @if (TempData["SuccessMessage"] != null)
        {
            <div style="background:#d4edda;color:#155724;padding:9px 14px;border-radius:4px;margin-bottom:12px;font-weight:600;">
                ✅ @TempData["SuccessMessage"]
            </div>
        }

        <div class="info">
            Hiển thị các chuyến xe có trạm xuất phát là <strong>"@order?.SendStation"</strong>
            và trạm đến là <strong>"@order?.ReceiveStation"</strong> — phù hợp để chuyển đơn hàng này.
        </div>

        @if (Model != null && Model.Any())
        {
            <table>
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Mã Chuyến</th>
                        <th>Lộ Trình</th>
                        <th>Biển Số</th>
                        <th>Tài Xế</th>
                        <th>Giờ Đi</th>
                        <th>Trạng Thái</th>
                        <th>Thao Tác</th>
                    </tr>
                </thead>
                <tbody>
                    @{ int i = 1; }
                    @foreach (var t in Model)
                    {
                        bool done = t.Status == "Đã đến";
                        <tr>
                            <td>@(i++)</td>
                            <td><strong>@t.TripId</strong></td>
                            <td style="color:#2980b9;font-weight:600;">@t.RouteInfo</td>
                            <td>@(t.LicensePlate ?? "-")</td>
                            <td>@(t.DriverName ?? "-")</td>
                            <td>@(t.DepartureTime ?? "-")</td>
                            <td>
                                @if (done) { <span class="st-done">🏁 Đã đến</span> }
                                else { <span class="st-going">🚛 Đang đi</span> }
                            </td>
                            <td>
                                @if (!done && order != null)
                                {
                                    <button type="button" class="btn-pick" onclick="confirmShip('@order.OrderId', '@t.TripId')">✓ Chọn chuyến này</button>
                                    <form id="shipForm-@t.TripId" asp-action="AssignToTrip" method="POST" style="display:none;">
                                        <input type="hidden" name="orderId" value="@order.OrderId">
                                        <input type="hidden" name="tripId" value="@t.TripId">
                                        <input type="hidden" name="source" value="ship">
                                    </form>
                                }
                                else
                                {
                                    <button class="btn-disabled" disabled>Không khả dụng</button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="no-data">
                <div style="font-size:2rem;margin-bottom:8px;">🔍</div>
                <p>Không tìm thấy chuyến xe phù hợp từ trạm <strong>"@order?.SendStation"</strong> đến trạm <strong>"@order?.ReceiveStation"</strong>.</p>
            </div>
        }

        <a asp-action="List" class="btn-back" style="text-decoration:none; display:inline-block; text-align:center; margin-top: 20px;">⬅ Quay lại DS Hàng</a>
    </div>
</div>

@section Scripts {
    <script>
        function confirmShip(orderId, tripId) {
            Swal.fire({
                title: 'Xác nhận chuyển hàng?',
                text: "Chuyển đơn " + orderId + " lên chuyến " + tripId + "?",
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: '#1a73e8',
                cancelButtonColor: '#d33',
                confirmButtonText: 'Đúng, chuyển ngay!',
                cancelButtonText: 'Hủy'
            }).then((result) => {
                if (result.isConfirmed) {
                    document.getElementById('shipForm-' + tripId).submit();
                }
            })
        }
    </script>
}
