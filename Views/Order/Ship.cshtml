@model Delivery_System.Models.TblOrder

@{
    ViewData["Title"] = "Điều Phối Đơn Hàng";
    var availableTrips = ViewBag.AvailableTrips as IEnumerable<Delivery_System.Models.VwTripList>;
}

@section Styles {
    <link rel="stylesheet" href="~/css/list_order.css?v=@DateTime.Now.Ticks">
}

<div class="order-list-container">
    <div class="modern-page-header">
        <div>
            <h3>🚛 ĐIỀU PHỐI ĐƠN HÀNG</h3>
            <div class="modern-page-header-meta">Mã Đơn: <strong>@Model.OrderId</strong> | Tên hàng: <strong>@Model.ItemName</strong></div>
        </div>
        <div class="header-actions">
            <div class="badge-status-m badge-going">@Model.SendStation ➔ @Model.ReceiveStation</div>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert-success-modern">
            ✅ @TempData["Success"]
        </div>
    }

    <div class="modern-card">
        <h4 class="mb-3">Tìm chuyến xe phù hợp:</h4>
        <div class="trip-table-card">
            <table class="modern-table">
                <thead>
                    <tr>
                        <th>Mã Chuyến</th>
                        <th>Lộ Trình</th>
                        <th>Biển Số</th>
                        <th>Ngày Đi</th>
                        <th>Thao Tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (availableTrips != null && availableTrips.Any())
                    {
                        foreach (var t in availableTrips)
                        {
                            <tr>
                                <td><span class="trip-id-link">@t.TripId</span></td>
                                <td class="route-info-blue">@t.RouteInfo</td>
                                <td class="col-plate-bold">@t.LicensePlate</td>
                                <td class="time-cell">@t.DepartureTime</td>
                                <td class="col-act">
                                    <button type="button" class="btn-action-text btn-s-ship btn-full-width" onclick="confirmShip('@t.TripId', '@t.RouteInfo')">🚚 Gán Xe</button>
                                    
                                    <form id="shipForm-@t.TripId" asp-action="AssignToTrip" method="POST" class="hidden-form">
                                        <input type="hidden" name="orderId" value="@Model.OrderId" />
                                        <input type="hidden" name="tripId" value="@t.TripId" />
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="no-data-msg">
                                <div class="search-empty-icon">🔍</div>
                                <div>Không tìm thấy chuyến xe nào có lộ trình phù hợp đang chờ hàng!</div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <a asp-action="List" class="btn-back back-btn-ship">⬅ Quay lại DS Hàng</a>
    </div>
</div>

@section Scripts {
    <script>
        function confirmShip(tripId, route) {
            Swal.fire({
                title: 'Xác nhận gán xe?',
                text: `Bạn muốn gán đơn hàng này vào chuyến ${tripId} (${route})?`,
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: '#1a73e8',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Đúng, gán ngay!',
                cancelButtonText: 'Hủy'
            }).then((result) => {
                if (result.isConfirmed) {
                    document.getElementById('shipForm-' + tripId).submit();
                }
            })
        }
    </script>
}
