@model Delivery_System.Models.TblOrder

@{
    ViewData["Title"] = "Điều Phối Đơn Hàng";
    var availableTrips = ViewBag.AvailableTrips as IEnumerable<Delivery_System.Models.VwTripList>;
}

@section Styles {
    <link rel="stylesheet" href="~/css/assign_goods.css?v=@DateTime.Now.Ticks">
    <style>
        .order-info-banner {
            background: #fff;
            padding: 20px;
            border-radius: 12px;
            box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1);
            margin-bottom: 25px;
            border-left: 5px solid #1a73e8;
        }
        .order-info-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
            margin-top: 15px;
        }
        .info-item {
            display: flex;
            flex-direction: column;
        }
        .info-label {
            font-size: 0.8rem;
            color: #64748b;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        .info-value {
            font-weight: 700;
            color: #1e293b;
            font-size: 1.05rem;
        }
        .route-arrow {
            color: #1a73e8;
            margin: 0 10px;
        }
    </style>
}

<div class="page-wrap">
    <div class="hdr">
        <h3>🚚 ĐIỀU PHỐI ĐƠN HÀNG LÊN XE</h3>
        <div class="meta">
            <span class="badge">Mã đơn: @Model.OrderId</span>
            <span class="badge">Trạng thái: @Model.ShipStatus</span>
        </div>
    </div>

    <div class="body">
        <!-- Thông tin đơn hàng đang điều phối -->
        <div class="order-info-banner">
            <div style="font-weight: 700; font-size: 1.1rem; color: #1a73e8;">📦 Thông tin đơn hàng</div>
            <div class="order-info-grid">
                <div class="info-item">
                    <span class="info-label">Tên hàng hóa</span>
                    <span class="info-value">@Model.ItemName</span>
                </div>
                <div class="info-item">
                    <span class="info-label">Lộ trình yêu cầu</span>
                    <span class="info-value">
                        @Model.SendStation <span class="route-arrow">➔</span> @Model.ReceiveStation
                    </span>
                </div>
                <div class="info-item">
                    <span class="info-label">Người gửi</span>
                    <span class="info-value">@Model.SenderName (@Model.SenderPhone)</span>
                </div>
            </div>
        </div>

        <div class="info">
            Dưới đây là danh sách các chuyến xe <strong>"Đang đi"</strong> có lộ trình khớp với đơn hàng này. 
            Hãy chọn một chuyến xe để gán đơn hàng.
        </div>

        @if (availableTrips != null && availableTrips.Any())
        {
            <table>
                <thead>
                    <tr>
                        <th>Mã Chuyến</th>
                        <th>Biển Số Xe</th>
                        <th>Lộ Trình Xe</th>
                        <th>Tài Xế</th>
                        <th>Giờ Khởi Hành</th>
                        <th>Ghi Chú</th>
                        <th class="text-center">Thao Tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var t in availableTrips)
                    {
                        <tr>
                            <td><strong class="order-id-highlight">@t.TripId</strong></td>
                            <td><span class="badge" style="background:#e0e7ff; color:#4338ca; border:1px solid #c7d2fe;">@t.LicensePlate</span></td>
                            <td><strong>@t.Departure</strong> ➔ <strong>@t.Destination</strong></td>
                            <td>@t.DriverName</td>
                            <td>@t.DepartureTime</td>
                            <td><small>@t.Notes</small></td>
                            <td class="text-center">
                                <form asp-action="AssignToTrip" method="POST" id="shipForm-@t.TripId">
                                    <input type="hidden" name="orderId" value="@Model.OrderId" />
                                    <input type="hidden" name="tripId" value="@t.TripId" />
                                    <input type="hidden" name="source" value="ship" />
                                    <button type="button" class="btn-assign" onclick="confirmShip('@t.TripId', '@t.LicensePlate')">
                                        🚛 Gán Lên Xe
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="no-data">
                <div class="no-data-icon">🚐</div>
                <p>Hiện không có chuyến xe nào đang chờ có lộ trình từ <strong>"@Model.SendStation"</strong> đến <strong>"@Model.ReceiveStation"</strong>.</p>
                <p style="font-size: 0.9rem; color: #64748b;">Vui lòng tạo chuyến xe mới hoặc kiểm tra lại lộ trình đơn hàng.</p>
            </div>
        }

        <div style="margin-top: 30px;">
            <a asp-action="List" class="btn-back">⬅ Quay lại danh sách đơn hàng</a>
        </div>
    </div>
</div>

<script>
    function confirmShip(tripId, plate) {
        Swal.fire({
            title: 'Xác nhận gán hàng?',
            text: `Bạn muốn gán đơn hàng này lên xe ${plate} (Chuyến: ${tripId})?`,
            icon: 'question',
            showCancelButton: true,
            confirmButtonColor: '#1a73e8',
            cancelButtonColor: '#64748b',
            confirmButtonText: '🚀 Gán ngay',
            cancelButtonText: 'Hủy'
        }).then((result) => {
            if (result.isConfirmed) {
                // Vô hiệu hóa tất cả các nút để tránh bấm nhiều lần
                document.querySelectorAll('.btn-assign').forEach(btn => {
                    btn.disabled = true;
                    btn.style.opacity = '0.5';
                });
                document.getElementById('shipForm-' + tripId).submit();
            }
        })
    }
</script>
