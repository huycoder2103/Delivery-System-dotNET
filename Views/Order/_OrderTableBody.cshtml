@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor
@model IEnumerable<Delivery_System.Models.TblOrder>

@{
    var currentUserRole = HttpContextAccessor.HttpContext.Session.GetString("Role");
    var currentUserID = HttpContextAccessor.HttpContext.Session.GetString("UserID");
}


@if (Model != null && Model.Any())
{
    var stationList = ViewBag.StationList as IEnumerable<Delivery_System.Models.TblStation>;
    var stationDict = stationList?.ToDictionary(s => s.StationName, s => s.StationId.ToString());

    foreach (var o in Model)
    {
        bool isShipped = !string.IsNullOrEmpty(o.TripId);
        bool canEdit = (currentUserRole == "AD" || o.StaffInput == currentUserID);
        <tr>
            <td><span class="text-order-id">@o.OrderId</span></td>
            <td class="col-item-name">@o.ItemName</td>
            <td class="col-route">
                <div class="route-container">
                    <span class="station-send">@(stationDict != null && o.SendStation != null && stationDict.ContainsKey(o.SendStation) ? stationDict[o.SendStation] : o.SendStation)</span>
                    <span class="route-arrow">=></span>
                    <span class="station-receive">@(stationDict != null && o.ReceiveStation != null && stationDict.ContainsKey(o.ReceiveStation) ? stationDict[o.ReceiveStation] : o.ReceiveStation)</span>
                </div>
            </td>
            <td class="col-customer">
                <div class="customer-info-box">
                    <div class="customer-name">@o.SenderName</div>
                    <div class="customer-phone">@o.SenderPhone</div>
                </div>
            </td>
            <td class="col-customer">
                <div class="customer-info-box">
                    <div class="customer-name">@o.ReceiverName</div>
                    <div class="customer-phone">@o.ReceiverPhone</div>
                </div>
            </td>
            <td class="staff-input-badge">@o.StaffInput</td>
            
            <td>
                @if (!string.IsNullOrEmpty(o.Tr))
                {
                    <span class="badge badge-success">@(o.Tr)k</span>
                }
                else { <span style="color:#ccc">—</span> }
            </td>
            <td>
                @if (!string.IsNullOrEmpty(o.Ct))
                {
                    <span class="badge badge-danger">@(o.Ct)k</span>
                }
                else { <span style="color:#ccc">—</span> }
            </td>
            
            <td class="note-cell">@o.Note</td>
            <td class="time-cell">
                @o.CreatedAt?.ToString("dd/MM/yyyy HH:mm")
            </td>
            @* <td>
                @if (o.ShipStatus == "Đã giao")
                {
                    <span class="badge badge-success status-badge-fixed" style="background:#dcfce7; color:#15803d; border:1px solid #bbf7d0;">Đã giao</span>
                }
                else if (!isShipped)
                {
                    <span class="badge badge-warning status-badge-fixed">Chờ giao</span>
                }
                else
                {
                    <span class="badge badge-info status-badge-fixed">Đang chuyển</span>
                }
            </td> *@
            <td class="col-order-id">
                <div class="action-btns-grid">
                    @* Hàng 1: Nút Chuyển (Chỉ hiện khi chưa chuyển) hoặc Xem Chuyến (Nếu đã chuyển) *@
                    @if (!isShipped)
                    {
                        if (currentUserRole == "AD" || o.StaffInput == currentUserID)
                        {
                            <a asp-action="Ship" asp-route-id="@o.OrderId" class="btn-action-text btn-s-ship btn-full-width">🚚 Chuyển</a>
                        }
                        else
                        {
                            <button type="button" class="btn-action-text btn-disabled btn-full-width" title="Bạn không có quyền chuyển đơn này">Chuyển</button>
                        }
                    }
                    else
                    {
                        <a asp-controller="Trip" asp-action="ViewGoods" asp-route-id="@o.TripId" class="btn-action-text btn-s-view-trip btn-full-width">🚛 Xem Xe</a>
                    }

                    @* Hàng 2: Nút In và Nút Sửa/Xóa *@
                    <button type="button" onclick="showPrintOptions('@o.OrderId')" class="btn-action-text btn-s-print">In</button>

                    @if (canEdit && !isShipped)
                    {
                        <a asp-action="Edit" asp-route-id="@o.OrderId" class="btn-action-text btn-s-edit">Sửa</a>
                    }
                    else
                    {
                        <button type="button" class="btn-action-text btn-disabled" title="Hàng đã lên xe hoặc không có quyền">Khóa</button>
                    }
                </div>
            </td>
        </tr>
    }
}
else
{
    <tr>
        <td colspan="12" class="no-data-msg">📭 Không tìm thấy đơn hàng nào phù hợp!</td>
    </tr>
}
