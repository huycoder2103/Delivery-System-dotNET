@model IEnumerable<Delivery_System.Models.TblOrder>

@{
    var currentUserRole = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value;
    var currentUserID = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
    var currentUserStation = Delivery_System.Helpers.UserExtensions.GetStationName(User);
}


@if (Model != null && Model.Any())
{
    var stationList = ViewBag.StationList as IEnumerable<Delivery_System.Models.TblStation>;
    var stationDict = stationList?.ToDictionary(s => s.StationName, s => s.StationId.ToString());
    var currentPage = (int)(ViewBag.CurrentPage ?? 1);
    var pageSize = 10;
    var index = (currentPage - 1) * pageSize + 1;

    foreach (var o in Model)
    {
        bool isShipped = !string.IsNullOrEmpty(o.TripId);
        bool canEdit = (currentUserRole == "AD" || o.StaffInput == currentUserID);
        bool canShip = (currentUserRole == "AD" || o.SendStation == currentUserStation);
        <tr>
            <td class="od-col-stt">@index</td>
            <td><span class="od-font-bold">@o.OrderId</span></td>
            <td class="od-col-item">@o.ItemName</td>
            <td>
                <div class="od-route-box">
                    @{
                        var sendID = (stationDict != null && o.SendStation != null && stationDict.ContainsKey(o.SendStation) ? stationDict[o.SendStation] : o.SendStation);
                        var receiveID = (stationDict != null && o.ReceiveStation != null && stationDict.ContainsKey(o.ReceiveStation) ? stationDict[o.ReceiveStation] : o.ReceiveStation);
                    }
                    <span class="od-station-send" onclick="showStationInfo('@o.SendStation', '@sendID')">@sendID</span>
                    <span class="od-route-arrow">➔</span>
                    <span class="od-station-receive" onclick="showStationInfo('@o.ReceiveStation', '@receiveID')">@receiveID</span>
                </div>
            </td>
            <td>
                <div class="od-cust-info">
                    <div class="od-cust-name">@o.SenderName</div>
                    <div class="od-cust-phone">@o.SenderPhone</div>
                </div>
            </td>
            <td>
                <div class="od-cust-info">
                    <div class="od-cust-name">@o.ReceiverName</div>
                    <div class="od-cust-phone">@o.ReceiverPhone</div>
                </div>
            </td>
            <td class="od-staff od-staff-id-text">@o.StaffInput</td>
            
            <td class="od-col-paid">
                @if (o.Tr.HasValue && o.Tr != 0)
                {
                    <span class="od-badge od-badge-success">@(o.Tr.Value.ToString("N0"))k</span>
                }
                else { <span>—</span> }
            </td>
            <td class="od-col-paid">
                @if (o.Ct.HasValue && o.Ct != 0)
                {
                    <span class="od-badge od-badge-pending-red">@(o.Ct.Value.ToString("N0"))k</span>
                }
                else { <span>—</span> }
            </td>
            
            <td>@o.Note</td>
            <td>
                @o.CreatedAt?.ToString("dd/MM HH:mm")
            </td>
            <td class="od-col-act">
                <div class="od-action-grid">
                    @if (o.ShipStatus == "Đã giao")
                    {
                        <span class="od-btn od-btn-s od-badge-delivered od-delivery-status-box">Đã giao</span>
                        <a asp-controller="Trip" asp-action="ViewGoods" asp-route-id="@o.TripId" class="od-btn od-btn-s od-btn-view-trip">🚛 Xem Xe</a>
                    }
                    else if (o.ShipStatus == "Đã đến")
                    {
                        <button type="button" onclick="deliverOrderDirect('@o.OrderId')" class="od-btn od-btn-s od-btn-s-pick">✅ Giao</button>
                        <a asp-controller="Trip" asp-action="ViewGoods" asp-route-id="@o.TripId" class="od-btn od-btn-s od-btn-view-trip">🚛 Xem Xe</a>
                    }
                    else if (!isShipped)
                    {
                        if (canShip)
                        {
                            <a asp-action="Ship" asp-route-id="@o.OrderId" class="od-btn od-btn-s od-btn-s-ship od-btn-full">🚚 Chuyển</a>
                        }
                        else
                        {
                            <button type="button" class="od-btn od-btn-s od-btn-full od-btn-disabled" title="Bạn không có quyền chuyển đơn này (Phải thuộc trạm @o.SendStation)">Chuyển</button>
                        }
                    }
                    else
                    {
                        <a asp-controller="Trip" asp-action="ViewGoods" asp-route-id="@o.TripId" class="od-btn od-btn-s od-btn-full od-btn-view-trip">🚛 Xem Xe</a>
                    }

                    <button type="button" onclick="showPrintOptions('@o.OrderId')" class="od-btn od-btn-s od-btn-s-print">In</button>

                    @if (canEdit && string.IsNullOrEmpty(o.TripId))
                    {
                        <a asp-action="Edit" asp-route-id="@o.OrderId" class="od-btn od-btn-s od-btn-s-edit">Sửa</a>
                    }
                    else
                    {
                        <button type="button" class="od-btn od-btn-s od-btn-disabled" title="Hàng đã lên xe hoặc đã hoàn thành, không thể sửa">Khóa</button>
                    }
                </div>
            </td>
        </tr>
        index++;
    }
}
else
{
    <tr>
        <td colspan="12" class="od-table-empty-state">📭 Không tìm thấy đơn hàng nào phù hợp!</td>
    </tr>
}
